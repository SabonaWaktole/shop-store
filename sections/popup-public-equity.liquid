<!-- sections/popup-public-equity.liquid -->
{%- if section.settings.enable_popup -%}
    {%- style -%}
        #popup-overlay[data-section-id="{{ section.id }}"] {
            background-color: {{ section.settings.overlay_color | color_modify: 'alpha', 0.8 }};
        }
        #popup-modal[data-section-id="{{ section.id }}"] {
            background-color: {{ section.settings.bg_color }};
            color: {{ section.settings.text_color }};
        }
        #popup-modal[data-section-id="{{ section.id }}"] .popup-input {
            border-color: {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
            color: {{ section.settings.text_color }};
        }
        #popup-modal[data-section-id="{{ section.id }}"] .popup-input::placeholder {
            color: {{ section.settings.text_color | color_modify: 'alpha', 0.5 }};
        }
    {%- endstyle -%}

    <div id="popup-overlay" data-section-id="{{ section.id }}" class="fixed inset-0 z-[100] backdrop-blur-[10px] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-500" data-delay="{{ section.settings.delay_seconds | times: 1000 }}" data-frequency="{{ section.settings.frequency }}">
        <div id="popup-modal" data-section-id="{{ section.id }}" class="relative w-full max-w-4xl flex flex-col md:flex-row transform scale-95 opacity-0 transition-all duration-500 shadow-2xl">
            
            <button class="absolute top-4 right-4 z-10 text-on-surface-variant hover:text-primary transition-colors popup-close" aria-label="Close">
                <span class="material-symbols-outlined">close</span>
            </button>

            {%- if section.settings.image != blank -%}
                <div class="hidden md:block w-1/2 relative overflow-hidden bg-surface">
                    <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" class="w-full h-full object-cover filter grayscale contrast-125">
                </div>
            {%- endif -%}

            <div class="w-full {% if section.settings.image != blank %}md:w-1/2{% endif %} p-12 md:p-16 flex flex-col justify-center">
                {%- if section.settings.subheading != blank -%}
                    <span class="font-label-mono text-label-mono uppercase tracking-widest mb-4 opacity-70">{{ section.settings.subheading }}</span>
                {%- endif -%}
                
                <h2 class="font-display-xl text-4xl md:text-5xl uppercase tracking-tighter mb-6 leading-none">{{ section.settings.heading }}</h2>
                
                {%- if section.settings.text != blank -%}
                    <div class="font-body-main text-body-main opacity-80 mb-8 prose prose-invert">
                        {{ section.settings.text }}
                    </div>
                {%- endif -%}

                {%- form 'customer', class: 'flex flex-col gap-4' -%}
                    <input type="hidden" name="contact[tags]" value="newsletter, popup">
                    
                    {%- if form.posted_successfully? -%}
                        <p class="font-label-mono text-label-mono text-primary uppercase p-4 border border-primary bg-primary/10">
                            {{ 'general.newsletter_form.confirmation' | t | default: 'INITIALIZATION COMPLETE. CHECK YOUR COMM LINK.' }}
                        </p>
                    {%- else -%}
                        <div class="flex flex-col gap-4">
                            <input type="email" name="contact[email]" class="popup-input w-full bg-transparent border-b p-4 font-label-mono text-label-mono uppercase outline-none focus:border-current transition-colors" placeholder="{{ section.settings.email_placeholder }}" required>
                            
                            {%- if section.settings.enable_sms -%}
                                <input type="tel" name="contact[phone]" class="popup-input w-full bg-transparent border-b p-4 font-label-mono text-label-mono uppercase outline-none focus:border-current transition-colors" placeholder="{{ section.settings.sms_placeholder }}">
                            {%- endif -%}

                            <button type="submit" class="w-full mt-4 border py-4 font-label-mono text-label-mono uppercase tracking-widest transition-all duration-300 hover:opacity-80" style="border-color: {{ section.settings.text_color }}; color: {{ section.settings.bg_color }}; background-color: {{ section.settings.text_color }}">
                                {{ section.settings.button_label }}
                            </button>
                        </div>
                        
                        {%- if form.errors -%}
                            <p class="font-label-mono text-label-mono text-error uppercase mt-4">
                                {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
                            </p>
                        {%- endif -%}
                    {%- endif -%}
                {%- endform -%}

                {%- if section.settings.footer_text != blank -%}
                    <div class="mt-8 font-caption text-caption opacity-50 uppercase tracking-widest text-center">
                        {{ section.settings.footer_text }}
                    </div>
                {%- endif -%}
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const overlay = document.querySelector('#popup-overlay[data-section-id="{{ section.id }}"]');
            const modal = document.querySelector('#popup-modal[data-section-id="{{ section.id }}"]');
            const closeBtns = overlay.querySelectorAll('.popup-close');
            
            if (!overlay || !modal) return;

            const delay = parseInt(overlay.dataset.delay) || 5000;
            const frequencyDays = parseInt(overlay.dataset.frequency) || 7;
            const cookieName = 'public_equity_popup_seen';

            function getCookie(name) {
                const value = `; ${document.cookie}`;
                const parts = value.split(`; ${name}=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
            }

            function setCookie(name, value, days) {
                const date = new Date();
                date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                document.cookie = `${name}=${value};expires=${date.toUTCString()};path=/`;
            }

            function openPopup() {
                overlay.classList.remove('opacity-0', 'pointer-events-none');
                modal.classList.remove('scale-95', 'opacity-0');
            }

            function closePopup() {
                overlay.classList.add('opacity-0', 'pointer-events-none');
                modal.classList.add('scale-95', 'opacity-0');
                setCookie(cookieName, 'true', frequencyDays);
            }

            closeBtns.forEach(btn => btn.addEventListener('click', closePopup));
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) closePopup();
            });

            // Shopify design mode check
            if (Shopify && Shopify.designMode) {
                openPopup();
            } else if (!getCookie(cookieName)) {
                setTimeout(openPopup, delay);
            }
        });
    </script>
{%- endif -%}

{% schema %}
{
  "name": "Popup Modal (PE)",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable Popup",
      "default": true
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "sec",
      "label": "Delay until popup appears",
      "default": 5
    },
    {
      "type": "range",
      "id": "frequency",
      "min": 1,
      "max": 30,
      "step": 1,
      "unit": "day",
      "label": "Frequency (days until shown again)",
      "default": 7
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Displays on the left side on desktop"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SYSTEM ALERT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INITIALIZE ACCESS"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Join the network to receive early access to drops and classified intel.</p>"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "ENTER EMAIL ADDRESS"
    },
    {
      "type": "checkbox",
      "id": "enable_sms",
      "label": "Enable SMS field",
      "default": true
    },
    {
      "type": "text",
      "id": "sms_placeholder",
      "label": "SMS Placeholder",
      "default": "ENTER PHONE NUMBER (OPTIONAL)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SUBMIT REQUEST"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "<p>By subscribing you agree to our terms.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
