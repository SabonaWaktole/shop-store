<div class="w-full max-w-container-max mx-auto pt-[60px] md:pt-[100px] pb-32 px-margin-mobile md:px-margin-desktop" data-section-id="{{ section.id }}" data-section-type="page">
    
    {%- if section.settings.show_title -%}
        <header class="mb-16 border-b border-outline-variant pb-8">
            <h1 class="font-display-xl text-display-xl uppercase max-w-5xl leading-none text-[36px] md:text-[64px]">
                {{ page.title }}
            </h1>
        </header>
    {%- endif -%}

    <div class="max-w-4xl prose-pe">
        {{ page.content }}
    </div>
</div>

<style>
    /* Brutalist prose styling for Shopify rich text */
    .prose-pe {
        color: #c4c7c8; /* on-surface-variant */
    }
    .prose-pe h1,
    .prose-pe h2,
    .prose-pe h3,
    .prose-pe h4,
    .prose-pe h5,
    .prose-pe h6 {
        color: #ffffff;
        font-family: 'Inter', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        line-height: 110%;
    }
    .prose-pe h1 { font-size: 48px; }
    .prose-pe h2 { font-size: 32px; }
    .prose-pe h3 { font-size: 24px; }
    .prose-pe h4 { font-size: 18px; }
    .prose-pe p {
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        line-height: 160%;
        letter-spacing: 0.01em;
        margin-bottom: 1.5rem;
    }
    .prose-pe a {
        color: #ffffff;
        text-decoration: underline;
        text-underline-offset: 4px;
        transition: opacity 0.3s;
    }
    .prose-pe a:hover {
        opacity: 0.7;
    }
    .prose-pe ul,
    .prose-pe ol {
        padding-left: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .prose-pe li {
        margin-bottom: 0.5rem;
        font-size: 16px;
        line-height: 160%;
    }
    .prose-pe ul li::marker {
        color: #ffffff;
    }
    .prose-pe blockquote {
        border-left: 1px solid #444748;
        padding-left: 1.5rem;
        font-style: italic;
        color: #8e9192;
        margin: 2rem 0;
    }
    .prose-pe hr {
        border: none;
        border-top: 1px solid #444748;
        margin: 3rem 0;
    }
    .prose-pe table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
    }
    .prose-pe th,
    .prose-pe td {
        border: 1px solid #444748;
        padding: 0.75rem 1rem;
        text-align: left;
        font-family: 'Geist', monospace;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }
    .prose-pe th {
        background: #1f1f20;
        color: #ffffff;
    }
    .prose-pe img {
        width: 100%;
        filter: grayscale(100%) contrast(1.25);
        transition: filter 0.7s;
    }
    .prose-pe img:hover {
        filter: grayscale(0%) contrast(1);
    }
</style>

{% schema %}
{
  "name": "Standard Page (PE)",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Page Title",
      "default": true
    }
  ]
}
{% endschema %}
