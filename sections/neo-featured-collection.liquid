          </div>
          <span class="font-utility-label text-[14px] text-primary-container">820_CR</span>
        </div>
      </div>
      
      <!-- Product Card 3 -->
      <div class="group relative">
        <div class="aspect-[3/4] bg-surface-container-low overflow-hidden relative border border-outline/10 group-hover:border-primary-container transition-all duration-500">
          <img class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" alt="Operator Boots Mk.II" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCBRajcpyjSWUwkAC_ze3IGW3EW9-rvjCV0gD3qlbj846t_xPB-OPicf3jy0Z9PYse3upQlD8scnxjxiHeX_un2kclHi6D4oNstrxeEI2OVkEvGJmGIeX0mSpjvoHQ-1UhyOMzm01wyJ35Cnt6F-eZgeFRDuZuiF8E8bYXsHsFcxBuV3LPGghIhMfyM8tMxAILcJTJ6s9Dh0_Cppk582f-lTsnbYKAkBgJTy1rXv4cmfc9KaeKbyA23wUQ67fJAbVThFK-IXKGwIj9G"/>
          <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-background/90 backdrop-blur-sm">
            <button class="w-full py-3 bg-primary-container text-black font-utility-label text-[12px] font-bold uppercase tracking-widest hover:bg-white transition-colors">QUICK_ADD</button>
          </div>
        </div>
        <div class="mt-6 flex justify-between items-start">
          <div>
            <h4 class="font-utility-label text-[14px] uppercase tracking-tight text-on-surface">OPERATOR_BOOTS_MK.II</h4>
            <p class="font-utility-label text-[10px] text-on-surface-variant uppercase mt-1">FOOTWEAR // KINETIC</p>
          </div>
          <span class="font-utility-label text-[14px] text-primary-container">1,100_CR</span>
        </div>
      </div>
      
      <!-- Product Card 4 -->
      <div class="group relative">
        <div class="aspect-[3/4] bg-surface-container-low overflow-hidden relative border border-outline/10 group-hover:border-primary-container transition-all duration-500">
          <img class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" alt="Neural Link Headpiece" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB-V6NAQsIX_9S5cH_bviyy6nqhhMLck728_9qTDyB8tu6mit4AVru4HSV3DMyu3orLvdFmKWU5IK_ug_pDFdmn8U-mUwHLYU7xaIbowFLV70lq6Bm-drlP8slv1MIEpwi8vI71x1DATzNjPnzgPJmVoRkxurvV8zCL2XvB4ZeQ9MrI110JflmbPNyF6iu9IUIbHHziTnYkjgtkHlwSVa2dbDfgDFNi9x3BP9QxOSbRxXP-oc4PDK9OnnMllgq7kRo1CEerAMW4N_o7"/>
          <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-background/90 backdrop-blur-sm">
            <button class="w-full py-3 bg-primary-container text-black font-utility-label text-[12px] font-bold uppercase tracking-widest hover:bg-white transition-colors">QUICK_ADD</button>
          </div>
        </div>
        <div class="mt-6 flex justify-between items-start">
          <div>
            <h4 class="font-utility-label text-[14px] uppercase tracking-tight text-on-surface">NEURAL_LINK_HEADPIECE</h4>
            <p class="font-utility-label text-[10px] text-on-surface-variant uppercase mt-1">ACCESSORY // UPLINK</p>
          </div>
          <span class="font-utility-label text-[14px] text-primary-container">450_CR</span>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>
