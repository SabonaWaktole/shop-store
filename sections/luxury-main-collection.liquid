{% schema %}
{
  "name": "Luxury Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    }
  ]
}
{% endschema %}

<section class="max-w-[1600px] mx-auto px-4 md:px-8 py-12 lg:py-24">
    <!-- Header -->
    <div class="mb-12 border-b border-border pb-8">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tighter uppercase mb-4">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
            <div class="text-sm text-muted-foreground max-w-2xl">{{ collection.description }}</div>
        {%- endif -%}
    </div>

    <!-- Grid -->
    {% paginate collection.products by section.settings.products_per_page %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
            {%- for product in collection.products -%}
                <div class="group relative">
                    <a href="{{ product.url }}" class="block aspect-portrait bg-muted overflow-hidden relative">
                        {%- if product.featured_image -%}
                            <img class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-0" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}">
                            {%- if product.images[1] -%}
                                <img class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 group-hover:opacity-100" src="{{ product.images[1] | image_url: width: 600 }}" alt="{{ product.images[1].alt | escape }}">
                            {%- else -%}
                                <img class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 group-hover:opacity-100" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}">
                            {%- endif -%}
                        {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
                        {%- endif -%}
                        
                        <div class="absolute top-4 left-4 flex flex-col gap-2">
                            {%- if product.tags contains 'preorder' -%}
                                <span class="bg-primary text-primary-foreground text-[10px] font-medium tracking-widest uppercase px-3 py-1">Pre-order</span>
                            {%- elsif product.available == false -%}
                                <span class="bg-muted text-muted-foreground border border-border text-[10px] font-medium tracking-widest uppercase px-3 py-1">Sold Out</span>
                            {%- elsif product.tags contains 'new' -%}
                                <span class="bg-primary text-primary-foreground text-[10px] font-medium tracking-widest uppercase px-3 py-1">New</span>
                            {%- endif -%}
                        </div>
                    </a>
                    
                    <div class="mt-4 flex flex-col gap-1">
                        <a href="{{ product.url }}" class="text-sm font-medium tracking-wide text-primary hover:underline underline-offset-4">
                            {{ product.title }}
                        </a>
                        <span class="text-xs text-muted-foreground">{{ product.price | money }}</span>
                    </div>
                </div>
            {%- else -%}
                <div class="col-span-full py-16 text-center text-muted-foreground">
                    <p>No products found in this collection.</p>
                </div>
            {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
            <div class="mt-16 flex justify-center">
                {{ paginate | default_pagination: next: 'Next &rarr;', previous: '&larr; Prev' }}
            </div>
        {%- endif -%}
    {% endpaginate %}
</section>
