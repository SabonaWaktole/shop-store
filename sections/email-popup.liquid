{% schema %}
{
  "name": "Email Popup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Waitlist"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Sign up for exclusive early access to Drop 01."
    }
  ]
}
{% endschema %}

<div id="email-popup" class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-[200] hidden flex items-center justify-center p-4">
    <div class="bg-background w-full max-w-md p-8 relative shadow-2xl animate-fade-in-up">
        <button class="absolute top-4 right-4 text-muted-foreground hover:text-primary transition-colors" onclick="dismissPopup()">
            <span class="material-symbols-outlined font-light">close</span>
        </button>
        
        <div class="text-center mb-8">
            <h2 class="text-2xl font-semibold tracking-tighter uppercase mb-2">{{ section.settings.heading }}</h2>
            <p class="text-sm text-muted-foreground">{{ section.settings.text }}</p>
        </div>

        {% form 'customer', id: 'PopupContactForm' %}
            <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
            
            {%- if form.posted_successfully? -%}
                <div class="p-4 bg-muted text-primary text-sm font-medium text-center mb-4 uppercase tracking-wide">
                    You're on the list.
                </div>
                <script>
                    localStorage.setItem('user_subscribed', 'true');
                </script>
            {%- else -%}
                {%- if form.errors -%}
                    <div class="p-4 border border-error text-error text-sm mb-4">
                        {{ form.errors | default_errors }}
                    </div>
                {%- endif -%}

                <div id="popup-step-1" class="space-y-4">
                    <input type="email" 
                           name="contact[email]" 
                           class="w-full bg-background border-b border-border px-0 py-3 text-sm focus:border-primary focus:ring-0 transition-colors placeholder:text-muted-foreground" 
                           placeholder="Email Address"
                           required>
                           
                    <div class="flex flex-col gap-3 pt-2">
                        <button type="button" onclick="submitPopupStep1()" class="w-full bg-primary text-primary-foreground font-medium text-sm tracking-widest uppercase py-4 hover:bg-primary/90 transition-colors">
                            Subscribe &rarr;
                        </button>
                        <button type="button" onclick="dismissPopup()" class="w-full text-center text-xs text-muted-foreground hover:text-primary transition-opacity opacity-50 hover:opacity-100 uppercase tracking-widest">
                            Skip for now
                        </button>
                    </div>
                </div>

                <div id="popup-step-2" class="space-y-4 hidden">
                    <div class="flex items-end gap-2 w-full">
                        <select id="country-code-popup" class="bg-background border-b border-border px-2 py-3 text-sm focus:border-primary focus:ring-0 transition-colors w-[90px] text-foreground">
                            <option value="+1">US (+1)</option>
                            <option value="+1">CA (+1)</option>
                        </select>
                        <input type="tel" 
                               name="contact[phone]"
                               id="local-phone-popup"
                               class="flex-1 w-full bg-background border-b border-border px-0 py-3 text-sm focus:border-primary focus:ring-0 transition-colors placeholder:text-muted-foreground" 
                               placeholder="Phone Number"
                               required>
                    </div>
                           
                    <div class="flex items-start gap-2 pt-2">
                        <input type="checkbox" id="sms-consent-popup" name="customer[accepts_sms_marketing]" class="mt-0.5 border-border text-primary focus:ring-primary rounded-sm bg-transparent">
                        <label for="sms-consent-popup" class="text-sm text-foreground">Text me early access</label>
                    </div>
                    
                    <p class="text-[10.5px] leading-relaxed text-muted-foreground italic">
                        By checking this box and subscribing, you agree to receive recurring automated marketing texts from PUBLIC EQUITY at the number provided. Consent is not a condition of purchase. Msg frequency varies. Msg & data rates may apply. Reply STOP to cancel, HELP for help. <a href="https://publicequity.shop/policies/terms-of-service" class="underline hover:text-primary transition-colors">Terms</a> · <a href="https://publicequity.shop/policies/privacy-policy" class="underline hover:text-primary transition-colors">Privacy Policy</a>
                    </p>

                    <div class="flex flex-col gap-3 pt-2">
                        <button type="submit" class="w-full bg-primary text-primary-foreground font-medium text-sm tracking-widest uppercase py-4 hover:bg-primary/90 transition-colors">
                            Subscribe &rarr;
                        </button>
                        <button type="button" onclick="dismissPopup()" class="w-full text-center text-xs text-muted-foreground hover:text-primary transition-opacity opacity-50 hover:opacity-100 uppercase tracking-widest">
                            Skip for now
                        </button>
                    </div>
                </div>
            {%- endif -%}
        {% endform %}
    </div>
</div>

<style>
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in-up {
    animation: fadeInUp 0.4s ease-out forwards;
}
</style>

<script>
// Show popup automatically after 5 seconds if not dismissed in this session AND user is not subscribed
(function() {
    var isCustomer = {% if customer %}true{% else %}false{% endif %};
    var hasSubscribed = localStorage.getItem('user_subscribed') === 'true';
    var dismissedInSession = sessionStorage.getItem('popup_dismissed') === 'true';

    // Also reset if in theme editor to make testing easier
    if (window.Shopify && window.Shopify.designMode) {
        dismissedInSession = false;
        hasSubscribed = false;
    }

    if (!dismissedInSession && !hasSubscribed && !isCustomer) {
        setTimeout(() => {
            document.getElementById('email-popup').classList.remove('hidden');
        }, 5000);
    }
})();

function submitPopupStep1() {
    var form = document.getElementById('PopupContactForm');
    var emailInput = form.querySelector('input[name="contact[email]"]');
    if (!emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
    }
    
    var formData = new FormData(form);
    fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    
    document.getElementById('popup-step-1').classList.add('hidden');
    document.getElementById('popup-step-2').classList.remove('hidden');
    localStorage.setItem('user_subscribed', 'true');
}

document.getElementById('PopupContactForm').addEventListener('submit', function(e) {
    var countryCode = document.getElementById('country-code-popup').value;
    var phoneInput = document.getElementById('local-phone-popup');
    if (!phoneInput.value.startsWith('+')) {
        phoneInput.value = countryCode + phoneInput.value;
    }
});

function dismissPopup() {
    document.getElementById('email-popup').classList.add('hidden');
    sessionStorage.setItem('popup_dismissed', 'true');
}

// Close on outside click
document.getElementById('email-popup').addEventListener('click', function(e) {
    if (e.target === this) {
        dismissPopup();
    }
});
</script>
