{% style %}
  .custom-password-main-section {
    font-family: var(--font-body-family, sans-serif);
    background-color: {{ section.settings.bg_color | default: 'transparent' }};
    color: {{ section.settings.text_color | default: '#000000' }};
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px 20px;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .custom-password-block {
    width: 100%;
    margin-bottom: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .custom-password-block:last-child {
    margin-bottom: 0;
  }
  .custom-password-logo {
    height: auto;
  }
  .custom-password-hero {
    height: auto;
  }
  .custom-password-heading {
    font-size: 24px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }
  .custom-password-subheading {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }
  .custom-password-embed {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  /* Force internal elements of the embed to center if they don't inherit it */
  .custom-password-embed * {
    text-align: center;
  }
  
  @media screen and (max-width: 768px) {
    .custom-password-heading {
      font-size: 18px;
    }
    .custom-password-main-section {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{% endstyle %}

<div class="custom-password-main-section">
  {% for block in section.blocks %}
    <div class="custom-password-block" {{ block.shopify_attributes }}>
      {% case block.type %}
        {% when 'logo' %}
          {% if block.settings.image %}
            {% assign logo_width_double = block.settings.width | times: 2 %}
            <img src="{{ block.settings.image | image_url: width: logo_width_double }}" 
                 alt="{{ block.settings.image.alt | default: 'Logo' }}" 
                 class="custom-password-logo" 
                 style="max-width: {{ block.settings.width }}px; width: 100%;"
                 loading="lazy">
          {% else %}
            <h1 class="custom-password-logo-text" style="font-size: 32px; font-weight: bold; text-transform: uppercase;">
              {{ shop.name }}
            </h1>
          {% endif %}

        {% when 'hero_image' %}
          {% if block.settings.image %}
            {% assign hero_width_double = block.settings.width | times: 2 %}
            <img src="{{ block.settings.image | image_url: width: hero_width_double }}" 
                 alt="{{ block.settings.image.alt | default: 'Hero Image' }}" 
                 class="custom-password-hero" 
                 style="max-width: {{ block.settings.width }}px; width: 100%;"
                 loading="lazy">
          {% endif %}

        {% when 'heading' %}
          {% if block.settings.text != blank %}
            <div class="custom-password-heading">
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% when 'subheading' %}
          {% if block.settings.text != blank %}
            <div class="custom-password-subheading">
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% when 'html_embed' %}
          {% if block.settings.html != blank %}
            <div class="custom-password-embed">
              {{ block.settings.html }}
            </div>
          {% endif %}
          
      {% endcase %}
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Custom Password Main",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "width",
          "min": 50,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Max Width",
          "default": 200
        }
      ]
    },
    {
      "type": "hero_image",
      "name": "Hero Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "width",
          "min": 100,
          "max": 1000,
          "step": 20,
          "unit": "px",
          "label": "Max Width",
          "default": 400
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "DROPPING SATURDAY JULY 11TH — 11AM PST"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "BLACK HICKORY DOUBLE KNEE CAPRIS."
        }
      ]
    },
    {
      "type": "html_embed",
      "name": "Custom HTML Embed",
      "settings": [
        {
          "type": "html",
          "id": "html",
          "label": "HTML code",
          "info": "Paste your Omnisend or other embed code here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Password Main",
      "blocks": [
        {
          "type": "html_embed"
        },
        {
          "type": "logo"
        },
        {
          "type": "hero_image"
        },
        {
          "type": "heading"
        },
        {
          "type": "subheading"
        }
      ]
    }
  ]
}
{% endschema %}
