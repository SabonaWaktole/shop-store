{% schema %}
{
  "name": "NEO-DYS Lookbook",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Small Label",
      "default": "LOOKBOOK_02"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "SYSTEM_VISUALS"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Lookbook Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "offset_down",
          "label": "Offset downwards (stagger effect)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NEO-DYS Lookbook"
    }
  ]
}
{% endschema %}

<!-- Lookbook Editorial Grid -->
<section class="py-section-gap bg-surface-container-low px-margin-desktop">
  <div class="text-center mb-16">
    <h3 class="font-utility-label text-primary-container uppercase tracking-[0.5em] mb-4">{{ section.settings.label }}</h3>
    <h2 class="font-headline-lg text-headline-lg uppercase">{{ section.settings.title }}</h2>
  </div>
  
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="aspect-[2/3] overflow-hidden bg-black relative group {% if block.settings.offset_down %}mt-12{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | escape }}" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Fallback Data -->
      <div class="aspect-[2/3] overflow-hidden bg-black relative group">
        <img alt="Editorial 1" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBBz83wMbxdlDxRajV6xjEtZ01vwssyXPvGjglYiyrWaiJ2rukI_z8V8EEYPb0nf5pFKG2149iYcdnnkNeb-p1pIpiGgrSHg2fn8LHc5LW3ZiwkendOLIOvKjFGi9oTxCdJR8AibLc71udb99l3BSHXe3h-24oOMFw5hi6CdGcyDlgUG-UikObgcg-3xwZX7XrEHD6DlTnpqloEUSL7rQtBYbmkDPT-ggXBkN2Mo2jTZ-LbxOkHZ5_ZyGQ6FJjlNlwZjBopGKzpSCQQ"/>
