{% schema %}
{
  "name": "NEO-DYS Search",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LOCATE_ASSET"
    }
  ]
}
{% endschema %}

<section class="py-section-gap px-margin-desktop bg-surface-container-lowest relative min-h-screen" style="background-color: #ffffff;" data-header-theme="light">
    <!-- Header -->
    <div class="mb-16 border-l-2 border-primary-container pl-6 relative z-10">
        <span class="font-utility-label text-primary-container mb-2 block uppercase tracking-widest">// GLOBAL_DATABASE_QUERY</span>
        <h1 class="font-headline-lg text-4xl md:text-5xl uppercase">{{ section.settings.heading }}</h1>
        
        <form action="{{ routes.search_url }}" method="get" role="search" class="mt-8 max-w-2xl flex items-center relative">
            <input type="hidden" name="type" value="product">
            <input type="search"
                   name="q"
                   value="{{ search.terms | escape }}"
                   placeholder="ENTER_SEARCH_PARAMETERS"
                   class="w-full bg-surface-container-low border border-outline-variant p-4 pr-16 font-utility-label text-on-surface focus:border-primary-container focus:ring-0 transition-colors uppercase">
            <button type="submit" class="absolute right-0 top-0 h-full px-4 text-on-surface hover:text-primary-container transition-colors">
                <span class="material-symbols-outlined">search</span>
            </button>
        </form>
    </div>

    {%- if search.performed -%}
        <!-- Results Info -->
        <div class="flex justify-between items-end mb-8 border-b border-outline-variant pb-4 relative z-10">
            <div class="font-utility-label text-xs text-on-surface-variant uppercase">
                {%- if search.results_count == 0 -%}
                    NO_MATCHES_FOUND_IN_DATABASE
                {%- else -%}
                    {{ search.results_count }} ASSETS_LOCATED
                {%- endif -%}
            </div>
            {%- if search.results_count > 0 -%}
                <div class="font-utility-label text-[10px] text-primary-fixed-dim border-l border-primary-fixed-dim pl-4 py-1">
                    QUERY_SUCCESSFUL
                </div>
            {%- endif -%}
        </div>

        {%- if search.results_count > 0 -%}
            <!-- Results Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter relative z-10">
                {% paginate search.results by 16 %}
                    {%- for item in search.results -%}
                        {%- if item.object_type == 'product' -%}
                            <div class="product-card group cursor-pointer">
                                <a href="{{ item.url }}" class="block relative aspect-[3/4] overflow-hidden bg-surface-container-low border border-outline-variant mb-4">
                                    {%- if item.featured_image -%}
                                        <img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.featured_image.alt | escape }}" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700">
                                    {%- else -%}
                                        {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700' }}
                                    {%- endif -%}
                                    
                                    <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-background/90 backdrop-blur-sm">
                                        <div class="w-full py-3 bg-primary-container text-black text-center font-utility-label text-[12px] font-bold uppercase tracking-widest hover:bg-white transition-colors">VIEW_DETAILS</div>
                                    </div>
                                </a>
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h4 class="font-utility-label text-[14px] uppercase tracking-tight text-on-surface"><a href="{{ item.url }}">{{ item.title }}</a></h4>
                                        <p class="font-utility-label text-[10px] text-on-surface-variant uppercase mt-1">{{ item.type | default: 'UNKNOWN_ASSET' }} // {{ item.vendor | default: 'SYSTEM' }}</p>
                                    </div>
                                    <span class="font-utility-label text-[14px] text-primary-container">
                                        {%- if item.price_varies -%}
                                            FROM {{ item.price_min | money_without_currency | replace: ',', '' | replace: '.00', '' }}_CR
                                        {%- else -%}
                                            {{ item.price | money_without_currency | replace: ',', '' | replace: '.00', '' }}_CR
                                        {%- endif -%}
                                    </span>
                                </div>
                            </div>
                        {%- endif -%}
                    {%- endfor -%}
                {% endpaginate %}
            </div>
        {%- else -%}
            <!-- Empty State -->
            <div class="py-24 text-center">
                <span class="material-symbols-outlined text-6xl text-outline-variant mb-6 font-light">search_off</span>
                <p class="font-headline-lg text-2xl uppercase tracking-tighter text-on-surface mb-2">QUERY_RETURNED_NULL</p>
                <p class="font-utility-label text-xs text-on-surface-variant uppercase tracking-widest max-w-md mx-auto">THE REQUESTED ASSET COULD NOT BE LOCATED IN THE ARCHIVE. PLEASE ADJUST YOUR SEARCH PARAMETERS OR RETURN TO THE MAIN TERMINAL.</p>
                
                <a href="{{ routes.all_products_collection_url }}" class="inline-block mt-8 border border-outline-variant px-8 py-4 font-utility-label text-xs uppercase hover:border-primary-container hover:text-primary-container transition-colors tracking-widest">
                    BROWSE_ALL_ASSETS
                </a>
            </div>
        {%- endif -%}
    {%- endif -%}
</section>
