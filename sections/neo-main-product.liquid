{% schema %}
{
  "name": "NEO-DYS Product",
  "settings": [],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant Picker",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1
    },
    {
      "type": "specs",
      "name": "Technical Specs",
      "limit": 1
    }
  ]
}
{% endschema %}

<!-- MAIN PRODUCT CANVAS -->
<main class="pt-32 pb-section-gap px-margin-desktop">
  <div class="grid grid-cols-12 gap-gutter">
    <!-- LEFT: PRODUCT GALLERY -->
    <div class="col-span-12 lg:col-span-7 flex flex-col gap-8">
      <div class="relative overflow-hidden border border-outline-variant bg-surface-container-lowest group">
        <div class="scanline"></div>
        <div class="zoom-container relative w-full aspect-[4/5] overflow-hidden">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}" class="zoom-image w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0" id="main-image">
          {%- else -%}
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDf1rWeFeHOgOzKIjAYUlMi8ojb5LF08dDA2dS-iqM2jGMK_bGnrEoH7crKX0YhvieMARj3DUvZPJqokxsTZ24b1eancuux8avulE9d_fjuZOg2RsyOcaIdQ3bs7vGpYNXJbRH1MMnZMXDS08Y0Pbo5h8C1nQRalmDRjUjFYZXseP_y68ZIFRMNKlPrncnOsjXzvoSJ-0twTJusR3n5VvqiAkFKTUcEZQOaB0Q3M7yWOjfgqQ0-HndZ9LffM4UqhMFsZ_YB41xgVIb0" class="zoom-image w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0" id="main-image">
          {%- endif -%}
          <div class="absolute inset-0 bg-gradient-to-t from-background/40 to-transparent pointer-events-none"></div>
        </div>
        
        <!-- UI OVERLAYS -->
        <div class="absolute top-8 left-8 flex flex-col gap-2 pointer-events-none">
          <span class="font-utility-label text-[10px] uppercase tracking-widest text-primary-fixed-dim border border-primary-fixed-dim/30 px-2 py-1 bg-background/50 backdrop-blur-sm">MODEL: {{ product.handle | default: 'NL_V4.02' }}</span>
          <span class="font-utility-label text-[10px] uppercase tracking-widest text-on-surface-variant border border-outline-variant px-2 py-1 bg-background/50 backdrop-blur-sm">HIGH_FIDELITY_INPUT</span>
        </div>
        <div class="absolute bottom-8 right-8 pointer-events-none">
          <span class="font-utility-label text-[10px] text-on-surface-variant opacity-50 uppercase">[HOVER_TO_ENHANCE]</span>
        </div>
      </div>

      <!-- THUMBNAILS -->
      {%- if product.media.size > 1 -%}
        <div class="grid grid-cols-4 gap-4">
          {%- for media in product.media -%}
            <button class="aspect-square border {% if forloop.first %}border-primary-fixed-dim{% else %}border-outline-variant{% endif %} hover:border-primary-fixed-dim transition-colors overflow-hidden group" onclick="updateImage(this.children[0].src, this)">
              <img src="{{ media | image_url: width: 400 }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500">
            </button>
          {%- endfor -%}
        </div>
      {%- elsif product == blank -%}
        <!-- Fallback Thumbnails -->
        <div class="grid grid-cols-4 gap-4">
          <button class="aspect-square border border-primary-fixed-dim hover:border-primary-fixed-dim transition-colors overflow-hidden group" onclick="updateImage(this.children[0].src, this)">
            <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDf1rWeFeHOgOzKIjAYUlMi8ojb5LF08dDA2dS-iqM2jGMK_bGnrEoH7crKX0YhvieMARj3DUvZPJqokxsTZ24b1eancuux8avulE9d_fjuZOg2RsyOcaIdQ3bs7vGpYNXJbRH1MMnZMXDS08Y0Pbo5h8C1nQRalmDRjUjFYZXseP_y68ZIFRMNKlPrncnOsjXzvoSJ-0twTJusR3n5VvqiAkFKTUcEZQOaB0Q3M7yWOjfgqQ0-HndZ9LffM4UqhMFsZ_YB41xgVIb0"/>
          </button>
          <button class="aspect-square border border-outline-variant hover:border-primary-fixed-dim transition-colors overflow-hidden group" onclick="updateImage(this.children[0].src, this)">
            <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDJKzCO_-59K6GrxRdcdgQKye6LfHx59rw2rctRFnMFQzgg_2vY4aQGsmFZj9aB3yhJ0YdYYn9C8adN5y_YfPNwfPddhLi946QdSzuEdEPd7GFOTrdOUm1j8WEbpqDty6uv8oNkbV6d7PWPWUBFSIcbTB_zQto6Uw05BusVlBUfgOOaj7OF0gEzD6JsO0wx0poTSsr2uEm95eRUgIXhRuOHspF8AEYeud-FZ34O3y-7roKQAdL3xKwQ8enfWgC41i8sGFbiul1fJf8z"/>
          </button>
          <button class="aspect-square border border-outline-variant hover:border-primary-fixed-dim transition-colors overflow-hidden group" onclick="updateImage(this.children[0].src, this)">
            <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBhMrPRUsoVJCHFQzDzRPq_GXs57hutroikX_DE5r8gxBmq0o31sSndwYX0f8X_JmGD5f60tGYDGRuilUa_MJH_un1JJ3b5H_K_gjsPeL8g-5MHY_jeLd6jfSMyyVgxMZwt-qy_LtDAo2O1GxfKU9kFoU6W_z6wfJOrgTxIs1mb11K2YuGlMHGjgIho7ZGpECze3lhDW5Jo-3XDGUm7KywfhyKkVGUz_0CxjjhBcE7txZfdAeasaf2Pywh1OOyNfLV1ZLra6uIvRVnK"/>
          </button>
          <button class="aspect-square border border-outline-variant hover:border-primary-fixed-dim transition-colors overflow-hidden group" onclick="updateImage(this.children[0].src, this)">
            <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBA7DAeHsg5KQAqhES0Tm_MlPYgFOx89NDrC9BLb-kuMTdKLMGsJoqNbyKVIJ2-AwQl5GTcfg9uD5OvDRCYjI5vErB_rxfN0sxWPfs_i5Oy0nbtbxpRi6n_4qAgvpBVFcMouE5XDKF23E6t2OEJvVs6CZdRJrJONocV_uql_MWI4qKBazBdw0LHJwO6XmZFSZrjFJK3NL4r3Grg8S3xX1_CthfNnMvCbQXkhFKoTrsdm2dvOBE_e0SDxziDgZ-wlAGqB7k8JIMdw92z"/>
          </button>
        </div>
      {%- endif -%}
    </div>
    
    <!-- RIGHT: PURCHASE CONTROLS -->
    <div class="col-span-12 lg:col-span-5 flex flex-col gap-10">
      <header>
        <p class="font-utility-label text-utility-label uppercase text-primary-fixed tracking-[0.4em] mb-4">HARDWARE_ASSET_AUTHENTICATED</p>
        <h1 class="font-headline-xl text-headline-xl uppercase leading-none mb-6">{{ product.title | default: 'NEURAL_LINK_V4' }}</h1>
        <div class="flex items-center gap-4 mb-6">
          <span class="text-2xl font-headline-lg text-primary-fixed-dim">
            {%- if product.price -%}
              {{ product.price | money }}
            {%- else -%}
              $1,450.00
            {%- endif -%}
          </span>
          {%- if product.compare_at_price > product.price -%}
            <span class="font-utility-label text-[10px] text-on-surface-variant line-through">{{ product.compare_at_price | money }}</span>
          {%- elsif product == blank -%}
            <span class="font-utility-label text-[10px] text-on-surface-variant line-through">$2,100.00</span>
          {%- endif -%}
          <span class="bg-primary-container text-on-primary-container px-2 py-0.5 text-[10px] font-bold">PRE-ORDER_BONUS</span>
        </div>
        <div class="font-body-lg text-body-lg text-secondary max-w-md rte">
          {{ product.description | default: 'Direct cortical interface designed for the 2093 urban operator. Engineered with sub-millisecond latency and cold-forged osmium structural integrity.' }}
        </div>
      </header>

      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        {%- unless product.has_only_default_variant or product == blank -%}
          {%- for option in product.options_with_values -%}
            <section class="flex flex-col gap-4">
              <div class="flex justify-between items-center">
                <span class="font-utility-label text-utility-label uppercase tracking-widest text-on-surface">
                  {%- if option.name == 'Color' or option.name == 'Colour' -%}
                    COLOR_VARIANT
                  {%- else -%}
                    CALIBRATION_{{ option.name | upcase }}
                  {%- endif -%}
                </span>
                {%- if option.name == 'Size' -%}
                  <a class="font-utility-label text-[10px] text-primary-fixed-dim hover:underline underline-offset-4" href="#">SIZE_CHART</a>
                {%- endif -%}
              </div>
              
              <div class="flex flex-wrap gap-3">
                {%- for value in option.values -%}
                  <button type="button" 
                          class="w-12 h-12 border {% if option.selected_value == value %}border-primary-fixed-dim text-primary-fixed-dim hover:bg-primary-container hover:text-on-primary-container{% else %}border-outline-variant text-secondary hover:border-primary-fixed-dim{% endif %} font-utility-label flex items-center justify-center transition-all">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </section>
          {%- endfor -%}
        {%- else -%}
          <!-- Fallback options if no product -->
          {%- if product == blank -%}
            <!-- COLOR VARIANTS -->
            <section class="flex flex-col gap-4">
              <span class="font-utility-label text-utility-label uppercase tracking-widest text-on-surface">COLOR_VARIANT</span>
              <div class="flex gap-4">
                  <button type="button" class="w-10 h-10 border-2 border-primary-fixed-dim p-0.5 group">
                      <div class="w-full h-full bg-surface-container-highest metal-texture"></div>
                  </button>
                  <button type="button" class="w-10 h-10 border border-outline-variant p-0.5 group hover:border-primary-fixed-dim transition-colors">
                      <div class="w-full h-full bg-black metal-texture"></div>
                  </button>
                  <button type="button" class="w-10 h-10 border border-outline-variant p-0.5 group hover:border-primary-fixed-dim transition-colors">
                      <div class="w-full h-full bg-gray-600 metal-texture"></div>
                  </button>
              </div>
            </section>
            
            <!-- SIZE SELECTOR -->
            <section class="flex flex-col gap-4">
              <div class="flex justify-between items-center">
                  <span class="font-utility-label text-utility-label uppercase tracking-widest text-on-surface">CALIBRATION_SIZE</span>
                  <a class="font-utility-label text-[10px] text-primary-fixed-dim hover:underline underline-offset-4" href="#">SIZE_CHART</a>
              </div>
              <div class="flex flex-wrap gap-3">
                  <button type="button" class="w-12 h-12 border border-outline-variant text-secondary font-utility-label flex items-center justify-center hover:border-primary-fixed-dim transition-all">XS</button>
                  <button type="button" class="w-12 h-12 border border-primary-fixed-dim text-primary-fixed-dim font-utility-label flex items-center justify-center hover:bg-primary-container hover:text-on-primary-container transition-all">S</button>
                  <button type="button" class="w-12 h-12 border border-outline-variant text-secondary font-utility-label flex items-center justify-center hover:border-primary-fixed-dim transition-all">M</button>
                  <button type="button" class="w-12 h-12 border border-outline-variant text-secondary font-utility-label flex items-center justify-center hover:border-primary-fixed-dim transition-all">L</button>
                  <button type="button" class="w-12 h-12 border border-outline-variant text-secondary font-utility-label flex items-center justify-center hover:border-primary-fixed-dim transition-all">XL</button>
              </div>
            </section>
          {%- endif -%}
        {%- endunless -%}

        <!-- CTA -->
        <div class="flex flex-col gap-4 mt-6">
          <button type="submit" class="glitch-btn group relative w-full py-6 bg-primary-container text-on-primary-container font-headline-lg text-2xl uppercase font-bold flex items-center justify-center gap-4 overflow-hidden border border-primary-container shadow-[0_0_20px_rgba(57,255,20,0.2)]">
            <span>SECURE_ACQUISITION</span>
            <span class="material-symbols-outlined font-variation-settings: 'FILL' 1;">bolt</span>
            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </button>
          
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse"></span>
            <span class="font-utility-label text-[10px] text-primary-fixed uppercase tracking-tighter">DISTRIBUTION_STATION_04: ACTIVE // {% if product.available %}{{ product.variants.first.inventory_quantity | default: '12' }}{% else %}12{% endif %}_UNITS_REMAINING</span>
          </div>
        </div>
      {%- endform -%}
      
      <!-- TECHNICAL LOG -->
      <section class="border-t border-outline-variant pt-8 flex flex-col gap-6">
        <h2 class="font-utility-label text-utility-label uppercase tracking-widest text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">settings_input_component</span>
            TECHNICAL_DATA_PACK
        </h2>
        <div class="flex flex-col gap-4">
            <div class="flex justify-between items-end border-b border-outline-variant/30 pb-2">
                <span class="font-utility-label text-[10px] text-on-surface-variant">FABRIC_COMPOSITION</span>
                <span class="font-utility-label text-sm text-tertiary-fixed">LIQUID_CRYSTAL_POLYMER</span>
            </div>
            <div class="flex justify-between items-end border-b border-outline-variant/30 pb-2">
                <span class="font-utility-label text-[10px] text-on-surface-variant">MATERIAL_WEIGHT</span>
                <span class="font-utility-label text-sm text-tertiary-fixed">42.5g_CORE_MASS</span>
            </div>
            <div class="flex justify-between items-end border-b border-outline-variant/30 pb-2">
                <span class="font-utility-label text-[10px] text-on-surface-variant">SHIPPING_PROTOCOL</span>
                <span class="font-utility-label text-sm text-tertiary-fixed">ORBITAL_DROP_SECURED</span>
            </div>
            <div class="flex justify-between items-end border-b border-outline-variant/30 pb-2">
                <span class="font-utility-label text-[10px] text-on-surface-variant">ENCRYPTION_LAYERS</span>
                <span class="font-utility-label text-sm text-tertiary-fixed">X-LEVEL_QUANTUM</span>
            </div>
            <div class="flex justify-between items-end border-b border-outline-variant/30 pb-2">
                <span class="font-utility-label text-[10px] text-on-surface-variant">LATENCY_SPEC</span>
                <span class="font-utility-label text-sm text-tertiary-fixed"><0.01ms</span>
            </div>
        </div>
      </section>
    </div>
  </div>
</main>

<script>
    // Gallery Zoom Functionality
    const mainImage = document.getElementById('main-image');
    if (mainImage) {
      const zoomContainer = mainImage.parentElement;

      zoomContainer.addEventListener('mousemove', (e) => {
          const { left, top, width, height } = zoomContainer.getBoundingClientRect();
          const x = ((e.clientX - left) / width) * 100;
          const y = ((e.clientY - top) / height) * 100;
          
          mainImage.style.transformOrigin = `${x}% ${y}%`;
          mainImage.style.transform = 'scale(2)';
      });

      zoomContainer.addEventListener('mouseleave', () => {
          mainImage.style.transform = 'scale(1)';
          mainImage.style.transformOrigin = 'center';
      });
    }

    function updateImage(src, button) {
        if(mainImage) mainImage.src = src;
        // Update active thumbnail styling
        document.querySelectorAll('button[onclick^="updateImage"]').forEach(btn => {
            btn.classList.remove('border-primary-fixed-dim');
            btn.classList.add('border-outline-variant');
        });
        if(button) {
          button.classList.add('border-primary-fixed-dim');
          button.classList.remove('border-outline-variant');
        }
    }

    // Hover Glitch for buttons
    document.querySelectorAll('.glitch-btn').forEach(btn => {
        btn.addEventListener('mouseenter', () => {
            const interval = setInterval(() => {
                btn.style.left = (Math.random() * 2 - 1) + 'px';
            }, 50);
            btn.dataset.intervalId = interval;
        });
        btn.addEventListener('mouseleave', () => {
            clearInterval(btn.dataset.intervalId);
            btn.style.left = '0px';
        });
    });
</script>
