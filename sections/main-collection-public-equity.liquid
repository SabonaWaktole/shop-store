{%- style -%}
  #shopify-section-{{ section.id }} .collection-banner {
    height: {{ section.settings.banner_height | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .collection-banner {
      height: {{ section.settings.banner_height }}px;
    }
  }
{%- endstyle -%}

<div class="w-full bg-background" data-section-id="{{ section.id }}" data-section-type="collection">
    
    <!-- Header & Controls -->
    {%- liquid
      assign banner_image = collection.metafields.custom.banner_image | default: section.settings.collection_banner_image | default: collection.image
    -%}
    {%- if section.settings.show_collection_image and banner_image -%}
        <div class="w-full collection-banner overflow-hidden relative">
            <img src="{{ banner_image | image_url: width: 2500 }}" alt="{{ collection.title | escape }}" class="w-full h-full object-cover filter grayscale contrast-125">
            <div class="absolute inset-0 bg-black/30 pointer-events-none"></div>
            {%- if section.settings.enable_scanner -%}
                <div class="scanner-line"></div>
            {%- endif -%}
        </div>
    {%- endif -%}

    <header class="px-margin-mobile md:px-margin-desktop py-12 md:py-24 max-w-container-max mx-auto">
        <h1 class="font-display-xl text-display-xl text-primary uppercase max-w-5xl leading-none mb-8 text-[48px] md:text-[80px]">
            {{ section.settings.title | default: collection.title | default: 'COLLECTION' }}
        </h1>
        
        {%- if collection.metafields.custom.subtitle != blank -%}
            <div class="font-label-mono text-label-mono text-accent uppercase tracking-widest mb-8">
                {{ collection.metafields.custom.subtitle }}
            </div>
        {%- endif -%}

        {%- if section.settings.show_collection_description and collection.description != blank -%}
            <div class="font-body-main text-body-main text-on-surface-variant max-w-3xl mb-16 prose prose-invert">
                {{ collection.description }}
            </div>
        {%- endif -%}
        
        <!-- Brutalist Filter & Sort Bar -->
        {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-outline-variant pb-4 font-label-mono text-label-mono uppercase gap-6 md:gap-0 mt-16">
            <form id="CollectionFiltersForm" class="flex flex-col md:flex-row w-full justify-between gap-6 md:gap-0">
                <div class="flex gap-8 md:gap-12 w-full md:w-auto overflow-x-auto hide-scrollbar items-center">
                    {%- if section.settings.enable_filtering -%}
                        {%- for filter in collection.filters -%}
                            <div class="group relative flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap cursor-pointer">
                                <span>{{ filter.label }}</span>
                                <span class="material-symbols-outlined text-[14px]">expand_more</span>
                                
                                <!-- Basic dropdown implementation for UI demonstration -->
                                <div class="absolute top-full left-0 mt-2 bg-surface border border-outline-variant p-4 hidden group-hover:flex flex-col gap-2 z-30 min-w-[200px]">
                                    {%- for value in filter.values -%}
                                        <label class="flex items-center gap-2 cursor-pointer hover:text-primary transition-colors">
                                            <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" class="cinetica-checkbox" {% if value.active %}checked{% endif %}>
                                            <span>{{ value.label }} ({{ value.count }})</span>
                                        </label>
                                    {%- endfor -%}
                                </div>
                            </div>
                        {%- endfor -%}
                    {%- endif -%}
                </div>
                
                {%- if section.settings.enable_sorting -%}
                <div class="flex items-center gap-2 text-primary whitespace-nowrap relative group cursor-pointer">
                    <span>SORT: <span id="SortLabel">FEATURED</span></span>
                    <span class="material-symbols-outlined text-[14px]">swap_vert</span>
                    <select name="sort_by" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" onchange="document.getElementById('SortLabel').innerText = this.options[this.selectedIndex].text; this.form.submit();">
                        {%- for option in collection.sort_options -%}
                            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
                        {%- endfor -%}
                    </select>
                </div>
                {%- endif -%}
            </form>
        </div>
        {%- endif -%}
    </header>

    <!-- Brutalist Grid -->
    {% paginate collection.products by section.settings.products_per_page %}
        {%- liquid
            assign grid_cols_desktop = section.settings.products_per_row_desktop
            assign grid_cols_mobile = section.settings.products_per_row_mobile
            
            assign grid_class = 'grid-cols-' | append: grid_cols_mobile | append: ' md:grid-cols-' | append: grid_cols_desktop
        -%}
        
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-24">
            <div class="grid {{ grid_class }} gap-gutter bg-outline-variant border border-outline-variant relative">
                
                {%- assign product_index = 0 -%}
                {%- for product in collection.products -%}
                    
                    <!-- Inject Promo Blocks -->
                    {%- for block in section.blocks -%}
                        {%- if block.type == 'promo_block' and block.settings.position == product_index -%}
                            <div class="bg-surface relative group overflow-hidden border border-outline-variant transition-colors hover:border-primary flex flex-col justify-center items-center text-center p-8 h-full min-h-[400px]" {{ block.shopify_attributes }}>
                                {%- if block.settings.image != blank -%}
                                    <div class="absolute inset-0 w-full h-full">
                                        <img src="{{ block.settings.image | image_url: width: 800 }}" alt="" class="w-full h-full object-cover filter grayscale contrast-125 opacity-40 group-hover:opacity-80 transition-opacity duration-700">
                                    </div>
                                {%- endif -%}
                                <div class="relative z-10">
                                    {%- if block.settings.heading != blank -%}
                                        <h3 class="font-display-xl text-primary text-3xl md:text-5xl uppercase tracking-tighter mb-4">{{ block.settings.heading }}</h3>
                                    {%- endif -%}
                                    {%- if block.settings.text != blank -%}
                                        <div class="font-body-main text-on-surface-variant mb-6">{{ block.settings.text }}</div>
                                    {%- endif -%}
                                    {%- if block.settings.button_label != blank -%}
                                        <a href="{{ block.settings.button_link }}" class="inline-flex items-center justify-center bg-transparent text-primary border border-primary font-label-mono text-label-mono px-8 py-3 uppercase tracking-widest hover:bg-primary hover:text-background transition-all duration-300">
                                            {{ block.settings.button_label }}
                                        </a>
                                    {%- endif -%}
                                </div>
                            </div>
                        {%- endif -%}
                    {%- endfor -%}

                    <div class="bg-background">
                        {% render 'product-card-public-equity', product: product %}
                    </div>
                    {%- assign product_index = product_index | plus: 1 -%}
                {%- else -%}
                    <!-- Demo fallback if no products are assigned -->
                    {% for i in (1..8) %}
                        {%- for block in section.blocks -%}
                            {%- if block.type == 'promo_block' and block.settings.position == i -%}
                                <div class="bg-surface relative group overflow-hidden border border-outline-variant transition-colors hover:border-primary flex flex-col justify-center items-center text-center p-8 h-full min-h-[400px]" {{ block.shopify_attributes }}>
                                    <div class="relative z-10">
                                        <h3 class="font-display-xl text-primary text-3xl uppercase tracking-tighter mb-4">PROMO BLOCK</h3>
                                    </div>
                                </div>
                            {%- endif -%}
                        {%- endfor -%}
                        <div class="bg-background">
                            {% render 'product-card-public-equity' %}
                        </div>
                    {% endfor %}
                {%- endfor -%}

                <!-- Catch remaining promo blocks -->
                {%- for block in section.blocks -%}
                    {%- if block.type == 'promo_block' and block.settings.position >= product_index -%}
                        <div class="bg-surface relative group overflow-hidden border border-outline-variant transition-colors hover:border-primary flex flex-col justify-center items-center text-center p-8 h-full min-h-[400px]" {{ block.shopify_attributes }}>
                            {%- if block.settings.image != blank -%}
                                <div class="absolute inset-0 w-full h-full">
                                    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="" class="w-full h-full object-cover filter grayscale contrast-125 opacity-40 group-hover:opacity-80 transition-opacity duration-700">
                                </div>
                            {%- endif -%}
                            <div class="relative z-10">
                                {%- if block.settings.heading != blank -%}
                                    <h3 class="font-display-xl text-primary text-3xl md:text-5xl uppercase tracking-tighter mb-4">{{ block.settings.heading }}</h3>
                                {%- endif -%}
                                {%- if block.settings.text != blank -%}
                                    <div class="font-body-main text-on-surface-variant mb-6">{{ block.settings.text }}</div>
                                {%- endif -%}
                                {%- if block.settings.button_label != blank -%}
                                    <a href="{{ block.settings.button_link }}" class="inline-flex items-center justify-center bg-transparent text-primary border border-primary font-label-mono text-label-mono px-8 py-3 uppercase tracking-widest hover:bg-primary hover:text-background transition-all duration-300">
                                        {{ block.settings.button_label }}
                                    </a>
                                {%- endif -%}
                            </div>
                        </div>
                    {%- endif -%}
                {%- endfor -%}

            </div>
        </div>

        {%- if paginate.pages > 1 -%}
            <!-- Load More (Brutalist style) -->
            <div class="mb-24 flex justify-center">
                <a href="{{ paginate.next.url }}" class="border border-outline-variant px-12 py-6 font-label-mono text-label-mono text-primary uppercase hover:bg-primary hover:text-on-primary hover:border-primary transition-colors duration-300 text-center cursor-pointer">
                    LOAD NEXT SEQUENCE
                </a>
            </div>
        {%- endif -%}
    {% endpaginate %}
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "header",
      "content": "Collection Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading Override",
      "info": "Leave blank to use the collection title"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection banner",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "collection_banner_image",
      "label": "Banner Image Override",
      "info": "Overrides the default collection image"
    },
    {
      "type": "range",
      "id": "banner_height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Banner Height",
      "default": 400
    },
    {
      "type": "checkbox",
      "id": "enable_scanner",
      "label": "Enable scanner overlay on banner",
      "default": true
    },
    {
      "type": "header",
      "content": "Filtering & Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Products per row (Desktop)"
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Products per row (Mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "promo_block",
      "name": "Promo Block",
      "settings": [
        {
          "type": "number",
          "id": "position",
          "label": "Position in Grid",
          "default": 4,
          "info": "Zero-indexed. E.g., 4 inserts after the 4th product."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "DISCOVER"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ]
}
{% endschema %}
