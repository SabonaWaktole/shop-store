{% schema %}
{
  "name": "Luxury Main Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "label": "Enable Sticky Product Info",
      "default": true
    },
    {
      "type": "text",
      "id": "preorder_date",
      "label": "Preorder Ship Date (Fallback)",
      "default": "Expected to ship August 2026",
      "info": "Used if the product is tagged 'preorder'."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "gallery_width",
      "options": [
        { "value": "6", "label": "50% (Balanced)" },
        { "value": "7", "label": "58% (Gallery Focus)" },
        { "value": "8", "label": "66% (Editorial)" }
      ],
      "default": "8",
      "label": "Gallery Width"
    },
    {
      "type": "select",
      "id": "image_gap",
      "options": [
        { "value": "4", "label": "Compact" },
        { "value": "8", "label": "Standard" },
        { "value": "16", "label": "Spacious" }
      ],
      "default": "8",
      "label": "Image Gallery Gap"
    },
    {
      "type": "select",
      "id": "image_aspect",
      "options": [
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "4/5", "label": "Tall Portrait (4:5)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "auto", "label": "Auto (Original)" }
      ],
      "default": "auto",
      "label": "Image Aspect Ratio (Mobile)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "default": "#FFFFFF",
      "label": "Section Background"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "default": "#000000",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "default": "#6B7280",
      "label": "Muted Text Color"
    },
    {
      "type": "color",
      "id": "section_border_color",
      "default": "#E5E7EB",
      "label": "Border Color"
    },
    {
      "type": "header",
      "content": "Title Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36,
      "label": "Title Font Size"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" }
      ],
      "default": "600",
      "label": "Title Font Weight"
    },
    {
      "type": "checkbox",
      "id": "title_uppercase",
      "default": true,
      "label": "Uppercase Title"
    },
    {
      "type": "range",
      "id": "price_font_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18,
      "label": "Price Font Size"
    },
    {
      "type": "range",
      "id": "vendor_font_size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "Vendor Font Size"
    },
    {
      "type": "header",
      "content": "Buy Button"
    },
    {
      "type": "checkbox",
      "id": "override_buttons",
      "default": false,
      "label": "Override Global Button Style"
    },
    {
      "type": "color",
      "id": "button_bg",
      "default": "#000000",
      "label": "Button Background"
    },
    {
      "type": "color",
      "id": "button_text",
      "default": "#FFFFFF",
      "label": "Button Text"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14,
      "label": "Button Font Size"
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16,
      "label": "Button Vertical Padding"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0,
      "label": "Button Border Radius"
    },
    {
      "type": "header",
      "content": "Preorder & Stock"
    },
    {
      "type": "color",
      "id": "preorder_badge_bg",
      "default": "#000000",
      "label": "Preorder Badge Background"
    },
    {
      "type": "color",
      "id": "preorder_badge_text",
      "default": "#FFFFFF",
      "label": "Preorder Badge Text"
    },
    {
      "type": "range",
      "id": "low_stock_threshold",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 10,
      "label": "Low Stock Threshold"
    },
    {
      "type": "checkbox",
      "id": "show_low_stock",
      "default": true,
      "label": "Show Low Stock Warning"
    },
    {
      "type": "header",
      "content": "Accordions"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_accordion",
      "default": true,
      "label": "Show Shipping & Returns"
    },
    {
      "type": "textarea",
      "id": "shipping_text",
      "default": "Complimentary worldwide shipping on orders over $300. Returns accepted within 14 days of delivery. Preorders cannot be cancelled once production has started.",
      "label": "Shipping & Returns Text"
    },
    {
      "type": "range",
      "id": "accordion_font_size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "Accordion Title Font Size"
    }
  ],
  "presets": [
    {
      "name": "Luxury Main Product"
    }
  ]
}
{% endschema %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- capture current_drop_state -%}{% render 'drop-state-engine', product: product, context: 'state_string' %}{%- endcapture -%}
{%- assign current_drop_state = current_drop_state | strip -%}

{%- assign info_cols = 12 | minus: section.settings.gallery_width -%}

{%- if section.settings.override_buttons -%}
  {%- assign btn_bg = section.settings.button_bg -%}
  {%- assign btn_text = section.settings.button_text -%}
{%- else -%}
  {%- assign btn_bg = section.settings.section_text_color -%}
  {%- assign btn_text = section.settings.section_bg_color -%}
{%- endif -%}

<section class="max-w-[1600px] mx-auto px-4 md:px-8" data-section="luxury-product" style="background-color: {{ section.settings.section_bg_color }}; color: {{ section.settings.section_text_color }}; padding-top: {{ section.settings.section_padding_top }}px; padding-bottom: {{ section.settings.section_padding_bottom }}px;">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
    
    <!-- Left: Image Gallery -->
    <div class="lg:col-span-{{ section.settings.gallery_width }} flex flex-col" style="gap: {{ section.settings.image_gap }}px;">
      {%- if product.media.size > 0 -%}
        {%- for media in product.media -%}
          <div class="w-full relative overflow-hidden" style="{% if section.settings.image_aspect != 'auto' %}aspect-ratio: {{ section.settings.image_aspect }};{% endif %}">
            {%- if media.media_type == 'image' -%}
              <img src="{{ media | image_url: width: 1400 }}" alt="{{ media.alt | escape }}" class="w-full h-full object-cover md:object-contain" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            {%- else -%}
              {{ media | media_tag: class: 'w-full h-full object-cover' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="w-full relative" style="aspect-ratio: 3/4;">
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
        </div>
        <div class="w-full relative" style="aspect-ratio: 3/4;">
          {{ 'product-2' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
        </div>
      {%- endif -%}
    </div>

    <!-- Right: Sticky Product Info -->
    <div class="lg:col-span-{{ info_cols }} relative">
      <div class="{% if section.settings.enable_sticky_info %}lg:sticky lg:top-[120px]{% endif %} flex flex-col gap-6">
        
        <!-- Vendor -->
        <div class="uppercase tracking-widest font-medium" style="font-size: {{ section.settings.vendor_font_size }}px; color: {{ section.settings.muted_text_color }};">
          {{ product.vendor | default: 'STUDIO' }}
        </div>

        <!-- Title & Price -->
        <div>
          <h1 class="tracking-tighter mb-4" style="font-size: {{ section.settings.title_font_size }}px; font-weight: {{ section.settings.title_font_weight }};{% if section.settings.title_uppercase %} text-transform: uppercase;{% endif %}">{{ product.title | default: 'Luxury Garment 01' }}</h1>
          <div class="font-medium flex items-center gap-4" style="font-size: {{ section.settings.price_font_size }}px;">
            <span id="luxury-product-price">{{ current_variant.price | money }}</span>
            <span id="luxury-product-compare-price" class="line-through {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}" style="font-size: {{ section.settings.price_font_size | minus: 4 }}px; color: {{ section.settings.muted_text_color }};">{{ current_variant.compare_at_price | money }}</span>
          </div>
        </div>

        <!-- Drop State Banner -->
        {% render 'drop-state-engine', product: product, context: 'product_page_banner', preorder_date: section.settings.preorder_date %}

        <!-- Low Stock Warning -->
        {%- if section.settings.show_low_stock and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= section.settings.low_stock_threshold and current_drop_state != 'preorder' and current_drop_state != 'waitlist' and current_drop_state != 'coming_soon' -%}
            <div class="flex items-center gap-2 uppercase tracking-widest font-medium" style="color: {{ settings.custom_error_color | default: '#EF4444' }}; font-size: {{ section.settings.vendor_font_size }}px;">
                <span class="w-2 h-2 rounded-full animate-pulse" style="background-color: {{ settings.custom_error_color | default: '#EF4444' }};"></span>
                Limited Stock: Only {{ current_variant.inventory_quantity }} left
            </div>
        {%- endif -%}

        <!-- Form -->
        {% form 'product', product, id: 'luxury-product-form', class: 'mt-4 flex flex-col gap-6' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          
          <style>
            .variant-label {
              border: 1px solid {{ section.settings.section_border_color }};
              background-color: {{ section.settings.section_bg_color }};
              color: {{ section.settings.section_text_color }};
            }
            input[type="radio"]:checked + .variant-label {
              background-color: {{ section.settings.section_text_color }};
              color: {{ section.settings.section_bg_color }};
              border-color: {{ section.settings.section_text_color }};
            }
          </style>

          {%- unless product.has_only_default_variant -%}
            <div class="flex flex-col gap-4">
              {%- for option in product.options_with_values -%}
                <div class="flex flex-col gap-3 variant-option-group" data-index="{{ forloop.index0 }}">
                  <label class="uppercase tracking-widest font-medium" style="font-size: {{ section.settings.vendor_font_size }}px; color: {{ section.settings.muted_text_color }};">{{ option.name }}</label>
                  <div class="flex flex-wrap gap-2">
                    {%- for value in option.values -%}
                      <label class="cursor-pointer relative">
                        <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="opacity-0 absolute inset-0 z-[-1]" {% if option.selected_value == value %}checked="checked"{% endif %}>
                        <span class="variant-label block px-5 py-3 text-sm uppercase tracking-wide transition-colors font-medium">
                          {{ value }}
                        </span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <div class="pt-4">
            <button type="submit" 
                    class="w-full font-medium tracking-widest uppercase transition-colors hover:opacity-90"
                    style="padding: {{ section.settings.button_padding_y }}px 0; font-size: {{ section.settings.button_font_size }}px; border-radius: {{ section.settings.button_border_radius }}px; {% if current_variant.available %}background-color: {{ btn_bg }}; color: {{ btn_text }};{% else %}background-color: {{ section.settings.section_border_color }}; color: {{ section.settings.muted_text_color }}; cursor: not-allowed;{% endif %}"
                    {% unless current_variant.available %}disabled{% endunless %}>
              {% render 'drop-state-engine', product: product, context: 'button_text' %}
            </button>
          </div>
        {% endform %}

        <!-- Description -->
        <div class="prose prose-sm mt-8" style="color: {{ section.settings.muted_text_color }};">
          {%- if product.description != blank -%}
            {{ product.description }}
          {%- else -%}
            <p>Signature heavy-weight cotton construction with dropped shoulders and a cropped hem. Features subtle distressed detailing and a tonal embroidered logo on the chest. Designed in Los Angeles.</p>
            <ul class="list-disc pl-4 mt-4 space-y-1 text-xs">
                <li>100% Organic Cotton</li>
                <li>450 GSM Heavyweight Fleece</li>
                <li>Oversized fit</li>
                <li>Made in Portugal</li>
            </ul>
          {%- endif -%}
        </div>

        <!-- Shipping Info Accordions -->
        {%- if section.settings.show_shipping_accordion -%}
        <div class="border-t mt-6 pt-6 flex flex-col gap-4" style="border-color: {{ section.settings.section_border_color }};">
            <details class="group cursor-pointer">
                <summary class="flex justify-between items-center font-medium uppercase tracking-widest list-none" style="font-size: {{ section.settings.accordion_font_size }}px;">
                    Shipping & Returns
                    <span class="material-symbols-outlined text-lg group-open:rotate-180 transition-transform">expand_more</span>
                </summary>
                <div class="pt-4 leading-relaxed" style="font-size: {{ section.settings.accordion_font_size | plus: 2 }}px; color: {{ section.settings.muted_text_color }};">
                    {{ section.settings.shipping_text }}
                </div>
            </details>
        </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<!-- Variant switching script -->
<script type="application/json" id="luxury-product-variants">
  [
    {% for variant in product.variants %}
      {
        "id": {{ variant.id }},
        "options": {{ variant.options | json }},
        "available": {{ variant.available | json }},
        "price": "{{ variant.price | money }}",
        "compare_at_price": "{{ variant.compare_at_price | money }}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
</script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('luxury-product-form');
    if(form) {
        const variantsData = JSON.parse(document.getElementById('luxury-product-variants').textContent);
        const hiddenIdInput = form.querySelector('input[name="id"]');
        const optionsContainer = form.querySelectorAll('.variant-option-group');
        const submitButton = form.querySelector('button[type="submit"]');
        const priceDisplay = document.getElementById('luxury-product-price');
        const comparePriceDisplay = document.getElementById('luxury-product-compare-price');

        function updateVariant() {
            const selectedOptions = Array.from(optionsContainer).map(group => {
                const checked = group.querySelector('input[type="radio"]:checked');
                return checked ? checked.value : null;
            });

            const matchedVariant = variantsData.find(variant => {
                return variant.options.every((opt, index) => opt === selectedOptions[index]);
            });

            if (matchedVariant) {
                hiddenIdInput.value = matchedVariant.id;
                
                const url = new URL(window.location);
                url.searchParams.set('variant', matchedVariant.id);
                window.history.replaceState({}, '', url);

                if (priceDisplay) priceDisplay.innerHTML = matchedVariant.price;
                if (comparePriceDisplay) {
                    if (matchedVariant.compare_at_price && matchedVariant.compare_at_price !== '' && matchedVariant.compare_at_price !== matchedVariant.price) {
                        comparePriceDisplay.innerHTML = matchedVariant.compare_at_price;
                        comparePriceDisplay.classList.remove('hidden');
                    } else {
                        comparePriceDisplay.classList.add('hidden');
                    }
                }

                if (matchedVariant.available) {
                    submitButton.disabled = false;
                    submitButton.style.cursor = 'pointer';
                    submitButton.style.opacity = '1';
                    if (submitButton.dataset.originalText) {
                        submitButton.innerHTML = submitButton.dataset.originalText;
                    }
                } else {
                    if (!submitButton.dataset.originalText) {
                        submitButton.dataset.originalText = submitButton.innerHTML;
                    }
                    submitButton.disabled = true;
                    submitButton.style.cursor = 'not-allowed';
                    submitButton.style.opacity = '0.7';
                    submitButton.innerHTML = 'SOLD OUT';
                }
            }
        }

        const inputs = form.querySelectorAll('input[type="radio"]');
        inputs.forEach(input => {
            input.addEventListener('change', updateVariant);
        });
    }
});
</script>
