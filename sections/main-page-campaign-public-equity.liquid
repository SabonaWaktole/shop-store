<div class="w-full" data-section-id="{{ section.id }}" data-section-type="campaign">
    
    {%- for block in section.blocks -%}

        {%- if block.type == 'hero_image' -%}
            <!-- Full-bleed Hero Image -->
            <div class="relative w-full h-screen overflow-hidden group" {{ block.shopify_attributes }}>
                {%- if block.settings.image -%}
                    <img src="{{ block.settings.image | image_url: width: 2000 }}" alt="{{ block.settings.image.alt | escape }}" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-1000">
                {%- else -%}
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCdB_IvBTZtKlzztKS8TF10wuVtherxBZ-FspVj0cZFY_OHOWQxW9HRv7omLtJdMz9JxHBU9jnFIRfpBq1YjdAbaAZ-fQzOKEUuXKGuuAB5u_3KrxPFcMfrgSlmwb6YgWv32siQnsFSvhO8TuzO1T0pRc7ppq6C3vTGE3hSP4TvB60SL6-MBAMeFYcF0_bdEptwpcTS0Lbn528FagArlHQClVVzJlnNvKJ-0wQKO_MM1FkTR4y-MFYNsqWBa5Ch9lZLthHQ23awTdG3" alt="Campaign Image" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-1000">
                {%- endif -%}
                <!-- Scanner on hover -->
                <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-1000">
                    <div class="scanner-line"></div>
                </div>
                <!-- Overlay text -->
                {%- if block.settings.overlay_text != blank -%}
                    <div class="absolute inset-0 flex items-center justify-center z-20">
                        <h2 class="font-display-xl text-[40px] md:text-display-xl text-primary uppercase tracking-widest mix-blend-difference text-center px-margin-mobile">
                            {{ block.settings.overlay_text }}
                        </h2>
                    </div>
                {%- endif -%}
                <!-- Caption badge -->
                {%- if block.settings.caption != blank -%}
                    <div class="absolute bottom-8 right-8 bg-background/80 backdrop-blur-xl px-4 py-2 border border-outline-variant z-20">
                        <span class="font-label-mono text-label-mono text-primary uppercase">{{ block.settings.caption }}</span>
                    </div>
                {%- endif -%}
            </div>

        {%- elsif block.type == 'text_block' -%}
            <!-- Editorial Text Block -->
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-24 md:py-40 grid grid-cols-1 md:grid-cols-12 gap-12" {{ block.shopify_attributes }}>
                <div class="md:col-span-5 flex flex-col justify-center">
                    {%- if block.settings.heading != blank -%}
                        <h2 class="font-headline-lg text-headline-lg uppercase mb-8 leading-tight text-primary">
                            {{ block.settings.heading }}
                        </h2>
                    {%- endif -%}
                    {%- if block.settings.body != blank -%}
                        <div class="font-body-main text-body-main text-on-surface-variant max-w-lg">
                            {{ block.settings.body }}
                        </div>
                    {%- endif -%}
                </div>
                {%- if block.settings.side_image -%}
                    <div class="md:col-span-7">
                        <div class="aspect-[16/9] w-full overflow-hidden group">
                            <img src="{{ block.settings.side_image | image_url: width: 1400 }}" alt="{{ block.settings.side_image.alt | escape }}" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105">
                        </div>
                    </div>
                {%- endif -%}
            </div>

        {%- elsif block.type == 'image_pair' -%}
            <!-- Side-by-side Image Pair -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter bg-outline-variant" {{ block.shopify_attributes }}>
                <div class="aspect-[3/4] overflow-hidden group">
                    {%- if block.settings.image_left -%}
                        <img src="{{ block.settings.image_left | image_url: width: 1200 }}" alt="{{ block.settings.image_left.alt | escape }}" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700">
                    {%- else -%}
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBaq04CKS6YJHm-62lWm7DQIidw3cuO1c3drK38DfNoYCei4j1X97W2aN8NUs11twz8LV7trFWA-BAcZ83DWJXm3On20h7_FEFC7tK-6ALFR6MlH8UdCXbwaRnOOmmq1cd-sSgFDgFi8xHk8rA9UuZtMtseSvnWYypdtX4ufqxbiGyB37yZiFaIYNORmvolWwyNMn_BhOe7_mj511oBKHD2qI4DQRaWkqgwI75rDyDh2s4cKd3PbZrGy6XtklS5n3YEo_ol9F-XneNp" alt="Placeholder" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700">
                    {%- endif -%}
                </div>
                <div class="aspect-[3/4] overflow-hidden group">
                    {%- if block.settings.image_right -%}
                        <img src="{{ block.settings.image_right | image_url: width: 1200 }}" alt="{{ block.settings.image_right.alt | escape }}" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700">
                    {%- else -%}
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuClJKNoOKwfYuzZ-paIStjuchYcDzRpM8kr42QbsOmX3_F7kuVft-mQuE58-bzAmZ-M0GdBz3shPyyOHdK8JEqA6bnm5eYhJ1rFSiJBktbDmH_VCCEs7HM5eHi4VP8AbyB23QIetf3sGmgOUMsyjnnCHlBks_3bKF6Tjh8uoKEL-9SLivimNPnHIry5N6Ok4Z4HS-bMcbq_1ria125GYEYdqIhMNI7VjY44uX3noFw7fwjWYBg2OI-BlNb-Ki4sgaghR4jAzvhaf8kb" alt="Placeholder" class="w-full h-full object-cover filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700">
                    {%- endif -%}
                </div>
            </div>

        {%- elsif block.type == 'featured_products' -%}
            <!-- Inline Product Grid -->
            <div class="max-w-container-max mx-auto py-24 md:py-32" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                    <header class="px-margin-mobile md:px-margin-desktop mb-12">
                        <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg uppercase text-primary leading-none tracking-tight">
                            {{ block.settings.heading }}
                        </h2>
                    </header>
                {%- endif -%}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter bg-outline-variant border-y border-outline-variant">
                    {%- assign block_collection = block.settings.collection -%}
                    {%- if block_collection != blank -%}
                        {%- for product in block_collection.products limit: 4 -%}
                            {% render 'product-card-public-equity', product: product %}
                        {%- endfor -%}
                    {%- else -%}
                        {% for i in (1..4) %}
                            {% render 'product-card-public-equity' %}
                        {% endfor %}
                    {%- endif -%}
                </div>
            </div>

        {%- elsif block.type == 'video' -%}
            <!-- Full-bleed Video Embed -->
            <div class="relative w-full aspect-video overflow-hidden" {{ block.shopify_attributes }}>
                {%- if block.settings.video_url != blank -%}
                    <iframe src="{{ block.settings.video_url }}" class="w-full h-full" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
                {%- else -%}
                    <div class="w-full h-full bg-surface-container flex items-center justify-center">
                        <span class="material-symbols-outlined text-[80px] text-outline-variant">play_circle</span>
                    </div>
                {%- endif -%}
            </div>

        {%- elsif block.type == 'spacer' -%}
            <!-- Vertical Spacer with optional divider -->
            <div class="w-full {{ block.settings.size }} {{ block.settings.show_divider | default: false | ternary: 'border-b border-outline-variant', '' }}" {{ block.shopify_attributes }}>
                {%- if block.settings.show_divider -%}
                    <div class="max-w-container-max mx-auto h-full border-l border-r border-outline-variant"></div>
                {%- endif -%}
            </div>

        {%- endif -%}
    {%- else -%}
        <!-- Fallback for empty campaign page -->
        <div class="relative w-full h-screen overflow-hidden group">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCdB_IvBTZtKlzztKS8TF10wuVtherxBZ-FspVj0cZFY_OHOWQxW9HRv7omLtJdMz9JxHBU9jnFIRfpBq1YjdAbaAZ-fQzOKEUuXKGuuAB5u_3KrxPFcMfrgSlmwb6YgWv32siQnsFSvhO8TuzO1T0pRc7ppq6C3vTGE3hSP4TvB60SL6-MBAMeFYcF0_bdEptwpcTS0Lbn528FagArlHQClVVzJlnNvKJ-0wQKO_MM1FkTR4y-MFYNsqWBa5Ch9lZLthHQ23awTdG3" alt="Campaign Placeholder" class="w-full h-full object-cover filter grayscale contrast-125">
            <div class="absolute inset-0 flex items-center justify-center">
                <h2 class="font-display-xl text-[40px] md:text-display-xl text-primary uppercase tracking-widest mix-blend-difference">CAMPAIGN 001</h2>
            </div>
            <div class="scanner-line"></div>
        </div>
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-32 text-center">
            <p class="font-label-mono text-label-mono text-on-surface-variant uppercase tracking-widest">ADD BLOCKS IN THE THEME EDITOR TO BUILD YOUR LOOKBOOK.</p>
        </div>
    {%- endfor -%}
</div>

{% schema %}
{
  "name": "Campaign / Lookbook (PE)",
  "max_blocks": 20,
  "settings": [],
  "blocks": [
    {
      "type": "hero_image",
      "name": "Hero Image (Full Bleed)",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Overlay Text"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption Badge"
        }
      ]
    },
    {
      "type": "text_block",
      "name": "Editorial Text + Image",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SEQUENCE 002: INITIALIZING"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body Text"
        },
        {
          "type": "image_picker",
          "id": "side_image",
          "label": "Side Image"
        }
      ]
    },
    {
      "type": "image_pair",
      "name": "Image Pair (Side by Side)",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_left",
          "label": "Left Image"
        },
        {
          "type": "image_picker",
          "id": "image_right",
          "label": "Right Image"
        }
      ]
    },
    {
      "type": "featured_products",
      "name": "Product Grid",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "FROM THIS CAMPAIGN"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video Embed",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video Embed URL",
          "info": "Paste an embed URL from YouTube or Vimeo"
        }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer / Divider",
      "settings": [
        {
          "type": "select",
          "id": "size",
          "label": "Spacer Height",
          "options": [
            { "value": "h-16", "label": "Small (64px)" },
            { "value": "h-32", "label": "Medium (128px)" },
            { "value": "h-48", "label": "Large (192px)" }
          ],
          "default": "h-32"
        },
        {
          "type": "checkbox",
          "id": "show_divider",
          "label": "Show Divider Line",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}
