{% schema %}
{
  "name": "Campaign Page",
  "settings": [],
  "blocks": [
    {
      "type": "hero_image",
      "name": "Hero Image",
      "settings": [
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Overlay Text"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        {
          "type": "text",
          "id": "size",
          "label": "Size"
        },
        {
          "type": "checkbox",
          "id": "show_divider",
          "label": "Show Divider"
        }
      ]
    },
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        }
      ]
    },
    {
      "type": "image_pair",
      "name": "Image Pair",
      "settings": []
    },
    {
      "type": "featured_products",
      "name": "Featured Products",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Campaign Page"
    }
  ]
}
{% endschema %}

<div>
  <!-- Campaign Public Equity Section -->
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'hero_image' -%}
        <div>{{ block.settings.overlay_text }}</div>
      {%- when 'text_block' -%}
        <div>
          <h2>{{ block.settings.heading }}</h2>
          <div>{{ block.settings.body }}</div>
        </div>
    {%- endcase -%}
  {%- endfor -%}
</div>
