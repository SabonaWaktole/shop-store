<nav class="{% if section.settings.sticky_header %}fixed{% else %}relative{% endif %} top-0 w-full z-50 transition-colors duration-300 {% if section.settings.transparent_header %}bg-transparent{% else %}bg-background/90 dark:bg-background/90 backdrop-blur-[30px] border-b border-outline-variant{% endif %}" data-section-id="{{ section.id }}" data-section-type="header">
    
    <!-- Announcement Bar -->
    {%- assign announcement_blocks = section.blocks | where: 'type', 'announcement' -%}
    {%- if announcement_blocks.size > 0 -%}
        <div class="w-full bg-primary text-background overflow-hidden relative flex items-center justify-center py-2" id="announcement-bar" style="height: 40px;">
            {%- for block in announcement_blocks -%}
                <div class="announcement-slide font-label-mono text-label-mono uppercase tracking-widest text-center px-4 w-full transition-opacity duration-500 absolute inset-0 flex items-center justify-center {% if forloop.first %}opacity-100 z-10{% else %}opacity-0 z-0{% endif %}" {{ block.shopify_attributes }}>
                    {%- if block.settings.link != blank -%}
                        <a href="{{ block.settings.link }}" class="hover:underline">{{ block.settings.text }}</a>
                    {%- else -%}
                        {{ block.settings.text }}
                    {%- endif -%}
                </div>
            {%- endfor -%}
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const slides = document.querySelectorAll('.announcement-slide');
                if(slides.length > 1) {
                    let current = 0;
                    setInterval(() => {
                        slides[current].classList.replace('opacity-100', 'opacity-0');
                        slides[current].classList.replace('z-10', 'z-0');
                        current = (current + 1) % slides.length;
                        slides[current].classList.replace('opacity-0', 'opacity-100');
                        slides[current].classList.replace('z-0', 'z-10');
                    }, {{ section.settings.announcement_speed | default: 5 }} * 1000);
                }
            });
        </script>
    {%- endif -%}

    <div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop w-full max-w-container-max mx-auto relative group/header" style="height: {{ section.settings.header_height }}px;">
        
        <!-- Navigation Links (Left) -->
        <div class="hidden md:flex items-center gap-10">
            {% for link in linklists[section.settings.menu].links %}
                {%- assign is_mega = false -%}
                {%- assign mega_block = null -%}
                {%- assign link_title_lower = link.title | downcase -%}
                {%- for block in section.blocks -%}
                    {%- assign trigger_lower = block.settings.trigger_word | downcase -%}
                    {%- if block.type == 'mega_menu' and trigger_lower == link_title_lower -%}
                        {%- assign is_mega = true -%}
                        {%- assign mega_block = block -%}
                        {%- break -%}
                    {%- endif -%}
                {%- endfor -%}

                <div class="relative group/navitem">
                    <a class="font-label-mono font-medium text-on-surface-variant hover:text-primary transition-colors duration-300 uppercase {% if link.active %}text-primary border-b border-primary pb-1{% endif %}" style="font-size: {{ section.settings.nav_font_size }}px;" href="{{ link.url }}">
                        {{ link.title }}
                    </a>
                    
                    {%- if is_mega -%}
                        <!-- Mega Menu Dropdown -->
                        <div class="absolute top-full left-0 pt-6 hidden group-hover/navitem:block z-50">
                            <div class="bg-surface border border-outline-variant p-8 flex gap-12 shadow-2xl min-w-[600px]">
                                <!-- Links Column -->
                                <div class="flex flex-col gap-4 min-w-[200px]">
                                    {%- for childlink in link.links -%}
                                        <a href="{{ childlink.url }}" class="font-body-main text-on-surface-variant hover:text-primary uppercase tracking-wider">{{ childlink.title }}</a>
                                        {%- if childlink.links != blank -%}
                                            <div class="flex flex-col gap-2 pl-4 mt-2">
                                                {%- for grandchild in childlink.links -%}
                                                    <a href="{{ grandchild.url }}" class="font-caption text-on-surface-variant hover:text-primary">{{ grandchild.title }}</a>
                                                {%- endfor -%}
                                            </div>
                                        {%- endif -%}
                                    {%- endfor -%}
                                </div>
                                <!-- Promotional Images -->
                                {%- if mega_block.settings.promo_image_1 != blank -%}
                                    <div class="flex-1">
                                        <a href="{{ mega_block.settings.promo_link_1 | default: '#' }}" class="block group/promo">
                                            <img src="{{ mega_block.settings.promo_image_1 | image_url: width: 400 }}" class="w-full h-auto filter grayscale group-hover/promo:grayscale-0 transition-all duration-300">
                                            {%- if mega_block.settings.promo_text_1 != blank -%}
                                                <span class="block mt-4 font-label-mono text-primary uppercase tracking-widest group-hover/promo:underline">{{ mega_block.settings.promo_text_1 }}</span>
                                            {%- endif -%}
                                        </a>
                                    </div>
                                {%- endif -%}
                            </div>
                        </div>
                    {%- elsif link.links != blank -%}
                        <!-- Simple Dropdown -->
                        <div class="absolute top-full left-0 pt-6 hidden group-hover/navitem:block z-50">
                            <div class="bg-surface border border-outline-variant p-6 flex flex-col gap-4 min-w-[200px] shadow-2xl">
                                {%- for childlink in link.links -%}
                                    <a href="{{ childlink.url }}" class="font-label-mono text-on-surface-variant hover:text-primary uppercase tracking-widest">{{ childlink.title }}</a>
                                {%- endfor -%}
                            </div>
                        </div>
                    {%- endif -%}
                </div>
            {% endfor %}
        </div>

        <!-- Brand Logo (Absolute Center) -->
        <a class="font-display-xl text-display-xl tracking-widest text-primary absolute left-1/2 -translate-x-1/2 uppercase whitespace-nowrap" href="{{ routes.root_url }}">
            {%- if section.settings.logo_image != blank -%}
                <img src="{{ section.settings.logo_image | image_url: width: section.settings.logo_width }}" style="max-width: {{ section.settings.logo_width }}px;" alt="{{ section.settings.logo_image.alt | default: shop.name }}">
            {%- else -%}
                {{ section.settings.logo_text | default: 'PUBLIC EQUITY' }}
            {%- endif -%}
        </a>

        <!-- Trailing Icons (Right) -->
        <div class="flex items-center gap-8 text-primary dark:text-primary">
            {% if shop.customer_accounts_enabled %}
                <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="hover:opacity-70 transition-opacity">
                    <span class="material-symbols-outlined" style="font-size: {{ section.settings.icon_size }}px;">person</span>
                </a>
            {% endif %}
            
            <button class="hover:opacity-70 transition-opacity" aria-label="Search" onclick="document.querySelector('#SearchForm').classList.toggle('hidden'); document.querySelector('#SearchInput').focus();">
                <span class="material-symbols-outlined" style="font-size: {{ section.settings.icon_size }}px;">search</span>
            </button>
            
            <button class="hover:opacity-70 transition-opacity relative flex items-center" aria-label="Cart" onclick="openCartDrawer()">
                <span class="material-symbols-outlined" style="font-size: {{ section.settings.icon_size }}px;">shopping_bag</span>
                <span id="CartCount" class="absolute -top-2 -right-3 text-[16px] bg-primary text-background rounded-full h-8 w-8 flex items-center justify-center font-bold {% if cart.item_count == 0 %}hidden{% endif %}">
                    {{ cart.item_count }}
                </span>
            </button>
        </div>
    </div>
    
    <!-- Quick Search Dropdown -->
    <div id="SearchForm" class="hidden absolute top-full left-0 w-full bg-surface border-b border-outline-variant p-4 z-40">
        <predictive-search class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative block">
            <form action="{{ routes.search_url }}" method="get" role="search" class="relative">
                <input type="text" id="SearchInput" name="q" placeholder="{{ section.settings.search_placeholder | default: 'SEARCH PUBLIC EQUITY...' }}" class="cinetica-input w-full font-label-mono text-label-mono uppercase outline-none focus:ring-0" autocomplete="off" {%- if section.settings.enable_predictive_search -%}role="combobox" aria-expanded="false" aria-owns="predictive-search-results" aria-controls="predictive-search-results" aria-haspopup="listbox" aria-autocomplete="list"{%- endif -%}>
                <input type="hidden" name="options[prefix]" value="last">
                <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2 text-primary">
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </form>
            
            {%- if section.settings.enable_predictive_search -%}
                <div id="predictive-search-results" class="hidden absolute top-[calc(100%+16px)] left-margin-mobile md:left-margin-desktop right-margin-mobile md:right-margin-desktop bg-surface border border-outline-variant p-6 shadow-2xl z-50 min-h-[100px]" tabindex="-1">
                    <!-- Results injected here via JS -->
                    <div id="predictive-search-results-list" class="flex flex-col gap-4"></div>
                    <div id="predictive-search-loading" class="hidden text-center text-on-surface-variant font-label-mono text-label-mono uppercase">Searching...</div>
                </div>
            {%- endif -%}
        </predictive-search>
    </div>
</nav>

{%- if section.settings.sticky_header -%}
<!-- Push main content down to account for fixed header -->
<div class="w-full" style="height: {{ section.settings.header_height }}px;"></div>
{%- endif -%}

<script>
    // Simple Cart Drawer Toggle
    function openCartDrawer() {
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-overlay');
        if(drawer && overlay) {
            drawer.classList.remove('translate-x-full');
            drawer.classList.add('translate-x-0');
            overlay.classList.remove('hidden');
        } else {
            window.location.href = "{{ routes.cart_url }}";
        }
    }
</script>

{%- if section.settings.enable_predictive_search -%}
<script>
class PredictiveSearch extends HTMLElement {
  constructor() {
    super();
    this.input = this.querySelector('input[type="text"]');
    this.predictiveSearchResults = this.querySelector('#predictive-search-results');
    this.resultsList = this.querySelector('#predictive-search-results-list');
    this.loadingIndicator = this.querySelector('#predictive-search-loading');

    this.input.addEventListener('input', this.debounce((event) => {
      this.onChange(event);
    }, 300).bind(this));
  }

  onChange() {
    const searchTerm = this.input.value.trim();

    if (!searchTerm.length) {
      this.close();
      return;
    }

    this.getSearchResults(searchTerm);
  }

  getSearchResults(searchTerm) {
    this.open();
    this.loadingIndicator.classList.remove('hidden');
    this.resultsList.innerHTML = '';

    fetch(`/search/suggest.json?q=${searchTerm}&resources[type]=product{% if section.settings.show_articles_pages %},article,page{% endif %}&resources[limit]=4&resources[options][unavailable_products]=last`)
      .then((response) => response.json())
      .then((text) => {
        const results = text.resources.results;
        this.loadingIndicator.classList.add('hidden');
        this.renderResults(results, searchTerm);
      })
      .catch((error) => {
        this.close();
        throw error;
      });
  }
  
  renderResults(results, searchTerm) {
      if(!results.products || results.products.length === 0) {
          this.resultsList.innerHTML = `<div class="font-label-mono text-label-mono uppercase text-on-surface-variant">No results for "${searchTerm}"</div>`;
          return;
      }
      
      let html = '';
      results.products.forEach(product => {
          html += `
          <a href="${product.url}" class="flex items-center gap-4 group/result hover:bg-surface-variant p-2 transition-colors">
              ${product.image && {{ section.settings.show_product_images | json }} ? `<img src="${product.image}" class="w-12 h-16 object-cover" alt="">` : ''}
              <div class="flex flex-col">
                  <span class="font-label-mono text-label-mono uppercase text-primary tracking-widest group-hover/result:underline">${product.title}</span>
                  <span class="font-body-main text-sm text-on-surface-variant">${product.price}</span>
              </div>
          </a>
          `;
      });
      
      {% if section.settings.show_articles_pages %}
      if(results.pages && results.pages.length > 0) {
          html += `<div class="border-t border-outline-variant my-2"></div><div class="font-label-mono text-label-mono text-on-surface-variant mb-2">PAGES</div>`;
          results.pages.forEach(page => {
              html += `<a href="${page.url}" class="font-body-main uppercase hover:underline text-primary block py-1">${page.title}</a>`;
          });
      }
      {% endif %}
      
      html += `
      <div class="border-t border-outline-variant my-2 pt-2">
        <a href="${routes.search_url}?q=${searchTerm}" class="font-label-mono text-label-mono uppercase text-accent hover:underline flex items-center gap-2">View all results <span class="material-symbols-outlined text-[16px]">arrow_forward</span></a>
      </div>
      `;
      
      this.resultsList.innerHTML = html;
  }

  open() {
    this.predictiveSearchResults.classList.remove('hidden');
  }

  close() {
    this.predictiveSearchResults.classList.add('hidden');
  }

  debounce(fn, wait) {
    let t;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn.apply(this, args), wait);
    };
  }
}

customElements.define('predictive-search', PredictiveSearch);
</script>
{%- endif -%}

{% schema %}
{
  "name": "Header (Public Equity)",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Appearance"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "Enable transparent header",
      "default": false
    },
    {
      "type": "range",
      "id": "header_height",
      "label": "Header Height",
      "min": 60,
      "max": 140,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "PUBLIC EQUITY"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width (Image only)",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu",
      "default": "main-menu"
    },
    {
      "type": "range",
      "id": "nav_font_size",
      "label": "Navigation Font Size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder Text",
      "default": "SEARCH PUBLIC EQUITY..."
    },
    {
      "type": "checkbox",
      "id": "enable_predictive_search",
      "label": "Enable predictive search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_images",
      "label": "Show product images in search results",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_articles_pages",
      "label": "Show articles and pages in search results",
      "default": true
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "range",
      "id": "announcement_speed",
      "label": "Rotation Speed (seconds)",
      "min": 3,
      "max": 15,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "default": "FREE SHIPPING ON ORDERS OVER $200"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "mega_menu",
      "name": "Mega Menu",
      "settings": [
        {
          "type": "text",
          "id": "trigger_word",
          "label": "Menu Item Trigger",
          "info": "Type the exact name of the menu item (e.g., 'Catalog') to attach this mega menu to it."
        },
        {
          "type": "image_picker",
          "id": "promo_image_1",
          "label": "Promo Image 1"
        },
        {
          "type": "text",
          "id": "promo_text_1",
          "label": "Promo Text 1"
        },
        {
          "type": "url",
          "id": "promo_link_1",
          "label": "Promo Link 1"
        }
      ]
    }
  ]
}
{% endschema %}
