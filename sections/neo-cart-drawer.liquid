{% schema %}
{
  "name": "NEO-DYS Cart Drawer",
  "settings": []
}
{% endschema %}

<div id="cart-drawer-overlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[90] hidden opacity-0 transition-opacity duration-300" onclick="closeCart()"></div>

<div id="cart-drawer" class="fixed top-0 right-0 h-full w-full sm:w-[450px] bg-surface-container-lowest border-l border-outline-variant z-[100] transform translate-x-full transition-transform duration-500 ease-out flex flex-col">
    <!-- Glitch edge effect -->
    <div class="absolute left-0 top-0 bottom-0 w-[1px] bg-primary-container shadow-[0_0_10px_#39ff14] opacity-50"></div>
    <div class="absolute inset-0 pointer-events-none metal-texture opacity-30"></div>
    <div class="scanline z-0"></div>

    <!-- Header -->
    <div class="p-6 border-b border-outline-variant flex justify-between items-center relative z-10 bg-background/90 backdrop-blur-md">
        <div>
            <h2 class="font-headline-lg text-2xl uppercase tracking-tighter text-on-surface">SECURED_CARGO</h2>
            <p class="font-utility-label text-[10px] text-primary-fixed-dim uppercase tracking-widest mt-1">
                SYSTEM_STATUS: <span class="animate-pulse inline-block w-1.5 h-1.5 bg-primary-container rounded-full ml-1"></span> ONLINE
            </p>
        </div>
        <button onclick="closeCart()" class="text-on-surface hover:text-primary-container transition-colors p-2">
            <span class="material-symbols-outlined text-3xl font-light">close</span>
        </button>
    </div>

    <!-- Cart Items Area -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-6 relative z-10">
        {%- if cart.item_count > 0 -%}
            <form action="{{ routes.cart_url }}" method="post" id="cart-drawer-form" class="flex flex-col gap-6">
                {%- for item in cart.items -%}
                    <div class="flex gap-4 p-4 border border-outline-variant bg-surface-container-low group hover:border-primary-fixed-dim transition-colors relative">
                        <!-- Product Image -->
                        <div class="w-24 h-24 bg-black border border-outline-variant flex-shrink-0 relative overflow-hidden">
                            {%- if item.image -%}
                                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500">
                            {%- else -%}
                                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover grayscale' }}
                            {%- endif -%}
                        </div>
                        
                        <!-- Details -->
                        <div class="flex-1 flex flex-col justify-between">
                            <div class="flex justify-between items-start gap-2">
                                <div>
                                    <h3 class="font-utility-label text-sm text-on-surface uppercase pr-4 leading-tight">
                                        <a href="{{ item.url }}" class="hover:text-primary-container transition-colors">{{ item.product.title }}</a>
                                    </h3>
                                    {%- unless item.product.has_only_default_variant -%}
                                        <p class="font-utility-label text-[10px] text-on-surface-variant uppercase mt-1">{{ item.variant.title }}</p>
                                    {%- endunless -%}
                                </div>
                                <a href="{{ item.url_to_remove }}" class="text-on-surface-variant hover:text-error transition-colors">
                                    <span class="material-symbols-outlined text-sm">delete</span>
                                </a>
                            </div>
                            
                            <div class="flex justify-between items-end mt-4">
                                <div class="flex items-center border border-outline-variant bg-background">
                                    <button type="button" class="px-2 py-1 text-on-surface hover:text-primary-container" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('change'))">-</button>
                                    <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="w-10 bg-transparent text-center font-utility-label text-sm text-on-surface border-none focus:ring-0 p-0 appearance-none">
                                    <button type="button" class="px-2 py-1 text-on-surface hover:text-primary-container" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('change'))">+</button>
                                </div>
                                <span class="font-utility-label text-sm text-primary-container">{{ item.final_line_price | money }}</span>
                            </div>
                        </div>
                    </div>
                {%- endfor -%}
            </form>
        {%- else -%}
            <!-- Empty State -->
            <div class="h-full flex flex-col items-center justify-center text-center opacity-50">
                <span class="material-symbols-outlined text-6xl mb-4 font-light">inventory_2</span>
                <p class="font-utility-label text-sm uppercase tracking-widest text-on-surface-variant">NO_ASSETS_ACQUIRED</p>
                <p class="font-utility-label text-[10px] text-on-surface-variant mt-2 max-w-xs">RETURN TO TERMINAL TO SECURE HARDWARE</p>
                <button onclick="closeCart()" class="mt-8 border border-outline-variant px-6 py-3 font-utility-label text-xs uppercase hover:border-primary-container hover:text-primary-container transition-colors">INITIATE_SEARCH</button>
            </div>
        {%- endif -%}
    </div>

    <!-- Footer / Checkout -->
    {%- if cart.item_count > 0 -%}
        <div class="p-6 border-t border-outline-variant relative z-10 bg-background/90 backdrop-blur-md">
            <div class="flex justify-between items-center mb-6">
                <span class="font-utility-label text-sm uppercase text-on-surface-variant tracking-widest">TOTAL_VALUATION</span>
                <span class="font-headline-lg text-2xl text-primary-container">{{ cart.total_price | money }}</span>
            </div>
            <p class="font-utility-label text-[10px] text-on-surface-variant uppercase mb-6 opacity-60">SHIPPING_AND_TAXES_CALCULATED_AT_CHECKOUT</p>
            
            <button type="submit" form="cart-drawer-form" name="checkout" class="glitch-hover relative w-full py-4 bg-primary-container text-on-primary-container font-utility-label text-sm uppercase font-bold tracking-widest flex items-center justify-center gap-3 border border-primary-container shadow-[0_0_15px_rgba(57,255,20,0.15)] group overflow-hidden">
                <span class="relative z-10">INITIATE_TRANSFER</span>
                <span class="material-symbols-outlined text-lg relative z-10">arrow_forward</span>
                <div class="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </button>
        </div>
    {%- endif -%}
</div>

<script>
    function openCart() {
        document.getElementById('cart-drawer').classList.remove('translate-x-full');
        document.getElementById('cart-drawer-overlay').classList.remove('hidden');
        // small delay to allow display:block to apply before opacity transition
        setTimeout(() => {
            document.getElementById('cart-drawer-overlay').classList.remove('opacity-0');
        }, 10);
        document.body.style.overflow = 'hidden';
    }

    function closeCart() {
        document.getElementById('cart-drawer').classList.add('translate-x-full');
        document.getElementById('cart-drawer-overlay').classList.add('opacity-0');
        setTimeout(() => {
            document.getElementById('cart-drawer-overlay').classList.add('hidden');
        }, 300);
        document.body.style.overflow = '';
    }

    // Bind to header cart icon if it exists (example: <span onclick="openCart()">...</span>)
    document.addEventListener('DOMContentLoaded', () => {
        // Find cart icons in the header and bind openCart
        const cartIcons = document.querySelectorAll('[href="{{ routes.cart_url }}"], .cart-icon, [onclick="openCart()"]');
        cartIcons.forEach(icon => {
            // Check if it's a link, if so prevent default
            if(icon.tagName === 'A') {
                icon.addEventListener('click', (e) => {
                    e.preventDefault();
                    openCart();
                });
            } else {
                icon.addEventListener('click', openCart);
            }
        });
    });
</script>
