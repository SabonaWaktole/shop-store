<div class="w-full max-w-container-max mx-auto pt-[60px] md:pt-[100px] pb-32 px-margin-mobile md:px-margin-desktop" data-section-id="{{ section.id }}" data-section-type="cart">
    <header class="mb-16 border-b border-outline-variant pb-8">
        <h1 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg uppercase text-primary leading-none tracking-tight">
            YOUR CART
            {%- if cart.item_count > 0 -%}
                <span class="text-on-surface-variant font-normal text-3xl ml-4">({{ cart.item_count }})</span>
            {%- endif -%}
        </h1>
    </header>

    {%- if cart.item_count > 0 -%}
        <form action="{{ routes.cart_url }}" method="post" id="cart-page-form" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
            
            <!-- Items List -->
            <div class="lg:col-span-8 flex flex-col gap-8">
                <!-- Shipping Progress -->
                {%- assign free_shipping_threshold = 20000 -%}
                {%- assign difference = free_shipping_threshold | minus: cart.total_price -%}
                <div class="p-8 bg-surface border border-outline-variant">
                    <div class="flex justify-between items-end mb-4">
                        <span class="font-label-mono text-label-mono text-on-surface-variant uppercase">Shipping Tier</span>
                        {%- if difference > 0 -%}
                            <span class="font-label-mono text-label-mono text-primary uppercase">{{ difference | money }} AWAY FROM SECURE DELIVERY</span>
                        {%- else -%}
                            <span class="font-label-mono text-label-mono text-primary uppercase">SECURE DELIVERY UNLOCKED</span>
                        {%- endif -%}
                    </div>
                    <!-- Minimal Progress Bar: 1px line -->
                    <div class="w-full h-gutter bg-surface-container-highest relative">
                        {%- assign progress = cart.total_price | times: 100 | divided_by: free_shipping_threshold | at_most: 100 -%}
                        <div class="absolute top-0 left-0 h-full bg-primary transition-all duration-1000 ease-out" style="width: {{ progress }}%;"></div>
                    </div>
                </div>

                <!-- Loop items -->
                <div class="border-t border-outline-variant">
                    {%- for item in cart.items -%}
                        <div class="flex gap-8 py-8 border-b border-outline-variant relative group">
                            <!-- Image -->
                            <a href="{{ item.url }}" class="w-32 h-40 md:w-40 md:h-48 shrink-0 bg-surface-container relative block">
                                {%- if item.image -%}
                                    <img src="{{ item.image | image_url: width: 400 }}" alt="{{ item.image.alt | escape }}" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500">
                                {%- else -%}
                                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAUUTk5MvbKcMcACFnaW3cb0njlZAHsWU28GDk4ovz5y4AXG4H7dQYTHdkTm-b8R6OdiLVQcDsUADfpB1Z_ukRc3HmiV8MleN2r2SXTOhReUvEltpbYsp-ymJ5yeQcUUg5hUovjlFVRrLPY_yEnGLrHAGjAfUNrPUxkCGseQmGj31mPTCRMk0O8StcSoCGjQvlTLqklwb5EqRCMf6Hs9PrT3vTgPf6c51u-p_fJZwF5a8NETdxOi9NG0ThU52dDFngmRuhoGD3fDBxu" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500">
                                {%- endif -%}
                                <div class="absolute inset-0 border border-outline-variant/30 pointer-events-none"></div>
                            </a>
                            
                            <!-- Details -->
                            <div class="flex flex-col justify-between flex-1">
                                <div class="flex justify-between items-start gap-4">
                                    <div class="flex flex-col">
                                        <a href="{{ item.url }}" class="font-headline-lg-mobile md:text-2xl text-primary uppercase tracking-wider hover:underline">{{ item.product.title }}</a>
                                        {%- unless item.product.has_only_default_variant -%}
                                            <span class="font-label-mono text-label-mono text-on-surface-variant mt-2">{{ item.variant.title }}</span>
                                        {%- endunless -%}
                                    </div>
                                    <span class="font-label-mono text-label-mono text-primary">{{ item.final_line_price | money }}</span>
                                </div>
                                
                                <div class="flex justify-between items-end mt-8">
                                    <div class="flex items-center gap-4 border border-outline-variant px-4 py-2 font-label-mono text-label-mono text-primary">
                                        <label for="updates_{{ item.key }}" class="sr-only">Quantity</label>
                                        <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="w-12 bg-transparent text-center focus:outline-none focus:ring-0 p-0 border-none">
                                    </div>
                                    <a href="{{ item.url_to_remove }}" class="font-label-mono text-label-mono text-on-surface-variant hover:text-error transition-colors underline decoration-outline-variant hover:decoration-error underline-offset-4">REMOVE</a>
                                </div>
                            </div>
                        </div>
                    {%- endfor -%}
                </div>
                
                <div class="flex justify-start">
                    <button type="submit" name="update" class="border border-outline-variant px-8 py-4 font-label-mono text-label-mono uppercase hover:bg-surface hover:text-primary transition-colors duration-300">
                        UPDATE QUANTITIES
                    </button>
                </div>
            </div>

            <!-- Summary Column -->
            <div class="lg:col-span-4 relative">
                <div class="sticky top-24 bg-surface border border-outline-variant p-8 md:p-12 flex flex-col gap-8">
                    <h2 class="font-label-mono text-label-mono text-on-surface-variant uppercase border-b border-outline-variant pb-4">ORDER SUMMARY</h2>
                    
                    <div class="flex justify-between items-end">
                        <span class="font-label-mono text-label-mono text-primary uppercase">SUBTOTAL</span>
                        <span class="font-headline-lg-mobile text-headline-lg-mobile text-primary tracking-widest">{{ cart.total_price | money }}</span>
                    </div>
                    
                    <p class="font-caption text-caption text-on-surface-variant border-y border-outline-variant py-4">
                        TAXES AND SHIPPING CALCULATED AT SECURE TERMINAL.
                    </p>
                    
                    <button type="submit" name="checkout" class="w-full bg-primary text-background border border-primary py-6 font-label-mono text-[14px] uppercase tracking-[0.2em] font-bold hover:bg-background hover:text-primary transition-all duration-300 flex justify-center items-center gap-4 group">
                        <span>INITIALIZE CHECKOUT</span>
                        <span class="material-symbols-outlined transform group-hover:translate-x-2 transition-transform duration-300">arrow_forward</span>
                    </button>
                </div>
            </div>
            
        </form>
    {%- else -%}
        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-32 text-center">
            <span class="material-symbols-outlined text-[80px] text-outline-variant mb-8">shopping_cart</span>
            <p class="font-label-mono text-label-mono text-on-surface-variant uppercase tracking-widest mb-12">CART IS EMPTY</p>
            <a href="{{ routes.all_products_collection_url }}" class="inline-block bg-primary text-background px-12 py-5 font-label-mono text-label-mono uppercase hover:bg-background hover:text-primary transition-colors border border-primary">
                RETURN TO SHOP
            </a>
        </div>
    {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart Page (PE)",
  "settings": []
}
{% endschema %}
