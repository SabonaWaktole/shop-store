{% schema %}
{
  "name": "Luxury Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "CURATED PRODUCTS"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "grid_columns",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ],
      "default": "4",
      "label": "Grid Columns (Desktop)"
    },
    {
      "type": "range",
      "id": "grid_gap_x",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24,
      "label": "Horizontal Gap"
    },
    {
      "type": "range",
      "id": "grid_gap_y",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Vertical Gap"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "default": "#FFFFFF",
      "label": "Section Background"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "default": "#000000",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "default": "#6B7280",
      "label": "Muted Text Color"
    },
    {
      "type": "color",
      "id": "section_border_color",
      "default": "#E5E7EB",
      "label": "Border Color"
    },
    {
      "type": "header",
      "content": "Card Display"
    },
    {
      "type": "select",
      "id": "card_aspect_ratio",
      "options": [
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/3", "label": "Landscape (4:3)" }
      ],
      "default": "3/4",
      "label": "Card Image Ratio"
    },
    {
      "type": "checkbox",
      "id": "show_hover_image",
      "default": true,
      "label": "Show Second Image on Hover"
    },
    {
      "type": "range",
      "id": "card_title_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14,
      "label": "Product Title Size"
    },
    {
      "type": "select",
      "id": "card_title_font_weight",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" }
      ],
      "default": "500",
      "label": "Product Title Weight"
    },
    {
      "type": "range",
      "id": "card_price_font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "Price Font Size"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show Vendor"
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "default": true,
      "label": "Show Drop Badges"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxury Featured Products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}

{%- assign grid_desktop = 'lg:grid-cols-4' -%}
{%- if section.settings.grid_columns == '2' -%}
  {%- assign grid_desktop = 'lg:grid-cols-2' -%}
{%- elsif section.settings.grid_columns == '3' -%}
  {%- assign grid_desktop = 'lg:grid-cols-3' -%}
{%- endif -%}

<section class="w-full py-16" style="background-color: {{ section.settings.section_bg_color }}; color: {{ section.settings.section_text_color }};">
    <div class="max-w-[1600px] mx-auto px-4 md:px-8">
        <div class="flex items-end justify-between mb-12 border-b pb-4" style="border-color: {{ section.settings.section_border_color }};">
            <h2 class="tracking-tighter text-2xl font-semibold uppercase">{{ section.settings.title }}</h2>
            {%- if section.settings.view_all_link != blank -%}
            <a href="{{ section.settings.view_all_link }}" class="font-medium tracking-widest uppercase transition-colors hover:opacity-70 text-xs" style="color: {{ section.settings.muted_text_color }};">
                View All
            </a>
            {%- endif -%}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 {{ grid_desktop }}" style="column-gap: {{ section.settings.grid_gap_x }}px; row-gap: {{ section.settings.grid_gap_y }}px;">
            {%- for block in section.blocks -%}
                {%- assign product = block.settings.product -%}
                
                <div class="group relative" {{ block.shopify_attributes }}>
                    {%- if product != blank -%}
                        <a href="{{ product.url }}" class="block overflow-hidden relative" style="aspect-ratio: {{ section.settings.card_aspect_ratio }};">
                            {%- if product.featured_image -%}
                                <img class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-0" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
                                
                                {%- if section.settings.show_hover_image -%}
                                    {%- if product.images[1] -%}
                                        <img class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 group-hover:opacity-100" src="{{ product.images[1] | image_url: width: 600 }}" alt="{{ product.images[1].alt | escape }}" loading="lazy">
                                    {%- else -%}
                                        <img class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 group-hover:opacity-100" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
                                    {%- endif -%}
                                {%- endif -%}
                            {%- else -%}
                                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
                            {%- endif -%}
                            
                            {%- if section.settings.show_badges -%}
                            <div class="absolute top-4 left-4 flex flex-col gap-2">
                                {% render 'drop-state-engine', product: product, context: 'badge' %}
                            </div>
                            {%- endif -%}
                        </a>
                        
                        <div class="mt-4 flex flex-col gap-1">
                            {%- if section.settings.show_vendor -%}
                                <span class="tracking-widest uppercase" style="font-size: {{ section.settings.card_price_font_size | minus: 2 }}px; color: {{ section.settings.muted_text_color }};">{{ product.vendor }}</span>
                            {%- endif -%}
                            <a href="{{ product.url }}" class="tracking-wide hover:underline underline-offset-4" style="font-size: {{ section.settings.card_title_font_size }}px; font-weight: {{ section.settings.card_title_font_weight }};">
                                {{ product.title }}
                            </a>
                            <span style="font-size: {{ section.settings.card_price_font_size }}px; color: {{ section.settings.muted_text_color }};">{{ product.price | money }}</span>
                        </div>
                    {%- else -%}
                        <!-- Fallback block -->
                        <div class="block overflow-hidden relative bg-muted/20" style="aspect-ratio: {{ section.settings.card_aspect_ratio }};">
                            <div class="flex items-center justify-center w-full h-full text-xs tracking-widest text-muted-foreground uppercase">Select Product</div>
                        </div>
                        <div class="mt-4 flex flex-col gap-1">
                            <span class="tracking-wide" style="font-size: {{ section.settings.card_title_font_size }}px; font-weight: {{ section.settings.card_title_font_weight }};">Product Title</span>
                            <span style="font-size: {{ section.settings.card_price_font_size }}px; color: {{ section.settings.muted_text_color }};">$0.00</span>
                        </div>
                    {%- endif -%}
                </div>
            {%- else -%}
                <p class="col-span-full py-12 text-center" style="color: {{ section.settings.muted_text_color }};">No products selected. Add product blocks below.</p>
            {%- endfor -%}
        </div>
    </div>
</section>
