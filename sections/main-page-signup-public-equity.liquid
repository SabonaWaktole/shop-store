<!-- Main Content Area - Cinematic Brutalism -->
<main class="flex-grow flex items-center justify-center relative w-full min-h-screen p-margin-mobile md:p-margin-desktop z-10" data-section-id="{{ section.id }}" data-section-type="signup">
    
    <!-- Hero Background Image Container with Scanner -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
        <div class="absolute inset-0 bg-background/80 z-10 mix-blend-multiply"></div> <!-- Void Stacking -->
        {%- if section.settings.bg_image -%}
            <div class="absolute inset-0 bg-cover bg-center filter grayscale contrast-125 opacity-30 object-center" style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}')"></div>
        {%- else -%}
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuC7WdURs0paQogpdnv7VlPc1DSkoOHsIanxF3NcfnuKJgiQ5wR9jvWzZWZngjKFmdpVB67m5A9GYVDLKwPzqXcSWvYPPdtzLi9GRIuiJxVORF5qryiJMJYKOqcBAdY1iitAvNNSv8vH7XFlak3Rp_-OzUny9_JPGK_ec3UxV7d3q-oo3vA78YhM76-cXSzRVNGKRrWKwsSN5mwVohLo_lhM2NtMkRe3k2l4T8u9gqGHEgofdJz2OHbjekMS2AVjnjGmKDR5HtHY5te5" alt="Placeholder" class="w-full h-full object-cover filter grayscale contrast-125 opacity-30 object-center">
        {%- endif -%}
        <div class="scanner-line"></div>
    </div>
    
    <!-- The Signup Modal / Container -->
    <div class="relative z-20 w-full max-w-2xl bg-surface/90 backdrop-blur-3xl border border-outline-variant p-8 md:p-16 flex flex-col gap-12">
        <!-- Grid Lines inside the box -->
        <div class="absolute top-0 left-0 w-full h-[1px] bg-outline-variant"></div>
        <div class="absolute bottom-0 left-0 w-full h-[1px] bg-outline-variant"></div>
        <div class="absolute top-0 left-0 w-[1px] h-full bg-outline-variant"></div>
        <div class="absolute top-0 right-0 w-[1px] h-full bg-outline-variant"></div>
        <div class="absolute top-1/2 left-0 w-full h-[1px] bg-outline-variant/30 pointer-events-none"></div>
        <div class="absolute top-0 left-1/2 w-[1px] h-full bg-outline-variant/30 pointer-events-none"></div>
        
        <!-- Header Section -->
        <div class="text-center space-y-6 relative z-10">
            <h1 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary uppercase tracking-widest">
                {{ section.settings.heading | default: 'ACCESS THE DROP 001' }}
            </h1>
            <div class="w-12 h-[1px] bg-primary mx-auto"></div>
            <p class="font-body-main text-body-main text-on-surface-variant max-w-md mx-auto">
                {{ section.settings.subheading | default: 'Join the list for early access and exclusive drops.' }}
            </p>
        </div>
        
        <!-- Form Section -->
        <div class="relative z-10">
            {% form 'customer', id: 'joinListForm', class: 'space-y-8' %}
                <input type="hidden" name="contact[tags]" value="prospect, early-access">
                
                <div class="space-y-6">
                    <!-- Email Field -->
                    <div class="flex flex-col relative group">
                        <label class="font-label-mono text-label-mono text-on-surface-variant mb-1 group-focus-within:text-primary transition-colors" for="email">
                            EMAIL ADDRESS
                        </label>
                        <input class="cinetica-input font-label-mono text-label-mono w-full focus:ring-0" id="email" name="contact[email]" placeholder=" " required type="email" value="{{ form.email }}">
                    </div>
                    <!-- Mobile Number Field -->
                    <div class="flex flex-col relative group">
                        <label class="font-label-mono text-label-mono text-on-surface-variant mb-1 group-focus-within:text-primary transition-colors" for="mobile">
                            MOBILE NUMBER
                        </label>
                        <input class="cinetica-input font-label-mono text-label-mono w-full focus:ring-0" id="mobile" name="contact[phone]" placeholder=" " required type="tel" value="{{ form.phone }}">
                    </div>
                </div>
                
                {%- if form.errors -%}
                    <div class="text-error font-label-mono text-label-mono mt-4 uppercase text-center">
                        {{ form.errors | default_errors }}
                    </div>
                {%- endif -%}

                <!-- Submit CTA -->
                <button type="submit" class="w-full bg-primary text-on-primary font-label-mono text-label-mono py-5 uppercase tracking-[0.2em] transition-all duration-300 hover:bg-background hover:text-primary hover:outline hover:outline-1 hover:outline-primary relative overflow-hidden group">
                    <span class="relative z-10">{{ section.settings.button_text | default: 'GET ACCESS' }}</span>
                    <!-- Hover Effect Background -->
                    <div class="absolute inset-0 bg-background transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 ease-out z-0"></div>
                    <span class="relative z-10 mix-blend-difference text-primary group-hover:text-primary transition-colors delay-100">{{ section.settings.button_text | default: 'GET ACCESS' }}</span>
                </button>
                
                <!-- Small Print -->
                <p class="font-caption text-caption text-on-surface-variant text-center mt-4">
                    {{ section.settings.footer_text | default: 'BY SUBMITTING, YOU AGREE TO OUR TERMS AND PRIVACY POLICY.' }}
                </p>

                <!-- Success State -->
                {%- if form.posted_successfully? -%}
                    <div class="absolute inset-0 bg-surface/95 backdrop-blur-xl flex flex-col items-center justify-center p-8 text-center z-50 border border-outline-variant" id="successState">
                        <span class="material-symbols-outlined text-[64px] text-primary mb-6 animate-pulse" style="font-variation-settings: 'FILL' 1;">done_all</span>
                        <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary uppercase mb-4">ACCESS GRANTED</h2>
                        <p class="font-label-mono text-label-mono text-on-surface-variant tracking-widest">TRANSMISSION SECURED.</p>
                    </div>
                {%- endif -%}
            {% endform %}
        </div>
    </div>
</main>

{% schema %}
{
  "name": "Signup (Public Equity)",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ACCESS THE DROP 001"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join the list for early access and exclusive drops."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "GET ACCESS"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Disclaimer",
      "default": "BY SUBMITTING, YOU AGREE TO OUR TERMS AND PRIVACY POLICY."
    }
  ]
}
{% endschema %}
