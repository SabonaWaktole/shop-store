{% schema %}
{
  "name": "Luxury Footer",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "footer_layout",
      "options": [
        { "value": "2-column", "label": "2 Columns" },
        { "value": "3-column", "label": "3 Columns" },
        { "value": "4-column", "label": "4 Columns" }
      ],
      "default": "3-column",
      "label": "Footer Layout"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "footer_padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64,
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "footer_padding_bottom",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32,
      "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "default": "#FFFFFF",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "footer_text_color",
      "default": "#000000",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "footer_heading_color",
      "default": "#6B7280",
      "label": "Heading Color"
    },
    {
      "type": "color",
      "id": "footer_link_color",
      "default": "#000000",
      "label": "Link Color"
    },
    {
      "type": "color",
      "id": "footer_link_hover_color",
      "default": "#6B7280",
      "label": "Link Hover Color"
    },
    {
      "type": "color",
      "id": "footer_border_color",
      "default": "#E5E7EB",
      "label": "Border Color"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "footer_heading_font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "Heading Font Size"
    },
    {
      "type": "select",
      "id": "footer_heading_font_weight",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" }
      ],
      "default": "500",
      "label": "Heading Font Weight"
    },
    {
      "type": "checkbox",
      "id": "footer_heading_uppercase",
      "default": true,
      "label": "Uppercase Headings"
    },
    {
      "type": "range",
      "id": "footer_link_font_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14,
      "label": "Link Font Size"
    },
    {
      "type": "range",
      "id": "footer_copyright_font_size",
      "min": 10,
      "max": 14,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "Copyright Font Size"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "checkbox",
      "id": "footer_show_social",
      "default": true,
      "label": "Show Social Section"
    },
    {
      "type": "range",
      "id": "footer_social_icon_size",
      "min": 14,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 20,
      "label": "Social Icon Size"
    },
    {
      "type": "color",
      "id": "footer_social_color",
      "default": "#000000",
      "label": "Social Icon Color"
    },
    {
      "type": "color",
      "id": "footer_social_hover_color",
      "default": "#6B7280",
      "label": "Social Hover Color"
    },
    {
      "type": "range",
      "id": "footer_social_spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16,
      "label": "Social Icon Spacing"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "footer_show_newsletter",
      "default": true,
      "label": "Show Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Join the Waitlist"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Subscribe to receive updates on exclusive releases, early access, and editorial content."
    },
    {
      "type": "range",
      "id": "newsletter_heading_font_size",
      "min": 16,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24,
      "label": "Newsletter Heading Size"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "default": "Subscribe",
      "label": "Button Text"
    },
    {
      "type": "header",
      "content": "── Klaviyo (optional) ──"
    },
    {
      "type": "text",
      "id": "klaviyo_public_key",
      "label": "Klaviyo Public API Key",
      "info": "Your 6-character Klaviyo Site ID. Leave blank to auto-detect from the Klaviyo app script."
    },
    {
      "type": "text",
      "id": "klaviyo_email_list_id",
      "label": "Klaviyo Email List ID",
      "info": "Optional. Adds subscribers to this Klaviyo list."
    },
    {
      "type": "text",
      "id": "klaviyo_sms_list_id",
      "label": "Klaviyo SMS List ID",
      "info": "Optional. Adds SMS subscribers to this Klaviyo list."
    },
    {
      "type": "header",
      "content": "Footer Extras"
    },
    {
      "type": "checkbox",
      "id": "footer_show_payment_icons",
      "default": false,
      "label": "Show Payment Icons"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "range",
      "id": "footer_logo_width",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120,
      "label": "Footer Logo Width"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "default": "footer",
      "label": "Footer Menu"
    }
  ]
}
{% endschema %}

{%- assign grid_cols = 'md:grid-cols-12' -%}
{%- assign newsletter_span = 'lg:col-span-6' -%}
{%- assign links_span = 'lg:col-span-3' -%}
{%- assign social_span = 'lg:col-span-3' -%}

{%- if section.settings.footer_layout == '2-column' -%}
  {%- assign newsletter_span = 'lg:col-span-6' -%}
  {%- assign links_span = 'lg:col-span-6' -%}
  {%- assign social_span = 'hidden' -%}
{%- elsif section.settings.footer_layout == '4-column' -%}
  {%- assign newsletter_span = 'lg:col-span-4' -%}
  {%- assign links_span = 'lg:col-span-4' -%}
  {%- assign social_span = 'lg:col-span-4' -%}
{%- endif -%}

<style>
  .footer-link-hover {
    color: {{ section.settings.footer_link_color }};
  }
  .footer-link-hover:hover {
    color: {{ section.settings.footer_link_hover_color }};
  }
  .footer-social-hover {
    color: {{ section.settings.footer_social_color }};
  }
  .footer-social-hover:hover {
    color: {{ section.settings.footer_social_hover_color }};
  }
</style>

<footer class="border-t mt-24" style="background-color: {{ section.settings.footer_bg_color }}; color: {{ section.settings.footer_text_color }}; border-color: {{ section.settings.footer_border_color }}; padding-top: {{ section.settings.footer_padding_top }}px; padding-bottom: {{ section.settings.footer_padding_bottom }}px;">
    <div class="max-w-[1600px] mx-auto px-4 md:px-8">
        
        {%- if section.settings.footer_logo != blank -%}
          <div class="mb-12">
            <img src="{{ section.settings.footer_logo | image_url: width: 400 }}" alt="{{ shop.name }}" style="width: {{ section.settings.footer_logo_width }}px; height: auto;">
          </div>
        {%- endif -%}

        <div class="grid grid-cols-1 {{ grid_cols }} gap-12 lg:gap-24 mb-16">
            
            <!-- Newsletter Signup -->
            {%- if section.settings.footer_show_newsletter -%}
            <div class="md:col-span-12 {{ newsletter_span }} flex flex-col gap-6">
                <div>
                    <h3 class="font-semibold tracking-tighter uppercase mb-2" style="font-size: {{ section.settings.newsletter_heading_font_size }}px;">{{ section.settings.newsletter_heading }}</h3>
                    <p style="color: {{ section.settings.footer_text_color }};">{{ section.settings.newsletter_text }}</p>
                </div>
                
                {% form 'customer', id: 'FooterContactForm', class: 'max-w-md w-full omnisend-subscribe-form' %}
                    <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
                    <input type="hidden" name="customer[accepts_marketing]" value="true">
                    
                    {%- if form.posted_successfully? -%}
                        <div class="font-medium uppercase tracking-wide" style="color: {{ section.settings.footer_heading_color }};">
                            Successfully subscribed.
                        </div>
                    {%- else -%}
                        <div id="footer-step-1" class="flex flex-col sm:flex-row gap-4">
                            <input type="email" 
                                   name="contact[email]" 
                                   class="flex-1 bg-transparent border-b px-0 py-3 focus:ring-0 transition-colors omnisend-subscribe-input-email" 
                                   style="border-color: {{ section.settings.footer_border_color }}; color: {{ section.settings.footer_text_color }}; font-size: {{ section.settings.footer_link_font_size }}px;"
                                   placeholder="Email Address"
                                   required>
                            <button type="button" onclick="submitFooterStep1()" class="font-medium uppercase tracking-widest px-8 py-3 transition-colors flex-shrink-0" style="background-color: {{ section.settings.footer_text_color }}; color: {{ section.settings.footer_bg_color }}; font-size: {{ section.settings.footer_link_font_size | minus: 2 }}px;">
                                {{ section.settings.newsletter_button_text }}
                            </button>
                        </div>
                        
                        <div id="footer-step-2" class="flex flex-col gap-4 hidden">
                            <div class="flex flex-col sm:flex-row gap-4">
                                <div class="flex flex-1 items-end gap-2 w-full">
                                    <select id="country-code-footer" class="bg-transparent border-b px-2 py-3 text-sm focus:ring-0 transition-colors w-[90px]" style="border-color: {{ section.settings.footer_border_color }}; color: {{ section.settings.footer_text_color }};">
                                        <option value="+1">US (+1)</option>
                                        <option value="+1">CA (+1)</option>
                                    </select>
                                    <input type="tel" 
                                           name="contact[phone]"
                                           id="local-phone-footer"
                                           class="flex-1 w-full bg-transparent border-b px-0 py-3 text-sm focus:ring-0 transition-colors" 
                                           style="border-color: {{ section.settings.footer_border_color }}; color: {{ section.settings.footer_text_color }}; font-size: {{ section.settings.footer_link_font_size }}px;"
                                           placeholder="Phone Number"
                                           required>
                                </div>
                                <div class="flex items-center gap-2 mt-2">
                                    <button type="button" onclick="submitFooterStep2()" class="w-full font-medium uppercase tracking-widest px-8 py-3 transition-colors" style="background-color: {{ section.settings.footer_text_color }}; color: {{ section.settings.footer_bg_color }}; font-size: {{ section.settings.footer_link_font_size | minus: 2 }}px;">
                                        Subscribe &rarr;
                                    </button>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2 mt-2">
                                <div class="flex items-start gap-2">
                                    <input type="checkbox" id="sms-consent-footer" name="customer[accepts_sms_marketing]" class="mt-1 bg-transparent focus:ring-0 rounded-sm" style="border-color: {{ section.settings.footer_border_color }}; color: {{ section.settings.footer_text_color }};">
                                    <label for="sms-consent-footer" class="cursor-pointer" style="color: {{ section.settings.footer_text_color }}; font-size: {{ section.settings.footer_link_font_size }}px;">Text me too</label>
                                </div>
                                <p class="italic leading-relaxed opacity-75" style="color: {{ section.settings.footer_text_color }}; font-size: {{ section.settings.footer_copyright_font_size }}px;">
                                    Recurring automated marketing texts from PUBLIC EQUITY. Consent not a condition of purchase. Msg & data rates may apply. Reply STOP to cancel, HELP for help. <a href="https://publicequity.shop/policies/terms-of-service" class="underline hover:opacity-100 transition-opacity">Terms</a> · <a href="https://publicequity.shop/policies/privacy-policy" class="underline hover:opacity-100 transition-opacity">Privacy</a>
                                </p>
                            </div>
                        </div>
                        {%- if form.errors -%}
                            <div class="text-error text-xs mt-2">
                                {{ form.errors | default_errors }}
                            </div>
                        {%- endif -%}
                    {%- endif -%}
                {% endform %}
            </div>
            {%- endif -%}

            <!-- Links -->
            <div class="md:col-span-6 {{ links_span }}">
                <h4 class="tracking-widest mb-6" style="color: {{ section.settings.footer_heading_color }}; font-size: {{ section.settings.footer_heading_font_size }}px; font-weight: {{ section.settings.footer_heading_font_weight }};{% if section.settings.footer_heading_uppercase %} text-transform: uppercase;{% endif %}">Information</h4>
                <ul class="flex flex-col gap-4">
                    {%- if section.settings.footer_menu != blank -%}
                        {%- for link in linklists[section.settings.footer_menu].links -%}
                            <li>
                                <a href="{{ link.url }}" class="transition-colors footer-link-hover" style="font-size: {{ section.settings.footer_link_font_size }}px;">{{ link.title }}</a>
                            </li>
                        {%- endfor -%}
                    {%- else -%}
                        <li><a href="#" class="transition-colors footer-link-hover" style="font-size: {{ section.settings.footer_link_font_size }}px;">Shipping & Returns</a></li>
                        <li><a href="#" class="transition-colors footer-link-hover" style="font-size: {{ section.settings.footer_link_font_size }}px;">Terms & Conditions</a></li>
                        <li><a href="#" class="transition-colors footer-link-hover" style="font-size: {{ section.settings.footer_link_font_size }}px;">Privacy Policy</a></li>
                        <li><a href="#" class="transition-colors footer-link-hover" style="font-size: {{ section.settings.footer_link_font_size }}px;">Contact</a></li>
                    {%- endif -%}
                </ul>
            </div>
            
            <!-- Socials -->
            {%- if section.settings.footer_show_social -%}
            <div class="md:col-span-6 {{ social_span }}">
                <h4 class="tracking-widest mb-6" style="color: {{ section.settings.footer_heading_color }}; font-size: {{ section.settings.footer_heading_font_size }}px; font-weight: {{ section.settings.footer_heading_font_weight }};{% if section.settings.footer_heading_uppercase %} text-transform: uppercase;{% endif %}">Social</h4>
                <ul class="flex flex-col" style="gap: {{ section.settings.footer_social_spacing }}px;">
                    <li><a href="#" class="transition-colors footer-social-hover flex items-center gap-2" style="font-size: {{ section.settings.footer_link_font_size }}px;"><span class="material-symbols-outlined" style="font-size: {{ section.settings.footer_social_icon_size }}px;">photo_camera</span> Instagram</a></li>
                    <li><a href="#" class="transition-colors footer-social-hover flex items-center gap-2" style="font-size: {{ section.settings.footer_link_font_size }}px;"><span class="material-symbols-outlined" style="font-size: {{ section.settings.footer_social_icon_size }}px;">play_arrow</span> TikTok</a></li>
                    <li><a href="#" class="transition-colors footer-social-hover flex items-center gap-2" style="font-size: {{ section.settings.footer_link_font_size }}px;"><span class="material-symbols-outlined" style="font-size: {{ section.settings.footer_social_icon_size }}px;">chat</span> Twitter</a></li>
                </ul>
            </div>
            {%- endif -%}
        </div>

        <!-- Copyright -->
        <div class="border-t pt-8 flex flex-col md:flex-row justify-between items-center gap-4 uppercase tracking-widest" style="border-color: {{ section.settings.footer_border_color }}; font-size: {{ section.settings.footer_copyright_font_size }}px; color: {{ section.settings.footer_heading_color }};">
            <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.</p>
            
            <div class="flex flex-col md:flex-row gap-4 items-center">
              {%- if section.settings.footer_show_payment_icons -%}
                <div class="flex gap-2">
                  {%- for type in shop.enabled_payment_types -%}
                    {{ type | payment_type_svg_tag: class: 'h-6' }}
                  {%- endfor -%}
                </div>
              {%- endif -%}
              <span>Powered by Shopify</span>
            </div>
        </div>
    </div>
</footer>

<script>
var FOOTER_KLAVIYO_CONFIG = {
    publicKey: {{ section.settings.klaviyo_public_key | json }},
    emailListId: {{ section.settings.klaviyo_email_list_id | json }},
    smsListId: {{ section.settings.klaviyo_sms_list_id | json }}
};

function getKlaviyoCompanyIdFooter() {
    if (FOOTER_KLAVIYO_CONFIG.publicKey) return FOOTER_KLAVIYO_CONFIG.publicKey;
    var scripts = document.querySelectorAll('script[src*="klaviyo"]');
    for (var i = 0; i < scripts.length; i++) {
        var match = scripts[i].src.match(/company_id=([^&]+)/);
        if (match) return decodeURIComponent(match[1]);
    }
    return null;
}

function buildKlaviyoSubscriptionPayloadFooter(email, phone, channel) {
    var attributes = { email: email, subscriptions: {} };
    if (channel === 'email') attributes.subscriptions.email = { marketing: { consent: 'SUBSCRIBED' } };
    if (channel === 'sms' && phone) {
        attributes.phone_number = phone;
        attributes.subscriptions.sms = { marketing: { consent: 'SUBSCRIBED' } };
    }
    var payload = { data: { type: 'subscription', attributes: { custom_source: 'Luxury Footer Signup', profile: { data: { type: 'profile', attributes: attributes } } } } };
    var listId = channel === 'sms' ? FOOTER_KLAVIYO_CONFIG.smsListId : FOOTER_KLAVIYO_CONFIG.emailListId;
    if (listId) payload.data.relationships = { list: { data: { type: 'list', id: listId } } };
    return payload;
}

async function subscribeViaKlaviyoFooter(email, phone, smsConsent) {
    var companyId = getKlaviyoCompanyIdFooter();
    if (!companyId) return false;
    var headers = { 'Content-Type': 'application/json', Accept: 'application/json', Revision: '2026-04-15' };
    var emailRes = await fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + encodeURIComponent(companyId), { method: 'POST', headers: headers, body: JSON.stringify(buildKlaviyoSubscriptionPayloadFooter(email, null, 'email')) });
    if (!emailRes.ok) return false;
    if (smsConsent && phone) {
        var smsRes = await fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + encodeURIComponent(companyId), { method: 'POST', headers: headers, body: JSON.stringify(buildKlaviyoSubscriptionPayloadFooter(email, phone, 'sms')) });
        if (!smsRes.ok) return false;
    }
    if (window.klaviyo && typeof window.klaviyo.identify === 'function') window.klaviyo.identify({ email: email, phone_number: phone || undefined });
    return true;
}

function submitFooterStep1() {
    var form = document.getElementById('FooterContactForm');
    var emailInput = form.querySelector('input[name="contact[email]"]');
    if (!emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
    }
    
    var formData = new FormData(form);
    fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    
    document.getElementById('footer-step-1').classList.add('hidden');
    document.getElementById('footer-step-2').classList.remove('hidden');
}



async function submitFooterStep2() {
    var form = document.getElementById('FooterContactForm');
    var phoneInput = document.getElementById('local-phone-footer');
    var smsConsent = document.getElementById('sms-consent-footer').checked;
    
    if (!phoneInput.checkValidity()) {
        phoneInput.reportValidity();
        return;
    }
    
    var emailInput = form.querySelector('input[name="contact[email]"]');
    var cc = document.getElementById('country-code-footer').value;
    var e164Phone = cc + phoneInput.value.replace(/\D/g, '');
    
    if (typeof window.omnisend !== 'undefined') {
        window.omnisend.push(["identifyContact", { 
            email: emailInput.value,
            phone: e164Phone
        }]);
    }
    
    await subscribeViaKlaviyoFooter(emailInput.value, e164Phone, smsConsent);
    
    try {
        await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
    } catch(e) {}
    
    document.getElementById('footer-step-2').innerHTML = '<div class="text-sm font-medium uppercase tracking-wide mt-4">Thank you. Check your inbox.</div>';
}
</script>
