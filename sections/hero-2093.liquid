{% schema %}
{
  "name": "Hero 2093",
  "tag": "section",
  "class": "section-hero-2093",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "DISTRIBUTION_NODE_01"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "REDEFINING THE PARAMETERS OF HUMAN INTERFACE IN THE POST-SYSTEM ERA. PROTOCOL ACTIVE."
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 Text",
      "default": "INITIALIZE"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 Text",
      "default": "OVERRIDE"
    }
  ],
  "presets": [
    {
      "name": "Hero 2093"
    }
  ]
}
{% endschema %}

<section class="relative h-screen w-full flex flex-col justify-center items-center overflow-hidden scanline">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-black/60 z-10"></div>
    {% if section.settings.background_image != blank %}
      <div class="w-full h-full bg-cover bg-center" style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}')"></div>
    {% else %}
      <div class="w-full h-full bg-surface-container-low"></div>
    {% endif %}
  </div>
  <div class="relative z-20 text-center px-margin-mobile lg:px-margin-desktop">
    <h1 class="font-headline-xl text-primary leading-none uppercase mb-8 glitch-hover tracking-tighter">
      {{ section.settings.title }}
    </h1>
    <p class="font-body-lg text-secondary max-w-2xl mx-auto mb-12 tracking-wide">
      {{ section.settings.subtitle }}
    </p>
    <div class="flex justify-center gap-gutter">
      {% if section.settings.button_1_text != blank %}
        <button class="px-12 py-5 industrial-border bg-transparent text-primary font-utility-label uppercase tracking-widest hero-btn-initialize transition-all neon-glow">
          {{ section.settings.button_1_text }}
        </button>
      {% endif %}
      {% if section.settings.button_2_text != blank %}
        <button class="px-12 py-5 industrial-border bg-white text-black font-utility-label uppercase tracking-widest hero-btn-override transition-all">
          {{ section.settings.button_2_text }}
        </button>
      {% endif %}
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce flex flex-col items-center">
    <span class="font-utility-label text-secondary mb-2">SCROLL_TO_INIT</span>
    <span class="material-symbols-outlined text-primary">keyboard_double_arrow_down</span>
  </div>
</section>

<style>
  .animate-bounce {
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, -10px); }
  }
  .section-hero-2093 .h-screen { height: 100vh; }
  .section-hero-2093 .w-full { width: 100%; }
  .section-hero-2093 .flex { display: flex; }
  .section-hero-2093 .flex-col { flex-direction: column; }
  .section-hero-2093 .justify-center { justify-content: center; }
  .section-hero-2093 .items-center { align-items: center; }
  .section-hero-2093 .overflow-hidden { overflow: hidden; }
  .section-hero-2093 .absolute { position: absolute; }
  .section-hero-2093 .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
  .section-hero-2093 .z-0 { z-index: 0; }
  .section-hero-2093 .z-10 { z-index: 10; }
  .section-hero-2093 .z-20 { z-index: 20; }
  .bg-black\/60 { background-color: rgba(0,0,0,0.6); }
  .bg-cover { background-size: cover; }
  .bg-center { background-position: center; }
  .bg-transparent { background-color: transparent; }
  .relative { position: relative; }
  .text-center { text-align: center; }
  .leading-none { line-height: 1; }
  .uppercase { text-transform: uppercase; }
  .mb-8 { margin-bottom: 32px; }
  .mb-12 { margin-bottom: 48px; }
  .mb-2 { margin-bottom: 8px; }
  .tracking-tighter { letter-spacing: -0.05em; }
  .tracking-wide { letter-spacing: 0.025em; }
  .tracking-widest { letter-spacing: 0.1em; }
  .max-w-2xl { max-width: 42rem; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .gap-gutter { gap: var(--spacing-gutter); }
  .px-12 { padding-left: 48px; padding-right: 48px; }
  .py-5 { padding-top: 20px; padding-bottom: 20px; }
  .transition-all { transition-property: all; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 300ms; }
  .bottom-10 { bottom: 40px; }
  .left-1\/2 { left: 50%; }
  .-translate-x-1\/2 { transform: translateX(-50%); }
  
  .hero-btn-initialize:hover { background-color: var(--color-primary-fixed-dim); color: #000; }
  .hero-btn-override:hover { background-color: transparent; color: #fff; }
</style>
