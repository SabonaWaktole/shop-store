{% schema %}
{
  "name": "Artifacts 2093",
  "tag": "section",
  "class": "section-artifacts-2093",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "TECH_ARTIFACTS_01"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Artifacts 2093"
    }
  ]
}
{% endschema %}

<section class="py-section-gap px-margin-mobile lg:px-margin-desktop bg-surface-container-lowest">
  <h3 class="font-headline-lg text-white uppercase mb-16 border-b border-outline-variant pb-8">{{ section.settings.title }}</h3>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
    
    {% assign collection = collections[section.settings.collection] %}
    {% if collection != blank %}
      {% for product in collection.products limit: 3 %}
        <div class="reveal-on-scroll industrial-border group hover-border-primary transition-all duration-300 p-2" style="transition-delay: {{ forloop.index0 | times: 100 }}ms;">
          <a href="{{ product.url }}" class="block">
            <div class="relative h-96 overflow-hidden bg-black mb-6">
              {% if product.featured_image != blank %}
                <img class="w-full h-full object-cover grayscale group-hover-grayscale-0 transition-all duration-700 group-hover-scale-110" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover grayscale group-hover-grayscale-0 transition-all duration-700 group-hover-scale-110' }}
              {% endif %}
              <div class="absolute top-4 right-4 bg-primary text-black px-2 py-1 font-utility-label">LTD_EDITION</div>
            </div>
            <div class="p-4">
              <h4 class="font-headline-lg-mobile text-white uppercase mb-2">{{ product.title }}</h4>
              <p class="font-utility-label text-on-surface-variant mb-6 uppercase">{{ product.type | default: 'HARDWARE / INTERFACE' }}</p>
              <div class="flex justify-between items-center">
                <span class="font-body-lg text-primary">{{ product.price | money }}</span>
                <button class="p-3 industrial-border hover-bg-white hover-text-black transition-colors" tabindex="-1">
                  <span class="material-symbols-outlined">add_shopping_cart</span>
                </button>
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    {% else %}
      <!-- Placeholders if no collection selected -->
      {% for i in (1..3) %}
        <div class="reveal-on-scroll industrial-border group hover-border-primary transition-all duration-300 p-2" style="transition-delay: {{ forloop.index0 | times: 100 }}ms;">
          <div class="relative h-96 overflow-hidden bg-black mb-6">
            {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full object-cover grayscale group-hover-grayscale-0 transition-all duration-700 group-hover-scale-110' }}
            <div class="absolute top-4 right-4 bg-primary text-black px-2 py-1 font-utility-label">LTD_EDITION</div>
          </div>
          <div class="p-4">
            <h4 class="font-headline-lg-mobile text-white uppercase mb-2">NEURAL_LINK_V{{ i }}</h4>
            <p class="font-utility-label text-on-surface-variant mb-6 uppercase">HARDWARE / INTERFACE</p>
            <div class="flex justify-between items-center">
              <span class="font-body-lg text-primary">0.45 ETH</span>
              <button class="p-3 industrial-border hover-bg-white hover-text-black transition-colors">
                <span class="material-symbols-outlined">add_shopping_cart</span>
              </button>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
    
  </div>
</section>

<style>
  .h-96 { height: 24rem; }
  .mb-16 { margin-bottom: 4rem; }
  .mb-6 { margin-bottom: 1.5rem; }
  .pb-8 { padding-bottom: 2rem; }
  .border-b { border-bottom-width: 1px; border-bottom-style: solid; }
  .p-2 { padding: 0.5rem; }
  .p-4 { padding: 1rem; }
  .p-3 { padding: 0.75rem; }
  .top-4 { top: 1rem; }
  .right-4 { right: 1rem; }
  .px-2 { padding-left: 0.5rem; padding-right: 0.5rem; }
  .py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
  .grayscale { filter: grayscale(100%); }
  
  .group:hover .hover-border-primary { border-color: var(--color-primary); }
  .group:hover .group-hover-grayscale-0 { filter: grayscale(0%); }
  .group:hover .group-hover-scale-110 { transform: scale(1.1); }
  
  .hover-bg-white:hover { background-color: #fff; }
  .hover-text-black:hover { color: #000; }
  .transition-colors { transition-property: color, background-color, border-color; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 300ms; }
  .duration-300 { transition-duration: 300ms; }
  .duration-700 { transition-duration: 700ms; }
  .block { display: block; }
  .justify-between { justify-content: space-between; }
  
  @media (min-width: 768px) {
    .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
</style>
