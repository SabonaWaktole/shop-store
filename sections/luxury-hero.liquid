{% schema %}
{
  "name": "Luxury Hero & Capture",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DROP 01: BEGINNINGS"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Sign up for exclusive access before the global release."
    }
  ],
  "presets": [
    {
      "name": "Luxury Hero"
    }
  ]
}
{% endschema %}

<section class="relative w-full min-h-[85vh] flex items-center justify-center overflow-hidden bg-muted">
    <!-- Background Image -->
    <div class="absolute inset-0 w-full h-full">
        {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.heading | escape }}" class="w-full h-full object-cover">
        {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
        {%- endif -%}
        <!-- Subtle dark gradient overlay to ensure text legibility if needed, or keep stark -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>

    <!-- Content / Email Capture Card -->
    <div class="relative z-10 w-full max-w-md mx-4 mt-auto mb-16 md:mb-24 bg-background p-8 shadow-2xl animate-fade-in-up">
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tighter uppercase mb-3">{{ section.settings.heading }}</h2>
        <p class="text-sm text-muted-foreground mb-8 leading-relaxed">{{ section.settings.text }}</p>

        {% form 'customer', id: 'HeroContactForm' %}
            <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
            
            {%- if form.posted_successfully? -%}
                <div class="p-4 bg-muted text-primary text-sm font-medium text-center uppercase tracking-wide">
                    Thank you. Check your inbox.
                </div>
            {%- else -%}
                {%- if form.errors -%}
                    <div class="p-4 border border-error text-error text-sm mb-4">
                        {{ form.errors | default_errors }}
                    </div>
                {%- endif -%}

                <div class="flex flex-col gap-4">
                    <input type="email" 
                           name="contact[email]" 
                           class="w-full bg-background border-b border-border px-0 py-3 text-sm focus:border-primary focus:ring-0 transition-colors placeholder:text-muted-foreground" 
                           placeholder="Email Address"
                           required>
                           
                    <button type="submit" class="w-full bg-primary text-primary-foreground font-medium text-sm tracking-widest uppercase py-4 hover:bg-primary/90 transition-colors flex items-center justify-center gap-2 group">
                        <span>Subscribe</span>
                        <span class="material-symbols-outlined text-sm font-light transform group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </button>
                </div>
            {%- endif -%}
        {% endform %}
    </div>
</section>
