{% schema %}
{
  "name": "Luxury Hero & Capture",
  "settings": [
    {
      "type": "header",
      "content": "Hero Mode"
    },
    {
      "type": "select",
      "id": "hero_mode",
      "options": [
        { "value": "single", "label": "Single Image" },
        { "value": "gallery", "label": "Multi-Image Gallery" }
      ],
      "default": "single",
      "label": "Hero Mode",
      "info": "Single uses one background image. Gallery displays multiple images in a layout you choose."
    },
    {
      "type": "header",
      "content": "── Single Image ──"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Hero Image"
    },
    {
      "type": "header",
      "content": "── Multi-Image Gallery ──"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        { "value": "horizontal", "label": "Horizontal (Side by Side)" },
        { "value": "vertical", "label": "Vertical (Stacked)" },
        { "value": "grid-2x2", "label": "Grid (2×2)" },
        { "value": "featured-left", "label": "Featured Left + Stack Right" },
        { "value": "featured-right", "label": "Featured Right + Stack Left" }
      ],
      "default": "horizontal",
      "label": "Gallery Layout",
      "info": "How the images are arranged."
    },
    {
      "type": "range",
      "id": "gallery_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8,
      "label": "Gap Between Images"
    },
    {
      "type": "select",
      "id": "gallery_image_fit",
      "options": [
        { "value": "cover", "label": "Cover (Fill & Crop)" },
        { "value": "contain", "label": "Contain (Fit Whole Image)" }
      ],
      "default": "cover",
      "label": "Image Fit Mode"
    },
    {
      "type": "image_picker",
      "id": "gallery_image_1",
      "label": "Gallery Image 1"
    },
    {
      "type": "image_picker",
      "id": "gallery_image_2",
      "label": "Gallery Image 2"
    },
    {
      "type": "image_picker",
      "id": "gallery_image_3",
      "label": "Gallery Image 3"
    },
    {
      "type": "image_picker",
      "id": "gallery_image_4",
      "label": "Gallery Image 4"
    },
    {
      "type": "select",
      "id": "gallery_mobile_layout",
      "options": [
        { "value": "keep", "label": "Keep Desktop Layout" },
        { "value": "vertical", "label": "Stack Vertically" },
        { "value": "horizontal-scroll", "label": "Horizontal Scroll" }
      ],
      "default": "vertical",
      "label": "Mobile Layout",
      "info": "How gallery images display on mobile."
    },
    {
      "type": "header",
      "content": "── Layout ──"
    },
    {
      "type": "select",
      "id": "hero_height",
      "options": [
        { "value": "60vh", "label": "Small" },
        { "value": "75vh", "label": "Medium" },
        { "value": "85vh", "label": "Large" },
        { "value": "100vh", "label": "Full" }
      ],
      "default": "85vh",
      "label": "Hero Height"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Text Alignment"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        { "value": "start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Bottom" }
      ],
      "default": "end",
      "label": "Content Position"
    },
    {
      "type": "select",
      "id": "content_width",
      "options": [
        { "value": "max-w-sm", "label": "Narrow" },
        { "value": "max-w-md", "label": "Medium" },
        { "value": "max-w-lg", "label": "Wide" }
      ],
      "default": "max-w-md",
      "label": "Content Width"
    },
    {
      "type": "header",
      "content": "── Overlay ──"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Overlay Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40,
      "label": "Overlay Opacity"
    },
    {
      "type": "checkbox",
      "id": "overlay_gradient",
      "default": true,
      "label": "Use Gradient Overlay"
    },
    {
      "type": "header",
      "content": "── Typography ──"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DROP 01: BEGINNINGS"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36,
      "label": "Heading Size (Desktop)"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 30,
      "label": "Heading Size (Mobile)"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" }
      ],
      "default": "600",
      "label": "Heading Font Weight"
    },
    {
      "type": "checkbox",
      "id": "heading_uppercase",
      "default": true,
      "label": "Uppercase Heading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "default": "#000000",
      "label": "Heading Color"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Sign up for exclusive access before the global release."
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14,
      "label": "Subtext Font Size"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "default": "#6B7280",
      "label": "Subtext Color"
    },
    {
      "type": "header",
      "content": "── CTA Button ──"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "Subscribe",
      "label": "CTA Button Text"
    },
    {
      "type": "select",
      "id": "cta_style",
      "options": [
        { "value": "filled", "label": "Filled" },
        { "value": "outlined", "label": "Outlined" },
        { "value": "minimal", "label": "Minimal" }
      ],
      "default": "filled",
      "label": "CTA Style"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "default": "#000000",
      "label": "CTA Background"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "default": "#FFFFFF",
      "label": "CTA Text Color"
    },
    {
      "type": "range",
      "id": "cta_font_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14,
      "label": "CTA Font Size"
    },
    {
      "type": "range",
      "id": "cta_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "label": "CTA Border Radius"
    },
    {
      "type": "header",
      "content": "── Card ──"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "default": "#FFFFFF",
      "label": "Card Background"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32,
      "label": "Card Padding"
    },
    {
      "type": "checkbox",
      "id": "card_shadow",
      "default": true,
      "label": "Show Card Shadow"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0,
      "label": "Card Border Radius"
    }
  ],
  "presets": [
    {
      "name": "Luxury Hero"
    }
  ]
}
{% endschema %}

{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

{%- comment -%} Count gallery images {%- endcomment -%}
{%- liquid
  assign gallery_count = 0
  if section.settings.gallery_image_1 != blank
    assign gallery_count = gallery_count | plus: 1
  endif
  if section.settings.gallery_image_2 != blank
    assign gallery_count = gallery_count | plus: 1
  endif
  if section.settings.gallery_image_3 != blank
    assign gallery_count = gallery_count | plus: 1
  endif
  if section.settings.gallery_image_4 != blank
    assign gallery_count = gallery_count | plus: 1
  endif
-%}

<style>
  /* ── Heading responsive sizes ── */
  #Hero-{{ section.id }} .hero-heading {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
  }
  @media (min-width: 768px) {
    #Hero-{{ section.id }} .hero-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  /* ── Gallery styles ── */
  .hero-gallery-{{ section.id }} {
    display: flex;
    width: 100%;
    height: 100%;
    gap: {{ section.settings.gallery_gap }}px;
  }

  /* Horizontal layout */
  .hero-gallery-{{ section.id }}.gallery-horizontal {
    flex-direction: row;
  }
  .hero-gallery-{{ section.id }}.gallery-horizontal .hero-gallery-item {
    flex: 1;
    min-width: 0;
  }

  /* Vertical layout */
  .hero-gallery-{{ section.id }}.gallery-vertical {
    flex-direction: column;
  }
  .hero-gallery-{{ section.id }}.gallery-vertical .hero-gallery-item {
    flex: 1;
    min-height: 0;
  }

  /* Grid 2x2 layout */
  .hero-gallery-{{ section.id }}.gallery-grid-2x2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  /* Featured left layout */
  .hero-gallery-{{ section.id }}.gallery-featured-left {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
  }
  .hero-gallery-{{ section.id }}.gallery-featured-left .hero-gallery-item:first-child {
    grid-row: 1 / -1;
  }

  /* Featured right layout */
  .hero-gallery-{{ section.id }}.gallery-featured-right {
    display: grid;
    grid-template-columns: 1fr 2fr;
    grid-template-rows: 1fr 1fr 1fr;
  }
  .hero-gallery-{{ section.id }}.gallery-featured-right .hero-gallery-item:last-child {
    grid-row: 1 / -1;
    grid-column: 2;
  }
  .hero-gallery-{{ section.id }}.gallery-featured-right .hero-gallery-item:not(:last-child) {
    grid-column: 1;
  }

  /* Gallery image styling */
  .hero-gallery-item {
    position: relative;
    overflow: hidden;
  }
  .hero-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.gallery_image_fit }};
    transition: transform 0.6s ease;
  }
  .hero-gallery-item:hover img {
    transform: scale(1.03);
  }

  /* ── Mobile gallery behavior ── */
  @media (max-width: 767px) {
    {%- if section.settings.gallery_mobile_layout == 'vertical' -%}
      .hero-gallery-{{ section.id }}.gallery-horizontal,
      .hero-gallery-{{ section.id }}.gallery-grid-2x2,
      .hero-gallery-{{ section.id }}.gallery-featured-left,
      .hero-gallery-{{ section.id }}.gallery-featured-right {
        display: flex !important;
        flex-direction: column !important;
        grid-template-columns: unset !important;
        grid-template-rows: unset !important;
      }
      .hero-gallery-{{ section.id }} .hero-gallery-item {
        grid-row: unset !important;
        grid-column: unset !important;
        flex: none !important;
        min-height: 200px;
      }
    {%- elsif section.settings.gallery_mobile_layout == 'horizontal-scroll' -%}
      .hero-gallery-{{ section.id }} {
        flex-direction: row !important;
        display: flex !important;
        overflow-x: auto !important;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        grid-template-columns: unset !important;
        grid-template-rows: unset !important;
      }
      .hero-gallery-{{ section.id }} .hero-gallery-item {
        flex: 0 0 85% !important;
        scroll-snap-align: center;
        min-height: 300px;
        grid-row: unset !important;
        grid-column: unset !important;
      }
      .hero-gallery-{{ section.id }}::-webkit-scrollbar {
        display: none;
      }
    {%- endif -%}
  }
</style>

<div class="relative w-full">
  <!-- Solid white block extending upwards to sit directly behind the transparent header -->
  <div class="absolute top-[-100px] left-0 w-full h-[100px] bg-white" data-header-theme="light"></div>

  <section id="Hero-{{ section.id }}" class="relative w-full flex justify-center overflow-hidden" style="min-height: {{ section.settings.hero_height }}; align-items: {{ section.settings.content_position }};">
    
    <!-- Background: Single Image or Gallery -->
    {%- if section.settings.hero_mode == 'gallery' and gallery_count > 0 -%}

      <!-- Multi-Image Gallery Background -->
      <div class="absolute inset-0 w-full h-full">
        <div class="hero-gallery-{{ section.id }} gallery-{{ section.settings.gallery_layout }}">
          {%- if section.settings.gallery_image_1 != blank -%}
            <div class="hero-gallery-item">
              <img src="{{ section.settings.gallery_image_1 | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" loading="eager">
            </div>
          {%- endif -%}
          {%- if section.settings.gallery_image_2 != blank -%}
            <div class="hero-gallery-item">
              <img src="{{ section.settings.gallery_image_2 | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" loading="eager">
            </div>
          {%- endif -%}
          {%- if section.settings.gallery_image_3 != blank -%}
            <div class="hero-gallery-item">
              <img src="{{ section.settings.gallery_image_3 | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
            </div>
          {%- endif -%}
          {%- if section.settings.gallery_image_4 != blank -%}
            <div class="hero-gallery-item">
              <img src="{{ section.settings.gallery_image_4 | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
            </div>
          {%- endif -%}
        </div>

        <!-- Overlay (same as single mode) -->
        {%- if section.settings.overlay_gradient -%}
          <div class="absolute inset-0 bg-gradient-to-t from-transparent" style="--tw-gradient-to: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_opacity }};"></div>
          <div class="absolute inset-0 bg-gradient-to-b from-transparent" style="--tw-gradient-to: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_opacity }};"></div>
        {%- else -%}
          <div class="absolute inset-0" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ overlay_opacity }};"></div>
        {%- endif -%}
      </div>

    {%- else -%}

      <!-- Single Image Background (original) -->
      <div class="absolute inset-0 w-full h-full">
        {%- if section.settings.image != blank -%}
          <picture>
            {%- if section.settings.mobile_image != blank -%}
              <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 800 }}">
            {%- endif -%}
            <img src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.heading | escape }}" class="w-full h-full object-cover">
          </picture>
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
        {%- endif -%}
        
        <!-- Overlay -->
        {%- if section.settings.overlay_gradient -%}
          <div class="absolute inset-0 bg-gradient-to-t from-transparent" style="--tw-gradient-to: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_opacity }};"></div>
          <div class="absolute inset-0 bg-gradient-to-b from-transparent" style="--tw-gradient-to: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_opacity }};"></div>
        {%- else -%}
          <div class="absolute inset-0" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ overlay_opacity }};"></div>
        {%- endif -%}
      </div>

    {%- endif -%}

    <!-- Content / Email Capture Card -->
    <div id="hero-signup-card" class="relative z-10 w-full {{ section.settings.content_width }} mx-4 mt-24 mb-16 md:mb-24 animate-fade-in-up" 
         style="background-color: {{ section.settings.card_bg_color }}; padding: {{ section.settings.card_padding }}px; border-radius: {{ section.settings.card_border_radius }}px; text-align: {{ section.settings.text_alignment }};{% if section.settings.card_shadow %} box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);{% endif %}">
        
        <h2 class="hero-heading tracking-tighter mb-3" style="font-weight: {{ section.settings.heading_font_weight }}; color: {{ section.settings.heading_color }};{% if section.settings.heading_uppercase %} text-transform: uppercase;{% endif %}">{{ section.settings.heading }}</h2>
        <p class="mb-8 leading-relaxed" style="font-size: {{ section.settings.subtext_font_size }}px; color: {{ section.settings.subtext_color }};">{{ section.settings.text }}</p>

        {% form 'customer', id: 'HeroContactForm' %}
            <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
            
            {%- if form.posted_successfully? -%}
                <div class="p-4 bg-muted text-primary text-sm font-medium text-center uppercase tracking-wide" style="background-color: {{ section.settings.card_bg_color | color_darken: 5 }};">
                    Thank you. Check your inbox.
                </div>
                <script>
                    localStorage.setItem('user_subscribed', 'true');
                </script>
            {%- else -%}
                {%- if form.errors -%}
                    <div class="p-4 border border-error text-error text-sm mb-4">
                        {{ form.errors | default_errors }}
                    </div>
                {%- endif -%}

                <div class="flex flex-col gap-4">
                    <input type="email" 
                           name="contact[email]" 
                           class="w-full bg-transparent border-b px-0 py-3 text-sm focus:ring-0 transition-colors" 
                           style="border-color: {{ section.settings.subtext_color }}; color: {{ section.settings.heading_color }};"
                           placeholder="Email Address"
                           required>
                           
                    {%- assign button_border = 'none' -%}
                    {%- assign button_bg = section.settings.cta_bg_color -%}
                    {%- assign button_text = section.settings.cta_text_color -%}
                    
                    {%- if section.settings.cta_style == 'outlined' -%}
                        {%- assign button_border = '1px solid ' | append: section.settings.cta_bg_color -%}
                        {%- assign button_bg = 'transparent' -%}
                        {%- assign button_text = section.settings.cta_bg_color -%}
                    {%- elsif section.settings.cta_style == 'minimal' -%}
                        {%- assign button_border = 'none' -%}
                        {%- assign button_bg = 'transparent' -%}
                        {%- assign button_text = section.settings.cta_bg_color -%}
                    {%- endif -%}
                           
                    <button type="submit" class="w-full font-medium tracking-widest uppercase py-4 transition-colors flex items-center justify-center gap-2 group hover:opacity-90"
                            style="background-color: {{ button_bg }}; color: {{ button_text }}; border: {{ button_border }}; font-size: {{ section.settings.cta_font_size }}px; border-radius: {{ section.settings.cta_border_radius }}px;">
                        <span>{{ section.settings.cta_text }}</span>
                        <span class="material-symbols-outlined text-sm font-light transform group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </button>
                </div>
            {%- endif -%}
        {% endform %}
    </div>

    <!-- Subscriber Detection Script -->
    <script>
        (function() {
            var isCustomer = {% if customer %}true{% else %}false{% endif %};
            var hasSubscribed = localStorage.getItem('user_subscribed') === 'true';
            
            if (isCustomer || hasSubscribed) {
                var card = document.getElementById('hero-signup-card');
                if (card) {
                    card.style.display = 'none';
                }
            }
        })();
    </script>
  </section>
</div>
