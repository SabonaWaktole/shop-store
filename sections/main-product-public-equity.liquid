{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  
  assign is_preorder = false
  if settings.enable_preorder and product.tags contains 'preorder'
    assign is_preorder = true
  endif

  assign is_waitlist = false
  if settings.enable_waitlist_mode and product.tags contains 'waitlist'
    assign is_waitlist = true
  endif
  
  assign has_drop = false
  if product.tags contains 'drop' and settings.global_drop_date != blank
      assign has_drop = true
  endif
-%}

<div class="w-full min-h-screen flex flex-col md:flex-row border-b border-outline-variant relative bg-background" data-section-id="{{ section.id }}" data-section-type="product">
    
    <!-- Left Gallery Column -->
    <div class="w-full {% if section.settings.gallery_layout == 'thumbnails-left' %}flex flex-row-reverse{% endif %} md:w-7/12 lg:w-8/12 bg-outline-variant border-r border-outline-variant">
        
        <div class="w-full flex flex-col gap-gutter">
            {%- if product.media.size > 0 -%}
                {%- for media in product.media -%}
                    <div class="relative w-full {% if section.settings.gallery_layout == 'stacked' %}aspect-[3/4] md:aspect-auto md:h-[1228px]{% else %}aspect-[3/4]{% endif %} bg-surface group overflow-hidden">
                        <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-1000">
                            <div class="w-full h-px bg-primary/50 shadow-[0_0_8px_rgba(255,255,255,0.8)] absolute top-0 left-0 animate-scanner"></div>
                        </div>
                        <img src="{{ media | image_url: width: 1400 }}" alt="{{ media.alt | escape }}" class="w-full h-full object-cover object-center grayscale hover:grayscale-0 transition-all duration-700 ease-in-out {% if section.settings.enable_zoom %}cursor-zoom-in{% endif %}" loading="lazy">
                    </div>
                {%- endfor -%}
            {%- else -%}
                <div class="relative w-full aspect-[3/4] md:aspect-auto md:h-[1228px] bg-surface group overflow-hidden">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBaq04CKS6YJHm-62lWm7DQIidw3cuO1c3drK38DfNoYCei4j1X97W2aN8NUs11twz8LV7trFWA-BAcZ83DWJXm3On20h7_FEFC7tK-6ALFR6MlH8UdCXbwaRnOOmmq1cd-sSgFDgFi8xHk8rA9UuZtMtseSvnWYypdtX4ufqxbiGyB37yZiFaIYNORmvolWwyNMn_BhOe7_mj511oBKHD2qI4DQRaWkqgwI75rDyDh2s4cKd3PbZrGy6XtklS5n3YEo_ol9F-XneNp" alt="Placeholder" class="w-full h-full object-cover object-center grayscale hover:grayscale-0 transition-all duration-700 ease-in-out">
                </div>
            {%- endif -%}
        </div>

        {%- if section.settings.gallery_layout contains 'thumbnails' -%}
            <!-- Thumbnail Strip -->
            <div class="{% if section.settings.gallery_layout == 'thumbnails-left' %}w-24 shrink-0 flex flex-col gap-2 p-2{% else %}w-full flex gap-2 p-2 overflow-x-auto{% endif %}">
                {%- for media in product.media -%}
                    <button class="w-20 h-24 border border-outline-variant hover:border-primary shrink-0 transition-colors">
                        <img src="{{ media | image_url: width: 200 }}" class="w-full h-full object-cover grayscale" loading="lazy">
                    </button>
                {%- endfor -%}
            </div>
        {%- endif -%}
    </div>

    <!-- Right Info Column (Sticky) -->
    <div class="w-full md:w-5/12 lg:w-4/12 bg-background relative z-10">
        <div class="sticky top-0 md:h-screen overflow-y-auto hide-scrollbar p-margin-mobile md:p-margin-desktop pt-24 pb-32 flex flex-col">
            
            {% form 'product', product, id: 'product-form', class: 'flex flex-col' %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">

                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'title' -%}
                            <h1 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg uppercase text-primary leading-none tracking-tight mb-4" {{ block.shopify_attributes }}>
                                {{ product.title | default: 'OBSIDIAN SHELL' }}
                            </h1>
                        
                        {%- when 'price' -%}
                            <div class="flex items-center gap-6 mb-8" {{ block.shopify_attributes }}>
                                <p class="font-label-mono text-label-mono text-on-surface-variant uppercase tracking-widest">
                                    {{ current_variant.price | money_with_currency | default: '$240.00 USD' }}
                                </p>
                                {%- if current_variant.compare_at_price > current_variant.price -%}
                                    <p class="font-label-mono text-label-mono text-on-surface-variant uppercase tracking-widest line-through">
                                        {{ current_variant.compare_at_price | money }}
                                    </p>
                                {%- endif -%}
                                {%- if block.settings.show_inventory -%}
                                    <span class="font-label-mono text-label-mono uppercase tracking-widest {% if current_variant.available %}text-primary{% else %}text-error{% endif %}">
                                        {% if current_variant.available %}
                                            [ IN STOCK ]
                                        {% else %}
                                            [ SOLD OUT ]
                                        {% endif %}
                                    </span>
                                {%- endif -%}
                            </div>

                        {%- when 'description' -%}
                            {%- if product.description != blank -%}
                                <div class="font-body-main text-body-main text-on-surface-variant mb-8 prose prose-invert" {{ block.shopify_attributes }}>
                                    {{ product.description }}
                                </div>
                            {%- endif -%}
                            <div class="w-full h-px bg-outline-variant mb-12"></div>

                        {%- when 'variant_selector' -%}
                            {%- unless product.has_only_default_variant -%}
                                <div class="mb-12" {{ block.shopify_attributes }}>
                                    {%- for option in product.options_with_values -%}
                                        <div class="mb-8 last:mb-0">
                                            <div class="flex justify-between items-center mb-4">
                                                <span class="font-label-mono text-label-mono text-on-surface-variant uppercase">{{ option.name }}</span>
                                                {% if section.settings.enable_size_guide and option.name == 'Size' or option.name == 'SIZE' %}
                                                    <button type="button" class="font-label-mono text-label-mono text-on-surface-variant uppercase border-b border-on-surface-variant hover:text-primary hover:border-primary transition-colors pb-0.5">GUIDE</button>
                                                {% else %}
                                                    <span class="font-label-mono text-label-mono text-primary uppercase" id="{{ option.name }}-display">{{ option.selected_value }}</span>
                                                {% endif %}
                                            </div>
                                            <div class="flex flex-wrap gap-2">
                                                {%- for value in option.values -%}
                                                    <label class="cursor-pointer">
                                                        <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="hidden peer" {% if option.selected_value == value %}checked{% endif %}>
                                                        {%- if settings.enable_color_swatches and option.name == 'Color' or option.name == 'Colour' -%}
                                                            <!-- Color Swatch -->
                                                            <div class="w-12 h-12 border border-outline-variant peer-checked:border-primary peer-checked:border-2 bg-[{{ value | downcase | replace: ' ', '' }}] transition-all"></div>
                                                        {%- else -%}
                                                            <!-- Pill/Button -->
                                                            <div class="border border-outline-variant px-6 py-3 font-label-mono text-label-mono uppercase peer-checked:bg-primary peer-checked:text-surface peer-checked:border-primary hover:border-primary transition-colors bg-surface text-primary">
                                                                {{ value }}
                                                            </div>
                                                        {%- endif -%}
                                                    </label>
                                                {%- endfor -%}
                                            </div>
                                        </div>
                                    {%- endfor -%}
                                </div>
                            {%- endunless -%}

                        {%- when 'quantity_selector' -%}
                            <div class="mb-12 flex flex-col gap-4" {{ block.shopify_attributes }}>
                                <span class="font-label-mono text-label-mono text-on-surface-variant uppercase">QUANTITY</span>
                                <div class="flex border border-outline-variant w-max bg-surface">
                                    <button type="button" class="w-12 h-12 flex items-center justify-center text-primary hover:bg-surface-variant transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                                    <input type="number" name="quantity" value="1" min="1" class="w-16 text-center bg-transparent font-label-mono text-label-mono text-primary outline-none appearance-none">
                                    <button type="button" class="w-12 h-12 flex items-center justify-center text-primary hover:bg-surface-variant transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
                                </div>
                            </div>

                        {%- when 'buy_button' -%}
                            <div class="flex flex-col gap-4 mb-12" {{ block.shopify_attributes }}>
                                
                                {%- if has_drop -%}
                                    <div class="bg-surface border border-outline-variant p-6 text-center mb-4">
                                        <span class="font-label-mono text-label-mono text-accent uppercase tracking-widest block mb-4">DROPPING IN</span>
                                        <span class="font-display-xl text-3xl text-primary tracking-tighter" data-countdown="{{ settings.global_drop_date }}">--:--:--</span>
                                    </div>
                                {%- endif -%}

                                {%- if is_waitlist -%}
                                    <button type="button" class="w-full bg-surface text-primary border border-outline-variant font-label-mono text-label-mono py-5 uppercase tracking-widest hover:border-primary transition-colors duration-300">
                                        JOIN WAITLIST
                                    </button>
                                {%- elsif current_variant.available == false and settings.enable_bis -%}
                                    <button type="button" class="w-full bg-surface text-primary border border-outline-variant font-label-mono text-label-mono py-5 uppercase tracking-widest hover:border-primary transition-colors duration-300">
                                        NOTIFY WHEN AVAILABLE
                                    </button>
                                {%- else -%}
                                    <button type="submit" name="add" class="w-full bg-primary text-surface border border-primary font-label-mono text-label-mono py-5 uppercase tracking-widest hover:bg-surface hover:text-primary transition-colors duration-300 flex justify-center items-center gap-2" {% unless current_variant.available or has_drop %}disabled{% endunless %}>
                                        {% if has_drop %}
                                            NOT YET AVAILABLE
                                        {% elsif current_variant.available %}
                                            {% if is_preorder %}PREORDER NOW{% else %}ADD TO BAG <span class="material-symbols-outlined text-[16px]">add</span>{% endif %}
                                        {% else %}
                                            SOLD OUT
                                        {% endif %}
                                    </button>
                                {%- endif -%}

                                <!-- Low Stock Warning -->
                                {%- if settings.low_stock_threshold > 0 and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= settings.low_stock_threshold -%}
                                    <p class="font-label-mono text-label-mono text-error uppercase text-center mt-2 tracking-widest">
                                        ONLY {{ current_variant.inventory_quantity }} LEFT
                                    </p>
                                {%- endif -%}
                            </div>

                        {%- when 'metafield' -%}
                            {%- assign meta_val = product.metafields.custom[block.settings.metafield_key] -%}
                            {%- if meta_val != blank -%}
                                <div class="accordion-item border-b border-outline-variant first-of-type:border-t" {{ block.shopify_attributes }}>
                                    <button type="button" class="w-full flex justify-between items-center py-6 focus:outline-none group" onclick="toggleAccordion(this)">
                                        <span class="font-label-mono text-label-mono text-primary uppercase tracking-widest">{{ block.settings.heading }}</span>
                                        <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors icon-state">add</span>
                                    </button>
                                    <div class="accordion-content overflow-hidden max-h-0 transition-all duration-500 ease-in-out font-body-main text-body-main text-on-surface-variant">
                                        <div class="pb-6 prose prose-invert">
                                            {{ meta_val | metafield_tag }}
                                        </div>
                                    </div>
                                </div>
                            {%- endif -%}

                        {%- when 'accordion' -%}
                            {%- if block.settings.heading != blank -%}
                                <div class="accordion-item border-b border-outline-variant first-of-type:border-t" {{ block.shopify_attributes }}>
                                    <button type="button" class="w-full flex justify-between items-center py-6 focus:outline-none group" onclick="toggleAccordion(this)">
                                        <span class="font-label-mono text-label-mono text-primary uppercase tracking-widest">{{ block.settings.heading }}</span>
                                        <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors icon-state">add</span>
                                    </button>
                                    <div class="accordion-content overflow-hidden max-h-0 transition-all duration-500 ease-in-out font-body-main text-body-main text-on-surface-variant">
                                        <div class="pb-6 prose prose-invert">
                                            {{ block.settings.content }}
                                        </div>
                                    </div>
                                </div>
                            {%- endif -%}

                        {%- when 'trust_badges' -%}
                            <div class="py-8 font-body-main text-on-surface-variant prose prose-invert" {{ block.shopify_attributes }}>
                                {{ block.settings.content }}
                            </div>

                        {%- when 'share' -%}
                            <div class="flex gap-4 py-8 items-center" {{ block.shopify_attributes }}>
                                <span class="font-label-mono text-label-mono text-on-surface-variant uppercase">SHARE:</span>
                                <a href="#" class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">link</span></a>
                                <a href="#" class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">share</span></a>
                            </div>

                    {%- endcase -%}
                {%- endfor -%}
            {% endform %}
            
        </div>
    </div>
</div>

{%- if section.settings.enable_sticky_atc -%}
    <div class="fixed bottom-0 left-0 w-full bg-surface border-t border-outline-variant p-4 z-50 transform translate-y-full transition-transform duration-300" id="StickyATC">
        <div class="max-w-container-max mx-auto flex justify-between items-center px-margin-mobile md:px-margin-desktop gap-4">
            <div class="hidden md:flex items-center gap-4">
                <img src="{{ product.featured_image | image_url: width: 100 }}" class="w-12 h-16 object-cover grayscale">
                <div class="flex flex-col">
                    <span class="font-label-mono text-label-mono uppercase text-primary">{{ product.title }}</span>
                    <span class="font-body-main text-sm text-on-surface-variant">{{ current_variant.price | money }}</span>
                </div>
            </div>
            <button class="w-full md:w-auto bg-primary text-surface px-12 py-4 font-label-mono text-label-mono uppercase tracking-widest hover:bg-background hover:text-primary transition-colors border border-primary" onclick="document.querySelector('#product-form button[type=submit]').click()">
                ADD TO BAG
            </button>
        </div>
    </div>
{%- endif -%}

<script>
    function toggleAccordion(btn) {
        const content = btn.nextElementSibling;
        const icon = btn.querySelector('.icon-state');
        if (content.style.maxHeight) {
            content.style.maxHeight = null;
            icon.textContent = 'add';
        } else {
            content.style.maxHeight = content.scrollHeight + "px";
            icon.textContent = 'remove';
        }
    }

    // Sticky ATC Logic
    {%- if section.settings.enable_sticky_atc -%}
        window.addEventListener('scroll', () => {
            const form = document.getElementById('product-form');
            const stickyAtc = document.getElementById('StickyATC');
            if(form && stickyAtc) {
                const formRect = form.getBoundingClientRect();
                if(formRect.bottom < 0) {
                    stickyAtc.classList.remove('translate-y-full');
                } else {
                    stickyAtc.classList.add('translate-y-full');
                }
            }
        });
    {%- endif -%}
    
    // AJAX Add to Cart
    const form = document.getElementById('product-form');
    if(form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(form);
            fetch(window.Shopify.routes.root + 'cart/add.js', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    if (typeof openCartDrawer === 'function') openCartDrawer();
                    else window.location.href = '/cart';
                }
            })
            .catch(error => console.error('Error adding to cart:', error));
        });
    }
</script>

{% schema %}
{
  "name": "Product Layout (PE)",
  "settings": [
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery Layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "thumbnails-left", "label": "Thumbnails Left" },
        { "value": "thumbnails-bottom", "label": "Thumbnails Bottom" }
      ],
      "default": "stacked"
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Enable Image Zoom",
      "default": true
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_atc",
      "label": "Enable Sticky Add to Cart",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_size_guide",
      "label": "Enable Size Guide Link",
      "default": true
    },
    {
      "type": "page",
      "id": "size_guide_page",
      "label": "Size Guide Page"
    }
  ],
  "blocks": [
    { "type": "title", "name": "Title", "limit": 1 },
    { 
      "type": "price", 
      "name": "Price", 
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_inventory", "label": "Show Inventory Status", "default": true }
      ]
    },
    { "type": "variant_selector", "name": "Variant Selector", "limit": 1 },
    { "type": "quantity_selector", "name": "Quantity Selector", "limit": 1 },
    { "type": "buy_button", "name": "Buy Buttons", "limit": 1 },
    { "type": "description", "name": "Description", "limit": 1 },
    {
      "type": "metafield",
      "name": "Dynamic Metafield",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "DETAILS" },
        { "type": "text", "id": "metafield_key", "label": "Metafield Key", "info": "e.g. fabric, fit_notes" }
      ]
    },
    {
      "type": "accordion",
      "name": "Static Accordion",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "SHIPPING & RETURNS" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Content goes here.</p>" }
      ]
    },
    {
      "type": "trust_badges",
      "name": "Trust Badges",
      "settings": [
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Guaranteed authentic. Free shipping on all orders.</p>" }
      ]
    },
    { "type": "share", "name": "Share Buttons", "limit": 1 }
  ],
  "default": {
    "blocks": [
      { "type": "title" },
      { "type": "price" },
      { "type": "description" },
      { "type": "variant_selector" },
      { "type": "quantity_selector" },
      { "type": "buy_button" }
    ]
  }
}
{% endschema %}
