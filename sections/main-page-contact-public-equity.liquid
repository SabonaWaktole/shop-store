<div class="w-full max-w-container-max mx-auto pt-[60px] md:pt-[100px] pb-32 px-margin-mobile md:px-margin-desktop" data-section-id="{{ section.id }}" data-section-type="contact">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        
        <!-- Left: Info -->
        <div class="lg:col-span-5 flex flex-col gap-12">
            <header>
                <h1 class="font-display-xl text-display-xl uppercase leading-none text-[36px] md:text-[64px] mb-8">
                    {{ section.settings.heading | default: 'CONTACT' }}
                </h1>
                {%- if section.settings.subtext != blank -%}
                    <p class="font-body-main text-body-main text-on-surface-variant max-w-md">
                        {{ section.settings.subtext }}
                    </p>
                {%- endif -%}
            </header>
            
            <div class="border-t border-outline-variant pt-8 flex flex-col gap-6">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'email' -%}
                            <div class="flex items-center gap-4" {{ block.shopify_attributes }}>
                                <span class="material-symbols-outlined text-primary text-[20px]">mail</span>
                                <a href="mailto:{{ block.settings.email }}" class="font-label-mono text-label-mono text-on-surface-variant uppercase hover:text-primary transition-colors underline underline-offset-4">{{ block.settings.email }}</a>
                            </div>
                        {%- when 'phone' -%}
                            <div class="flex items-center gap-4" {{ block.shopify_attributes }}>
                                <span class="material-symbols-outlined text-primary text-[20px]">call</span>
                                <a href="tel:{{ block.settings.phone }}" class="font-label-mono text-label-mono text-on-surface-variant uppercase hover:text-primary transition-colors">{{ block.settings.phone }}</a>
                            </div>
                        {%- when 'address' -%}
                            <div class="flex items-start gap-4" {{ block.shopify_attributes }}>
                                <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">location_on</span>
                                <span class="font-label-mono text-label-mono text-on-surface-variant uppercase">{{ block.settings.address }}</span>
                            </div>
                        {%- when 'text' -%}
                            <div class="font-body-main text-body-main text-on-surface-variant prose prose-invert" {{ block.shopify_attributes }}>
                                {{ block.settings.text }}
                            </div>
                    {%- endcase -%}
                {%- endfor -%}
            </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-7">
            <div class="bg-surface border border-outline-variant p-8 md:p-12 relative">
                {% form 'contact', id: 'contactForm' %}
                    <div class="flex flex-col gap-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="flex flex-col relative group">
                                <label class="font-label-mono text-label-mono text-on-surface-variant mb-2 group-focus-within:text-primary transition-colors uppercase" for="contact-name">NAME</label>
                                <input class="cinetica-input font-label-mono text-label-mono w-full focus:ring-0 uppercase" id="contact-name" name="contact[name]" placeholder=" " required type="text">
                            </div>
                            <div class="flex flex-col relative group">
                                <label class="font-label-mono text-label-mono text-on-surface-variant mb-2 group-focus-within:text-primary transition-colors uppercase" for="contact-email">EMAIL</label>
                                <input class="cinetica-input font-label-mono text-label-mono w-full focus:ring-0 uppercase" id="contact-email" name="contact[email]" placeholder=" " required type="email">
                            </div>
                        </div>
                        
                        <div class="flex flex-col relative group">
                            <label class="font-label-mono text-label-mono text-on-surface-variant mb-2 group-focus-within:text-primary transition-colors uppercase" for="contact-subject">SUBJECT</label>
                            <input class="cinetica-input font-label-mono text-label-mono w-full focus:ring-0 uppercase" id="contact-subject" name="contact[subject]" placeholder=" " type="text">
                        </div>

                        <div class="flex flex-col relative group">
                            <label class="font-label-mono text-label-mono text-on-surface-variant mb-2 group-focus-within:text-primary transition-colors uppercase" for="contact-body">MESSAGE</label>
                            <textarea class="cinetica-input font-label-mono text-label-mono w-full focus:ring-0 uppercase resize-none" id="contact-body" name="contact[body]" rows="6" placeholder=" " required></textarea>
                        </div>

                        {%- if form.errors -%}
                            <div class="text-error font-label-mono text-label-mono uppercase text-center">
                                {{ form.errors | default_errors }}
                            </div>
                        {%- endif -%}

                        <button type="submit" class="w-full bg-primary text-background border border-primary font-label-mono text-label-mono py-5 uppercase tracking-[0.2em] hover:bg-background hover:text-primary transition-all duration-300 flex justify-center items-center gap-4 group">
                            <span>SEND TRANSMISSION</span>
                            <span class="material-symbols-outlined transform group-hover:translate-x-2 transition-transform duration-300 text-[16px]">arrow_forward</span>
                        </button>
                    </div>

                    {%- if form.posted_successfully? -%}
                        <div class="absolute inset-0 bg-surface/95 backdrop-blur-xl flex flex-col items-center justify-center p-8 text-center z-50 border border-outline-variant">
                            <span class="material-symbols-outlined text-[64px] text-primary mb-6 animate-pulse" style="font-variation-settings: 'FILL' 1;">done_all</span>
                            <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-primary uppercase mb-4">MESSAGE SENT</h2>
                            <p class="font-label-mono text-label-mono text-on-surface-variant tracking-widest">TRANSMISSION SECURED. WE'LL RESPOND SHORTLY.</p>
                        </div>
                    {%- endif -%}
                {% endform %}
            </div>
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Contact Page (PE)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CONTACT"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subheading Text",
      "default": "For inquiries regarding orders, collaborations, or wholesale access, submit a transmission below."
    }
  ],
  "blocks": [
    {
      "type": "email",
      "name": "Email Address",
      "settings": [
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "INFO@PUBLICEQUITY.CO"
        }
      ]
    },
    {
      "type": "phone",
      "name": "Phone Number",
      "settings": [
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+1 800 123 4567"
        }
      ]
    },
    {
      "type": "address",
      "name": "Address",
      "settings": [
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "123 MAIN ST, NEW YORK, NY 10001"
        }
      ]
    },
    {
      "type": "text",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Additional information here.</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "email" },
      { "type": "address" }
    ]
  }
}
{% endschema %}
