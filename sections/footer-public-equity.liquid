{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.color_bg != blank and section.settings.color_bg != 'rgba(0,0,0,0)' %}
    #shopify-section-{{ section.id }} footer { background-color: {{ section.settings.color_bg }}; }
  {% endif %}
  {% if section.settings.color_text != blank and section.settings.color_text != 'rgba(0,0,0,0)' %}
    #shopify-section-{{ section.id }} footer,
    #shopify-section-{{ section.id }} footer a { color: {{ section.settings.color_text }}; }
  {% endif %}
{%- endstyle -%}

<footer class="text-primary font-label-mono text-label-mono w-full border-t border-outline-variant section-{{ section.id }}-padding bg-background transition-colors">
    <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        
        <!-- Top Section (Grid) -->
        <div class="flex flex-col md:flex-row gap-12 md:gap-24 mb-16 md:mb-24">
            {%- for block in section.blocks -%}
                <div class="flex flex-col flex-1 {% if block.type == 'newsletter' %}md:flex-[2]{% endif %}" {{ block.shopify_attributes }}>
                    
                    {%- case block.type -%}
                        {%- when 'link_list' -%}
                            <div class="md:hidden border-b border-outline-variant first:border-t">
                                <button class="w-full flex justify-between items-center py-4 font-body-main font-bold uppercase tracking-widest text-on-surface-variant" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('.icon').textContent = this.nextElementSibling.classList.contains('hidden') ? '+' : '-';">
                                    {{ block.settings.heading }}
                                    <span class="icon font-label-mono text-xl">+</span>
                                </button>
                                <div class="hidden pb-4">
                                    <ul class="flex flex-col gap-4 pl-2">
                                        {%- for link in linklists[block.settings.menu].links -%}
                                            <li><a href="{{ link.url }}" class="hover:underline hover:text-accent transition-all uppercase">{{ link.title }}</a></li>
                                        {%- endfor -%}
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="hidden md:flex flex-col gap-6">
                                {%- if block.settings.heading != blank -%}
                                    <h4 class="font-body-main font-bold uppercase tracking-widest text-on-surface-variant mb-2">{{ block.settings.heading }}</h4>
                                {%- endif -%}
                                {%- if block.settings.menu != blank -%}
                                    <ul class="flex flex-col gap-4">
                                        {%- for link in linklists[block.settings.menu].links -%}
                                            <li><a href="{{ link.url }}" class="hover:underline hover:text-accent transition-all uppercase">{{ link.title }}</a></li>
                                        {%- endfor -%}
                                    </ul>
                                {%- endif -%}
                            </div>
                            
                        {%- when 'text' -%}
                            <div class="flex flex-col gap-6 py-4 md:py-0">
                                {%- if block.settings.heading != blank -%}
                                    <h4 class="font-body-main font-bold uppercase tracking-widest text-on-surface-variant mb-2">{{ block.settings.heading }}</h4>
                                {%- endif -%}
                                <div class="prose prose-invert font-body-main text-on-surface-variant max-w-none">
                                    {{ block.settings.subtext }}
                                </div>
                            </div>

                        {%- when 'brand_info' -%}
                            <div class="flex flex-col gap-6 py-4 md:py-0">
                                {%- if block.settings.logo_image != blank -%}
                                    <img src="{{ block.settings.logo_image | image_url: width: 400 }}" alt="{{ shop.name }}" class="max-w-[150px] h-auto object-contain">
                                {%- else -%}
                                    <h4 class="font-display-xl text-3xl uppercase tracking-tighter text-primary">{{ section.settings.brand_text | default: shop.name }}</h4>
                                {%- endif -%}
                                {%- if block.settings.text != blank -%}
                                    <div class="prose prose-invert font-body-main text-on-surface-variant">{{ block.settings.text }}</div>
                                {%- endif -%}
                                {%- if block.settings.show_social -%}
                                    <div class="flex items-center gap-4 mt-2">
                                        <a href="{{ settings.social_instagram_link | default: '#' }}" class="hover:opacity-70 transition-opacity"><span class="material-symbols-outlined text-[24px]">photo_camera</span></a>
                                        <a href="{{ settings.social_twitter_link | default: '#' }}" class="hover:opacity-70 transition-opacity"><span class="material-symbols-outlined text-[24px]">chat_bubble</span></a>
                                    </div>
                                {%- endif -%}
                            </div>

                        {%- when 'contact_info' -%}
                            <div class="flex flex-col gap-6 py-4 md:py-0">
                                {%- if block.settings.heading != blank -%}
                                    <h4 class="font-body-main font-bold uppercase tracking-widest text-on-surface-variant mb-2">{{ block.settings.heading }}</h4>
                                {%- endif -%}
                                <ul class="flex flex-col gap-4 font-body-main text-on-surface-variant">
                                    {%- if block.settings.email != blank -%}<li><a href="mailto:{{ block.settings.email }}" class="hover:text-primary transition-colors">{{ block.settings.email }}</a></li>{%- endif -%}
                                    {%- if block.settings.phone != blank -%}<li><a href="tel:{{ block.settings.phone }}" class="hover:text-primary transition-colors">{{ block.settings.phone }}</a></li>{%- endif -%}
                                    {%- if block.settings.address != blank -%}<li>{{ block.settings.address }}</li>{%- endif -%}
                                    {%- if block.settings.hours != blank -%}<li>{{ block.settings.hours }}</li>{%- endif -%}
                                </ul>
                            </div>
                            
                        {%- when 'social_text_links' -%}
                            <div class="hidden md:flex flex-col gap-6">
                                {%- if block.settings.heading != blank -%}
                                    <h4 class="font-body-main font-bold uppercase tracking-widest text-on-surface-variant mb-2">{{ block.settings.heading }}</h4>
                                {%- endif -%}
                                <ul class="flex flex-col gap-4 font-body-main text-primary">
                                    {%- if settings.social_instagram_link != blank -%}<li><a href="{{ settings.social_instagram_link }}" class="hover:text-accent transition-colors">Instagram</a></li>{%- endif -%}
                                    {%- if settings.social_tiktok_link != blank -%}<li><a href="{{ settings.social_tiktok_link }}" class="hover:text-accent transition-colors">TikTok</a></li>{%- endif -%}
                                    {%- if settings.social_twitter_link != blank -%}<li><a href="{{ settings.social_twitter_link }}" class="hover:text-accent transition-colors">Twitter</a></li>{%- endif -%}
                                    {%- if settings.social_facebook_link != blank -%}<li><a href="{{ settings.social_facebook_link }}" class="hover:text-accent transition-colors">Facebook</a></li>{%- endif -%}
                                </ul>
                            </div>
                            <div class="md:hidden border-b border-outline-variant first:border-t">
                                <button class="w-full flex justify-between items-center py-4 font-body-main font-bold uppercase tracking-widest text-on-surface-variant" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('.icon').textContent = this.nextElementSibling.classList.contains('hidden') ? '+' : '-';">
                                    {{ block.settings.heading }}
                                    <span class="icon font-label-mono text-xl">+</span>
                                </button>
                                <div class="hidden pb-4">
                                    <ul class="flex flex-col gap-4 pl-2 font-body-main text-primary">
                                        {%- if settings.social_instagram_link != blank -%}<li><a href="{{ settings.social_instagram_link }}" class="hover:text-accent transition-colors">Instagram</a></li>{%- endif -%}
                                        {%- if settings.social_tiktok_link != blank -%}<li><a href="{{ settings.social_tiktok_link }}" class="hover:text-accent transition-colors">TikTok</a></li>{%- endif -%}
                                        {%- if settings.social_twitter_link != blank -%}<li><a href="{{ settings.social_twitter_link }}" class="hover:text-accent transition-colors">Twitter</a></li>{%- endif -%}
                                        {%- if settings.social_facebook_link != blank -%}<li><a href="{{ settings.social_facebook_link }}" class="hover:text-accent transition-colors">Facebook</a></li>{%- endif -%}
                                    </ul>
                                </div>
                            </div>
                            
                        {%- when 'newsletter' -%}
                            <div class="flex flex-col gap-6 py-4 md:py-0">
                                {%- if block.settings.heading != blank -%}
                                    <h2 class="font-display-xl text-3xl md:text-4xl uppercase tracking-tighter text-primary mb-2">{{ block.settings.heading }}</h2>
                                {%- endif -%}
                                <div class="font-body-main text-on-surface-variant">{{ block.settings.text }}</div>
                                {%- form 'customer', id: 'FooterNewsletterForm', class: 'flex w-full mt-2' -%}
                                    <input type="hidden" name="contact[tags]" value="newsletter">
                                    <input type="email" name="contact[email]" class="cinetica-input flex-1 py-3 px-4 border border-outline-variant bg-transparent text-primary outline-none focus:border-primary font-body-main placeholder-on-surface-variant/50" placeholder="{{ block.settings.placeholder }}" required>
                                    <button type="submit" class="bg-primary text-background px-8 py-3 font-label-mono uppercase tracking-widest hover:opacity-80 transition-opacity whitespace-nowrap">
                                        {{ block.settings.button_text | default: 'SUBSCRIBE' }}
                                    </button>
                                {%- endform -%}
                            </div>
                    {%- endcase -%}
                </div>
            {%- endfor -%}
        </div>

        <!-- Optional Large Center Logo -->
        {%- if section.settings.show_large_logo -%}
        <div class="flex items-center justify-center border-t border-b border-outline-variant py-12 md:py-16 mb-12 md:mb-16 relative overflow-hidden">
            {%- if section.settings.logo_image != blank -%}
                <img src="{{ section.settings.logo_image | image_url: width: 800 }}" alt="{{ section.settings.logo_image.alt | escape }}" class="max-w-full h-auto object-contain" style="max-height: 120px;">
            {%- else -%}
                <h2 class="font-display-xl text-4xl md:text-display-xl tracking-tighter uppercase leading-none text-center m-0 max-w-full whitespace-nowrap">
                    {{ section.settings.brand_text | default: 'PUBLIC EQUITY' }}
                </h2>
            {%- endif -%}
        </div>
        {%- else -%}
        <div class="border-t border-outline-variant mb-8"></div>
        {%- endif -%}

        <!-- Bottom Section (Meta) -->
        <div class="flex flex-col md:flex-row justify-between items-center gap-8 text-sm">
            <div class="flex items-center gap-6">
                {%- if section.settings.show_social -%}
                    <a href="{{ settings.social_instagram_link | default: '#' }}" class="hover:opacity-70 transition-opacity"><span class="material-symbols-outlined text-[20px]">photo_camera</span></a>
                    <a href="{{ settings.social_twitter_link | default: '#' }}" class="hover:opacity-70 transition-opacity"><span class="material-symbols-outlined text-[20px]">chat_bubble</span></a>
                {%- endif -%}
                
                {%- if section.settings.show_localization and localization.available_countries.size > 1 -%}
                    {%- form 'localization', id: 'FooterCountryForm', class: 'relative' -%}
                        <select name="country_code" class="bg-transparent border border-outline-variant rounded px-2 py-1 text-label-mono font-label-mono uppercase outline-none focus:border-primary" onchange="this.form.submit()">
                            {%- for country in localization.available_countries -%}
                                <option value="{{ country.iso_code }}" class="bg-surface text-primary" {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                                    {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                                </option>
                            {%- endfor -%}
                        </select>
                    {%- endform -%}
                {%- endif -%}
            </div>

            <div class="text-on-surface-variant uppercase text-center md:text-left">
                &copy; {{ 'now' | date: "%Y" }} {{ section.settings.brand_text | default: 'PUBLIC EQUITY' }}. ALL RIGHTS RESERVED.
            </div>

            <div class="flex items-center gap-3 opacity-70">
                {%- if section.settings.show_payment_icons -%}
                    {%- for type in shop.enabled_payment_types -%}
                        {{ type | payment_type_svg_tag: class: 'h-5 w-auto' }}
                    {%- endfor -%}
                {%- endif -%}
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Large Center Logo"
    },
    {
      "type": "checkbox",
      "id": "show_large_logo",
      "label": "Show large logo strip",
      "default": true
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand Text",
      "default": "PUBLIC EQUITY"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Footer Logo Image"
    },
    {
      "type": "header",
      "content": "Bottom Bar Toggles"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_localization",
      "label": "Show country/region selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors (Optional Overrides)"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "brand_info",
      "name": "Brand Information",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Brand Logo"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Defining the future of luxury artifacts.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "label": "Show Social Icons",
          "default": true
        }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Details",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "info@publicequity.com"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number"
        },
        {
          "type": "text",
          "id": "address",
          "label": "Address"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Operating Hours",
          "default": "Mon - Fri, 9am - 5pm"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About us"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Text",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Subscribe"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Sign up to get the latest on sales, new releases and more.</p>"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Input Placeholder",
          "default": "Email Address"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SUBSCRIBE"
        }
      ]
    },
    {
      "type": "social_text_links",
      "name": "Social Links (Text)",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SOCIAL"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "newsletter"
      },
      {
        "type": "link_list"
      },
      {
        "type": "social_text_links"
      }
    ]
  }
}
{% endschema %}
