{% style %}
  .custom-password-header-section {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 20px 40px;
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    color: {{ section.settings.text_color | default: '#000000' }};
    align-items: center;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    font-family: var(--font-body-family, sans-serif);
  }
  .custom-password-header__left {
    text-align: left;
    text-transform: uppercase;
    font-weight: 500;
  }
  .custom-password-header__center {
    text-align: center;
    text-transform: uppercase;
    font-weight: 500;
  }
  .custom-password-header__right {
    text-align: right;
  }
  .custom-password-header__right a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
  }
  
  @media screen and (max-width: 768px) {
    .custom-password-header-section {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 15px;
      padding: 15px 20px;
      border-bottom: none;
    }
    .custom-password-header__left,
    .custom-password-header__center,
    .custom-password-header__right {
      text-align: center;
    }
  }
{% endstyle %}

<div class="custom-password-header-section">
  <div class="custom-password-header__left">
    {{ section.settings.header_left_text }}
  </div>
  <div class="custom-password-header__center">
    {{ section.settings.header_center_text }}
  </div>
  <div class="custom-password-header__right">
    <a href="#password-form" id="trigger-password-modal">
      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-padlock" viewBox="0 0 20 20" width="16" height="16">
        <path fill-rule="evenodd" d="M14 8.5V6a4 4 0 10-8 0v2.5H4.5v10h11v-10H14zm-7-2.5a3 3 0 116 0V8.5H7V6zm-1.5 3.5h9v8h-9v-8z" fill="currentColor"/>
      </svg>
      {{ section.settings.header_right_text }}
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var trigger = document.getElementById('trigger-password-modal');
    if (trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var dialog = document.querySelector('dialog-component dialog') || document.querySelector('dialog');
        if (dialog && typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
            console.error("Password dialog not found or HTML5 dialog element is not supported by this browser.");
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Custom Password Header",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "header_left_text",
      "label": "Left Text",
      "default": "PUBLIC EQUITY"
    },
    {
      "type": "text",
      "id": "header_center_text",
      "label": "Center Text",
      "default": "EQUITY ISSUED"
    },
    {
      "type": "text",
      "id": "header_right_text",
      "label": "Right Text",
      "default": "Enter using password"
    }
  ],
  "presets": [
    {
      "name": "Custom Password Header"
    }
  ]
}
{% endschema %}
