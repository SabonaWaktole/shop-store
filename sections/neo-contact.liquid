{% schema %}
{
  "name": "NEO-DYS Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ESTABLISH_CONNECTION"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "TRANSMIT_SECURE_COMMUNIQUE_TO_CENTRAL_COMMAND"
    }
  ],
  "presets": [
    {
      "name": "NEO-DYS Contact Form"
    }
  ]
}
{% endschema %}

<section class="py-section-gap px-margin-desktop bg-surface-container-lowest relative overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute top-0 right-0 w-1/3 h-full volumetric-glow pointer-events-none"></div>
    
    <div class="max-w-3xl mx-auto relative z-10">
        <!-- Header -->
        <div class="mb-12 border-l-2 border-primary-container pl-6">
            <span class="font-utility-label text-primary-container mb-2 block uppercase tracking-widest">// SECURE_CHANNEL_OPEN</span>
            <h1 class="font-headline-lg text-4xl md:text-5xl uppercase">{{ section.settings.heading }}</h1>
            <p class="font-utility-label text-on-surface-variant text-xs mt-4 uppercase">{{ section.settings.subheading }}</p>
        </div>

        <!-- Form Area -->
        <div class="border border-outline-variant bg-surface-container-low p-8 relative">
            <div class="absolute -top-[1px] -left-[1px] w-4 h-4 border-t-2 border-l-2 border-primary-container"></div>
            <div class="absolute -bottom-[1px] -right-[1px] w-4 h-4 border-b-2 border-r-2 border-primary-container"></div>

            {%- form 'contact', id: 'ContactForm', class: 'space-y-6' -%}
                {%- if form.posted_successfully? -%}
                    <div class="bg-primary-container/20 border border-primary-container p-4 mb-8 flex items-center gap-4">
                        <span class="material-symbols-outlined text-primary-container">check_circle</span>
                        <p class="font-utility-label text-sm text-primary-container uppercase tracking-widest">TRANSMISSION_SUCCESSFUL. AWAIT_REPLY.</p>
                    </div>
                {%- elsif form.errors -%}
                    <div class="bg-error/20 border border-error p-4 mb-8">
                        <div class="flex items-center gap-4 mb-2">
                            <span class="material-symbols-outlined text-error">error</span>
                            <p class="font-utility-label text-sm text-error uppercase tracking-widest">TRANSMISSION_FAILED</p>
                        </div>
                        <ul class="font-utility-label text-[10px] text-error list-disc pl-8">
                            {%- for field in form.errors -%}
                                <li>{{ field | replace: 'body', 'Message' | capitalize }} {{ form.errors.messages[field] }}</li>
                            {%- endfor -%}
                        </ul>
                    </div>
                {%- endif -%}

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Name Field -->
                    <div class="flex flex-col gap-2">
                        <label class="font-utility-label text-[10px] text-secondary uppercase tracking-widest" for="ContactForm-name">OPERATIVE_ID (NAME)</label>
                        <input class="bg-background border border-outline-variant p-4 font-utility-label text-on-surface focus:border-primary-container focus:ring-0 transition-colors uppercase" 
                               type="text" 
                               id="ContactForm-name" 
                               name="contact[name]" 
                               value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" 
                               placeholder="ENTER_ID">
                    </div>
                    <!-- Email Field -->
                    <div class="flex flex-col gap-2">
                        <label class="font-utility-label text-[10px] text-secondary uppercase tracking-widest" for="ContactForm-email">COMM_LINK (EMAIL) <span class="text-primary-container">*</span></label>
                        <input class="bg-background border border-outline-variant p-4 font-utility-label text-on-surface focus:border-primary-container focus:ring-0 transition-colors uppercase {% if form.errors contains 'email' %}border-error{% endif %}" 
                               type="email" 
                               id="ContactForm-email" 
                               name="contact[email]" 
                               autocorrect="off" 
                               autocapitalize="off" 
                               value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" 
                               aria-required="true"
                               required
                               placeholder="ENTER_ADDRESS">
                    </div>
                </div>

                <!-- Phone Field -->
                <div class="flex flex-col gap-2">
                    <label class="font-utility-label text-[10px] text-secondary uppercase tracking-widest" for="ContactForm-phone">FREQUENCY (PHONE)</label>
                    <input class="bg-background border border-outline-variant p-4 font-utility-label text-on-surface focus:border-primary-container focus:ring-0 transition-colors uppercase" 
                           type="tel" 
                           id="ContactForm-phone" 
                           name="contact[phone]" 
                           pattern="[0-9\-]*" 
                           value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" 
                           placeholder="OPTIONAL">
                </div>

                <!-- Message Field -->
                <div class="flex flex-col gap-2">
                    <label class="font-utility-label text-[10px] text-secondary uppercase tracking-widest" for="ContactForm-body">TRANSMISSION_DATA (MESSAGE) <span class="text-primary-container">*</span></label>
                    <textarea class="bg-background border border-outline-variant p-4 font-utility-label text-on-surface focus:border-primary-container focus:ring-0 transition-colors resize-none uppercase" 
                              rows="8" 
                              id="ContactForm-body" 
                              name="contact[body]"
                              required
                              placeholder="ENTER_ENCRYPTED_MESSAGE">
                        {{- form.body -}}
                    </textarea>
                </div>

                <!-- Submit Button -->
                <div class="pt-6 border-t border-outline-variant">
                    <button type="submit" class="glitch-btn group relative w-full py-5 bg-primary-container text-on-primary-container font-headline-lg text-xl uppercase font-bold flex items-center justify-center gap-4 overflow-hidden border border-primary-container shadow-[0_0_15px_rgba(57,255,20,0.15)]">
                        <span class="relative z-10 tracking-widest">TRANSMIT_DATA</span>
                        <span class="material-symbols-outlined relative z-10">send</span>
                        <div class="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    </button>
                    <div class="flex items-center gap-3 justify-center mt-4 opacity-50">
                        <span class="font-utility-label text-[10px] text-secondary uppercase tracking-tighter">CONNECTION_SECURE // 256_BIT_ENCRYPTION</span>
                    </div>
                </div>
            {%- endform -%}
        </div>
    </div>
</section>

<script>
    document.querySelectorAll('.glitch-btn').forEach(btn => {
        btn.addEventListener('mouseenter', () => {
            const interval = setInterval(() => {
                btn.style.left = (Math.random() * 2 - 1) + 'px';
            }, 50);
            btn.dataset.intervalId = interval;
        });
        btn.addEventListener('mouseleave', () => {
            clearInterval(btn.dataset.intervalId);
            btn.style.left = '0px';
        });
    });
</script>
