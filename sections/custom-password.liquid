{% style %}
  .custom-password-section {
    font-family: var(--font-body-family, sans-serif);
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    color: {{ section.settings.text_color | default: '#000000' }};
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .custom-password-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 20px 40px;
    background-color: transparent;
    align-items: center;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .custom-password-header__left {
    text-align: left;
    text-transform: uppercase;
    font-weight: 500;
  }
  .custom-password-header__center {
    text-align: center;
    text-transform: uppercase;
    font-weight: 500;
  }
  .custom-password-header__right {
    text-align: right;
  }
  .custom-password-header__right a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
  }
  .custom-password-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px {{ section.settings.lower_section_height }}px 20px;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .custom-password-block {
    width: 100%;
    margin-bottom: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .custom-password-block:last-child {
    margin-bottom: 0;
  }
  .custom-password-logo {
    height: auto;
  }
  .custom-password-hero {
    height: auto;
  }
  .custom-password-heading {
    font-size: 24px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }
  .custom-password-subheading {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }
  .custom-password-embed {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }
  .custom-password-footer-bg {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ section.settings.lower_section_height }}px;
    background-size: cover;
    background-position: center bottom;
    background-repeat: no-repeat;
    z-index: 1;
  }
  
  @media screen and (max-width: 768px) {
    .custom-password-header {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 15px;
      padding: 15px 20px;
      border-bottom: none;
    }
    .custom-password-header__left,
    .custom-password-header__center,
    .custom-password-header__right {
      text-align: center;
    }
    .custom-password-main {
      padding-top: 20px;
    }
    .custom-password-heading {
      font-size: 18px;
    }
  }
{% endstyle %}

<div class="custom-password-section">
  <div class="custom-password-header">
    <div class="custom-password-header__left">
      {{ section.settings.header_left_text }}
    </div>
    <div class="custom-password-header__center">
      {{ section.settings.header_center_text }}
    </div>
    <div class="custom-password-header__right">
      <a href="#password-form" id="trigger-password-modal">
        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-padlock" viewBox="0 0 20 20" width="16" height="16">
          <path fill-rule="evenodd" d="M14 8.5V6a4 4 0 10-8 0v2.5H4.5v10h11v-10H14zm-7-2.5a3 3 0 116 0V8.5H7V6zm-1.5 3.5h9v8h-9v-8z" fill="currentColor"/>
        </svg>
        {{ section.settings.header_right_text }}
      </a>
    </div>
  </div>

  <div class="custom-password-main">
    {% for block in section.blocks %}
      <div class="custom-password-block" {{ block.shopify_attributes }}>
        {% case block.type %}
          {% when 'logo' %}
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: block.settings.width | times: 2 }}" 
                   alt="{{ block.settings.image.alt | default: 'Logo' }}" 
                   class="custom-password-logo" 
                   style="max-width: {{ block.settings.width }}px;"
                   loading="lazy">
            {% else %}
              <h1 class="custom-password-logo-text" style="font-size: 32px; font-weight: bold; text-transform: uppercase;">
                {{ shop.name }}
              </h1>
            {% endif %}

          {% when 'hero_image' %}
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: block.settings.width | times: 2 }}" 
                   alt="{{ block.settings.image.alt | default: 'Hero Image' }}" 
                   class="custom-password-hero" 
                   style="max-width: {{ block.settings.width }}px;"
                   loading="lazy">
            {% endif %}

          {% when 'heading' %}
            {% if block.settings.text != blank %}
              <div class="custom-password-heading">
                {{ block.settings.text }}
              </div>
            {% endif %}

          {% when 'subheading' %}
            {% if block.settings.text != blank %}
              <div class="custom-password-subheading">
                {{ block.settings.text }}
              </div>
            {% endif %}

          {% when 'html_embed' %}
            {% if block.settings.html != blank %}
              <div class="custom-password-embed">
                {{ block.settings.html }}
              </div>
            {% endif %}
            
        {% endcase %}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.background_image %}
    <div class="custom-password-footer-bg" style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');"></div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var trigger = document.getElementById('trigger-password-modal');
    if (trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var dialog = document.querySelector('dialog-component dialog') || document.querySelector('dialog');
        if (dialog && typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
            console.error("Password dialog not found or HTML5 dialog element is not supported by this browser.");
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Custom Password Page",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "header_left_text",
      "label": "Header Left Text",
      "default": "PUBLIC EQUITY"
    },
    {
      "type": "text",
      "id": "header_center_text",
      "label": "Header Center Text",
      "default": "EQUITY ISSUED"
    },
    {
      "type": "text",
      "id": "header_right_text",
      "label": "Header Right Text",
      "default": "Enter using password"
    },
    {
      "type": "header",
      "content": "Lower Section"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Lower Background Image",
      "info": "Image spanning the bottom of the page."
    },
    {
      "type": "range",
      "id": "lower_section_height",
      "min": 200,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Lower Section Height",
      "default": 650
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "width",
          "min": 50,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Max Width",
          "default": 200
        }
      ]
    },
    {
      "type": "hero_image",
      "name": "Hero Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "width",
          "min": 100,
          "max": 1000,
          "step": 20,
          "unit": "px",
          "label": "Max Width",
          "default": 400
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "DROPPING SATURDAY JULY 11TH — 11AM PST"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "BLACK HICKORY DOUBLE KNEE CAPRIS."
        }
      ]
    },
    {
      "type": "html_embed",
      "name": "Custom HTML Embed",
      "settings": [
        {
          "type": "html",
          "id": "html",
          "label": "HTML code",
          "info": "Paste your Omnisend or other embed code here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Password Page",
      "blocks": [
        {
          "type": "html_embed"
        },
        {
          "type": "logo"
        },
        {
          "type": "hero_image"
        },
        {
          "type": "heading"
        },
        {
          "type": "subheading"
        }
      ]
    }
  ]
}
{% endschema %}
