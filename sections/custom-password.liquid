{% style %}
  .custom-password-section {
    font-family: var(--font-body-family, sans-serif);
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    color: {{ section.settings.text_color | default: '#000000' }};
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .custom-password-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 20px 40px;
    background-color: transparent;
    align-items: center;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .custom-password-header__left {
    text-align: left;
    text-transform: uppercase;
    font-weight: 500;
  }
  .custom-password-header__center {
    text-align: center;
    text-transform: uppercase;
    font-weight: 500;
  }
  .custom-password-header__right {
    text-align: right;
  }
  .custom-password-header__right a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
  }
  .custom-password-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px 400px 20px; /* Space for the bottom image */
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .custom-password-logo {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
    margin-bottom: 40px;
  }
  .custom-password-hero {
    max-width: {{ section.settings.hero_width }}px;
    height: auto;
    margin-bottom: 30px;
  }
  .custom-password-heading {
    font-size: 24px;
    font-weight: bold;
    text-transform: uppercase;
    margin-bottom: 10px;
    letter-spacing: 1px;
  }
  .custom-password-subheading {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 30px;
  }
  .custom-password-embed {
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
  }
  .custom-password-footer-bg {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 400px; /* Base height */
    background-size: cover;
    background-position: center bottom;
    background-repeat: no-repeat;
    z-index: 1;
  }

  /* Handle images naturally based on their aspect ratio if possible, otherwise cover */
  
  @media screen and (max-width: 768px) {
    .custom-password-header {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 15px;
      padding: 15px 20px;
      border-bottom: none;
    }
    .custom-password-header__left,
    .custom-password-header__center,
    .custom-password-header__right {
      text-align: center;
    }
    .custom-password-main {
      padding-bottom: 300px; /* adjust for mobile */
      padding-top: 20px;
    }
    .custom-password-footer-bg {
      height: 300px;
    }
    .custom-password-heading {
      font-size: 18px;
    }
  }
{% endstyle %}

<div class="custom-password-section">
  <div class="custom-password-header">
    <div class="custom-password-header__left">
      {{ section.settings.header_left_text }}
    </div>
    <div class="custom-password-header__center">
      {{ section.settings.header_center_text }}
    </div>
    <div class="custom-password-header__right">
      <a href="#password-form" id="trigger-password-modal">
        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-padlock" viewBox="0 0 20 20" width="16" height="16">
          <path fill-rule="evenodd" d="M14 8.5V6a4 4 0 10-8 0v2.5H4.5v10h11v-10H14zm-7-2.5a3 3 0 116 0V8.5H7V6zm-1.5 3.5h9v8h-9v-8z" fill="currentColor"/>
        </svg>
        {{ section.settings.header_right_text }}
      </a>
    </div>
  </div>

  <div class="custom-password-main">
    {% if section.settings.logo_image %}
      <img src="{{ section.settings.logo_image | image_url: width: 600 }}" alt="{{ section.settings.logo_image.alt | default: 'Logo' }}" class="custom-password-logo" loading="lazy">
    {% else %}
      <h1 class="custom-password-logo-text" style="font-size: 32px; font-weight: bold; text-transform: uppercase; margin-bottom: 40px;">
        {{ shop.name }}
      </h1>
    {% endif %}

    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="{{ section.settings.hero_image.alt | default: 'Hero Image' }}" class="custom-password-hero" loading="lazy">
    {% endif %}

    {% if section.settings.main_heading != blank %}
      <div class="custom-password-heading">
        {{ section.settings.main_heading }}
      </div>
    {% endif %}

    {% if section.settings.sub_heading != blank %}
      <div class="custom-password-subheading">
        {{ section.settings.sub_heading }}
      </div>
    {% endif %}

    {% if section.settings.html_embed != blank %}
      <div class="custom-password-embed">
        {{ section.settings.html_embed }}
      </div>
    {% endif %}
  </div>

  {% if section.settings.background_image %}
    <div class="custom-password-footer-bg" style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');"></div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var trigger = document.getElementById('trigger-password-modal');
    if (trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var dialog = document.querySelector('dialog-component dialog') || document.querySelector('dialog');
        if (dialog && typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
            console.error("Password dialog not found or dialog HTML5 element is not supported by this browser.");
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Custom Password Page",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "header_left_text",
      "label": "Header Left Text",
      "default": "PUBLIC EQUITY"
    },
    {
      "type": "text",
      "id": "header_center_text",
      "label": "Header Center Text",
      "default": "EQUITY ISSUED"
    },
    {
      "type": "text",
      "id": "header_right_text",
      "label": "Header Right Text",
      "default": "Enter using password"
    },
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Logo Max Width",
      "default": 200
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "range",
      "id": "hero_width",
      "min": 100,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Hero Max Width",
      "default": 400
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "DROPPING SATURDAY JULY 11TH — 11AM PST"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "BLACK HICKORY DOUBLE KNEE CAPRIS."
    },
    {
      "type": "html",
      "id": "html_embed",
      "label": "Omnisend Custom HTML Embed",
      "info": "Paste your Omnisend embed code here."
    },
    {
      "type": "header",
      "content": "Lower Section"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Lower Background Image",
      "info": "Image spanning the bottom of the page."
    }
  ],
  "presets": [
    {
      "name": "Custom Password Page"
    }
  ]
}
{% endschema %}
