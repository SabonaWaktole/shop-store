{% comment %} Customer Addresses — Premium Design {% endcomment %}

{{ 'account.css' | asset_url | stylesheet_tag }}

<div class="acct-page-bg">
  <div class="max-w-[1000px] mx-auto py-24 px-4 md:px-8">

    <!-- BREADCRUMBS -->
    <div class="acct-breadcrumbs acct-fade-in">
      <a href="{{ routes.account_url }}">Account</a>
      <span class="separator">›</span>
      <span class="current">Addresses</span>
    </div>

    <!-- HEADER -->
    <div class="acct-fade-in acct-fade-in-delay-1 mb-12">
      <h1 class="acct-page-title">Your Addresses</h1>
    </div>

    <!-- ADDRESS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12 acct-fade-in acct-fade-in-delay-2">
      
      <!-- FIRST CARD: Add New Address -->
      <div class="acct-address-card acct-address-card--add" onclick="toggleNewAddress()" id="add-address-trigger">
        <div class="add-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent, #8B5CF6);">
            <path d="M12 5v14M5 12h14"/>
          </svg>
        </div>
        <span class="text-sm font-medium" style="color: var(--color-secondary-text, #6B7280);">Add New Address</span>
      </div>

      <!-- Existing Addresses -->
      {% for address in customer.addresses %}
        <div class="acct-address-card flex flex-col">
          {% if address == customer.default_address %}
            <div>
              <span class="acct-badge acct-badge--default mb-3 inline-block">Default</span>
            </div>
          {% endif %}
          <div class="text-sm leading-relaxed mb-6" style="color: #737373;">
            {{ address | format_address }}
          </div>
          <div class="flex gap-3 mt-auto">
            <button type="button" class="acct-btn-secondary" style="padding: 8px 20px; font-size: 10px;" onclick="toggleEditAddress('{{ address.id }}')">Edit</button>
            <button type="button" class="acct-btn-danger" style="padding: 8px 20px; font-size: 10px;" onclick="if(confirm('Delete this address?')){Shopify.postLink('{{ routes.account_addresses_url }}/{{ address.id }}',{'parameters':{'_method':'delete'}})}">Delete</button>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- NEW ADDRESS FORM -->
    <div id="new-address-form" class="acct-slide-panel acct-glass-card mb-12">
      <h2 class="acct-section-label">New Address</h2>
      {% form 'customer_address', customer.new_address %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
          <div class="acct-input-group">
            <label for="address_first_name_new">First Name</label>
            <div class="acct-input-underline">
              <input type="text" id="address_first_name_new" name="address[first_name]" autocomplete="given-name" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group">
            <label for="address_last_name_new">Last Name</label>
            <div class="acct-input-underline">
              <input type="text" id="address_last_name_new" name="address[last_name]" autocomplete="family-name" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group md:col-span-2">
            <label for="address_company_new">Company</label>
            <div class="acct-input-underline">
              <input type="text" id="address_company_new" name="address[company]" autocomplete="organization" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group md:col-span-2">
            <label for="address_address1_new">Address</label>
            <div class="acct-input-underline">
              <input type="text" id="address_address1_new" name="address[address1]" autocomplete="address-line1" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group md:col-span-2">
            <label for="address_address2_new">Apartment, Suite, Etc.</label>
            <div class="acct-input-underline">
              <input type="text" id="address_address2_new" name="address[address2]" autocomplete="address-line2" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group">
            <label for="address_city_new">City</label>
            <div class="acct-input-underline">
              <input type="text" id="address_city_new" name="address[city]" autocomplete="address-level2" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group">
            <label for="address_country_new">Country/Region</label>
            <div class="acct-input-underline">
              <select id="address_country_new" name="address[country]" data-default="{{ form.country }}" autocomplete="country" class="acct-select">
                {{ all_country_option_tags }}
              </select>
            </div>
          </div>
          <div class="acct-input-group">
            <label for="address_province_new">Province/State</label>
            <div class="acct-input-underline">
              <select id="address_province_new" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1" class="acct-select">
              </select>
            </div>
          </div>
          <div class="acct-input-group">
            <label for="address_zip_new">Postal/Zip Code</label>
            <div class="acct-input-underline">
              <input type="text" id="address_zip_new" name="address[zip]" autocomplete="postal-code" class="acct-input">
            </div>
          </div>
          <div class="acct-input-group md:col-span-2">
            <label for="address_phone_new">Phone</label>
            <div class="acct-input-underline">
              <input type="tel" id="address_phone_new" name="address[phone]" autocomplete="tel" class="acct-input">
            </div>
          </div>
          <div class="md:col-span-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="address[default]" value="1" class="acct-checkbox">
              <span class="text-xs tracking-widest uppercase" style="color: #737373;">Set as default address</span>
            </label>
          </div>
        </div>
        <div class="flex gap-4 mt-8">
          <button type="submit" class="acct-btn-primary flex-1"><span>Add Address</span></button>
          <button type="button" class="acct-btn-secondary" onclick="toggleNewAddress()">Cancel</button>
        </div>
      {% endform %}
    </div>

    <!-- EDIT ADDRESS FORMS -->
    {% for address in customer.addresses %}
      <div id="edit-address-{{ address.id }}" class="acct-slide-panel acct-glass-card col-span-full">
        <h2 class="acct-section-label">Edit Address</h2>
        {% form 'customer_address', address %}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
            <div class="acct-input-group">
              <label for="address_first_name_{{ address.id }}">First Name</label>
              <div class="acct-input-underline">
                <input type="text" id="address_first_name_{{ address.id }}" name="address[first_name]" value="{{ form.first_name }}" autocomplete="given-name" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group">
              <label for="address_last_name_{{ address.id }}">Last Name</label>
              <div class="acct-input-underline">
                <input type="text" id="address_last_name_{{ address.id }}" name="address[last_name]" value="{{ form.last_name }}" autocomplete="family-name" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group md:col-span-2">
              <label for="address_company_{{ address.id }}">Company</label>
              <div class="acct-input-underline">
                <input type="text" id="address_company_{{ address.id }}" name="address[company]" value="{{ form.company }}" autocomplete="organization" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group md:col-span-2">
              <label for="address_address1_{{ address.id }}">Address</label>
              <div class="acct-input-underline">
                <input type="text" id="address_address1_{{ address.id }}" name="address[address1]" value="{{ form.address1 }}" autocomplete="address-line1" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group md:col-span-2">
              <label for="address_address2_{{ address.id }}">Apartment, Suite, Etc.</label>
              <div class="acct-input-underline">
                <input type="text" id="address_address2_{{ address.id }}" name="address[address2]" value="{{ form.address2 }}" autocomplete="address-line2" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group">
              <label for="address_city_{{ address.id }}">City</label>
              <div class="acct-input-underline">
                <input type="text" id="address_city_{{ address.id }}" name="address[city]" value="{{ form.city }}" autocomplete="address-level2" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group">
              <label for="address_country_{{ address.id }}">Country/Region</label>
              <div class="acct-input-underline">
                <select id="address_country_{{ address.id }}" name="address[country]" data-default="{{ form.country }}" autocomplete="country" class="acct-select">
                  {{ all_country_option_tags }}
                </select>
              </div>
            </div>
            <div class="acct-input-group">
              <label for="address_province_{{ address.id }}">Province/State</label>
              <div class="acct-input-underline">
                <select id="address_province_{{ address.id }}" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1" class="acct-select">
                </select>
              </div>
            </div>
            <div class="acct-input-group">
              <label for="address_zip_{{ address.id }}">Postal/Zip Code</label>
              <div class="acct-input-underline">
                <input type="text" id="address_zip_{{ address.id }}" name="address[zip]" value="{{ form.zip }}" autocomplete="postal-code" class="acct-input">
              </div>
            </div>
            <div class="acct-input-group md:col-span-2">
              <label for="address_phone_{{ address.id }}">Phone</label>
              <div class="acct-input-underline">
                <input type="tel" id="address_phone_{{ address.id }}" name="address[phone]" value="{{ form.phone }}" autocomplete="tel" class="acct-input">
              </div>
            </div>
            <div class="md:col-span-2">
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" name="address[default]" value="1" class="acct-checkbox" {% if address == customer.default_address %}checked{% endif %}>
                <span class="text-xs tracking-widest uppercase" style="color: #737373;">Set as default address</span>
              </label>
            </div>
          </div>
          <div class="flex gap-4 mt-8">
            <button type="submit" class="acct-btn-primary flex-1"><span>Update Address</span></button>
            <button type="button" class="acct-btn-secondary" onclick="toggleEditAddress('{{ address.id }}')">Cancel</button>
          </div>
        {% endform %}
      </div>
    {% endfor %}

  </div>
</div>

<script>
  function toggleNewAddress() {
    const form = document.getElementById('new-address-form');
    const trigger = document.getElementById('add-address-trigger');
    form.classList.toggle('is-open');
    if (form.classList.contains('is-open')) {
      trigger.style.display = 'none';
    } else {
      trigger.style.display = 'flex';
    }
  }

  function toggleEditAddress(id) {
    const form = document.getElementById('edit-address-' + id);
    form.classList.toggle('is-open');
  }

  // Initialize Shopify country/province selectors
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof Shopify !== 'undefined' && Shopify.CountryProvinceSelector) {
      new Shopify.CountryProvinceSelector(
        'address_country_new',
        'address_province_new',
        { hideElement: 'address_province_new_container' }
      );

      {% for address in customer.addresses %}
        new Shopify.CountryProvinceSelector(
          'address_country_{{ address.id }}',
          'address_province_{{ address.id }}',
          { hideElement: 'address_province_{{ address.id }}_container' }
        );
      {% endfor %}
    }
  });
</script>
