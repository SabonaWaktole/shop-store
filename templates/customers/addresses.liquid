{% comment %}
  Customer Addresses
  Manage shipping addresses: list, add, edit, delete
{% endcomment %}

<div class="max-w-[800px] mx-auto py-24 px-4 md:px-8">

  <!-- Back Link -->
  <a href="{{ routes.account_url }}" class="inline-block mb-12 text-xs tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors">
    &larr; Back to Account
  </a>

  <!-- Heading -->
  <h1 class="text-2xl font-semibold tracking-tighter uppercase text-foreground mb-16">Addresses</h1>

  <!-- Add New Address Toggle -->
  <button
    type="button"
    onclick="document.getElementById('new-address-form').classList.toggle('hidden')"
    class="w-full py-4 bg-primary text-primary-foreground text-xs tracking-widest uppercase hover:opacity-80 transition-opacity mb-16"
  >
    Add New Address
  </button>

  <!-- New Address Form -->
  <div id="new-address-form" class="hidden mb-20">
    <h2 class="text-xs tracking-widest uppercase text-muted-foreground mb-8">New Address</h2>

    {% form 'customer_address', customer.new_address %}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
        <!-- First Name -->
        <div>
          <label for="address_first_name_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            First Name
          </label>
          <input
            type="text"
            id="address_first_name_new"
            name="address[first_name]"
            autocomplete="given-name"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Last Name -->
        <div>
          <label for="address_last_name_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Last Name
          </label>
          <input
            type="text"
            id="address_last_name_new"
            name="address[last_name]"
            autocomplete="family-name"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Company -->
        <div class="md:col-span-2">
          <label for="address_company_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Company
          </label>
          <input
            type="text"
            id="address_company_new"
            name="address[company]"
            autocomplete="organization"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Address 1 -->
        <div class="md:col-span-2">
          <label for="address_address1_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Address
          </label>
          <input
            type="text"
            id="address_address1_new"
            name="address[address1]"
            autocomplete="address-line1"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Address 2 -->
        <div class="md:col-span-2">
          <label for="address_address2_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Apartment, Suite, Etc.
          </label>
          <input
            type="text"
            id="address_address2_new"
            name="address[address2]"
            autocomplete="address-line2"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- City -->
        <div>
          <label for="address_city_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            City
          </label>
          <input
            type="text"
            id="address_city_new"
            name="address[city]"
            autocomplete="address-level2"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Country -->
        <div>
          <label for="address_country_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Country / Region
          </label>
          <select
            id="address_country_new"
            name="address[country]"
            data-default="{{ form.country }}"
            autocomplete="country"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground focus:outline-none focus:border-foreground transition-colors appearance-none"
          >
            {{ all_country_option_tags }}
          </select>
        </div>

        <!-- Province -->
        <div>
          <label for="address_province_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Province / State
          </label>
          <select
            id="address_province_new"
            name="address[province]"
            data-default="{{ form.province }}"
            autocomplete="address-level1"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground focus:outline-none focus:border-foreground transition-colors appearance-none"
          >
          </select>
        </div>

        <!-- Zip -->
        <div>
          <label for="address_zip_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Postal / Zip Code
          </label>
          <input
            type="text"
            id="address_zip_new"
            name="address[zip]"
            autocomplete="postal-code"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Phone -->
        <div class="md:col-span-2">
          <label for="address_phone_new" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
            Phone
          </label>
          <input
            type="tel"
            id="address_phone_new"
            name="address[phone]"
            autocomplete="tel"
            class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
        </div>

        <!-- Default Address -->
        <div class="md:col-span-2">
          <label class="flex items-center gap-3 cursor-pointer">
            <input
              type="checkbox"
              name="address[default]"
              value="1"
              class="w-4 h-4 border border-border text-foreground focus:ring-0 focus:ring-offset-0"
            />
            <span class="text-xs tracking-widest uppercase text-muted-foreground">Set as default address</span>
          </label>
        </div>
      </div>

      <!-- Submit -->
      <div class="flex gap-4 mt-10">
        <button
          type="submit"
          class="flex-1 py-4 bg-primary text-primary-foreground text-xs tracking-widest uppercase hover:opacity-80 transition-opacity"
        >
          Add Address
        </button>
        <button
          type="button"
          onclick="document.getElementById('new-address-form').classList.add('hidden')"
          class="py-4 px-8 border border-border text-xs tracking-widest uppercase text-foreground hover:bg-muted transition-colors"
        >
          Cancel
        </button>
      </div>
    {% endform %}
  </div>

  <!-- Existing Addresses -->
  {% if customer.addresses.size > 0 %}
    <div class="space-y-12">
      {% for address in customer.addresses %}
        <div class="border-b border-border pb-12">

          <!-- Address Display -->
          <div id="address-display-{{ address.id }}">
            {% if address == customer.default_address %}
              <span class="inline-block text-xs tracking-widest uppercase text-muted-foreground mb-4">Default</span>
            {% endif %}

            <div class="text-sm text-muted-foreground leading-relaxed mb-6">
              {{ address | format_address }}
            </div>

            <div class="flex gap-4">
              <button
                type="button"
                onclick="document.getElementById('edit-address-{{ address.id }}').classList.remove('hidden'); document.getElementById('address-display-{{ address.id }}').classList.add('hidden');"
                class="text-xs tracking-widest uppercase text-foreground underline underline-offset-4 hover:text-muted-foreground transition-colors"
              >
                Edit
              </button>
              <button
                type="button"
                onclick="if(confirm('Are you sure you want to delete this address?')) { Shopify.postLink('{{ routes.account_addresses_url }}/{{ address.id }}', {'parameters': {'_method': 'delete'}}) }"
                class="text-xs tracking-widest uppercase text-error underline underline-offset-4 hover:opacity-70 transition-opacity"
              >
                Delete
              </button>
            </div>
          </div>

          <!-- Edit Address Form (hidden by default) -->
          <div id="edit-address-{{ address.id }}" class="hidden">
            <h3 class="text-xs tracking-widest uppercase text-muted-foreground mb-8">Edit Address</h3>

            {% form 'customer_address', address %}
              <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                <!-- First Name -->
                <div>
                  <label for="address_first_name_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    First Name
                  </label>
                  <input
                    type="text"
                    id="address_first_name_{{ address.id }}"
                    name="address[first_name]"
                    value="{{ form.first_name }}"
                    autocomplete="given-name"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Last Name -->
                <div>
                  <label for="address_last_name_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Last Name
                  </label>
                  <input
                    type="text"
                    id="address_last_name_{{ address.id }}"
                    name="address[last_name]"
                    value="{{ form.last_name }}"
                    autocomplete="family-name"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Company -->
                <div class="md:col-span-2">
                  <label for="address_company_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Company
                  </label>
                  <input
                    type="text"
                    id="address_company_{{ address.id }}"
                    name="address[company]"
                    value="{{ form.company }}"
                    autocomplete="organization"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Address 1 -->
                <div class="md:col-span-2">
                  <label for="address_address1_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Address
                  </label>
                  <input
                    type="text"
                    id="address_address1_{{ address.id }}"
                    name="address[address1]"
                    value="{{ form.address1 }}"
                    autocomplete="address-line1"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Address 2 -->
                <div class="md:col-span-2">
                  <label for="address_address2_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Apartment, Suite, Etc.
                  </label>
                  <input
                    type="text"
                    id="address_address2_{{ address.id }}"
                    name="address[address2]"
                    value="{{ form.address2 }}"
                    autocomplete="address-line2"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- City -->
                <div>
                  <label for="address_city_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    City
                  </label>
                  <input
                    type="text"
                    id="address_city_{{ address.id }}"
                    name="address[city]"
                    value="{{ form.city }}"
                    autocomplete="address-level2"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Country -->
                <div>
                  <label for="address_country_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Country / Region
                  </label>
                  <select
                    id="address_country_{{ address.id }}"
                    name="address[country]"
                    data-default="{{ form.country }}"
                    autocomplete="country"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground focus:outline-none focus:border-foreground transition-colors appearance-none"
                  >
                    {{ all_country_option_tags }}
                  </select>
                </div>

                <!-- Province -->
                <div>
                  <label for="address_province_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Province / State
                  </label>
                  <select
                    id="address_province_{{ address.id }}"
                    name="address[province]"
                    data-default="{{ form.province }}"
                    autocomplete="address-level1"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground focus:outline-none focus:border-foreground transition-colors appearance-none"
                  >
                  </select>
                </div>

                <!-- Zip -->
                <div>
                  <label for="address_zip_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Postal / Zip Code
                  </label>
                  <input
                    type="text"
                    id="address_zip_{{ address.id }}"
                    name="address[zip]"
                    value="{{ form.zip }}"
                    autocomplete="postal-code"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Phone -->
                <div class="md:col-span-2">
                  <label for="address_phone_{{ address.id }}" class="block text-xs tracking-widest uppercase text-muted-foreground mb-2">
                    Phone
                  </label>
                  <input
                    type="tel"
                    id="address_phone_{{ address.id }}"
                    name="address[phone]"
                    value="{{ form.phone }}"
                    autocomplete="tel"
                    class="w-full bg-transparent border-0 border-b border-border py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
                  />
                </div>

                <!-- Default Address -->
                <div class="md:col-span-2">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      name="address[default]"
                      value="1"
                      {% if address == customer.default_address %}checked{% endif %}
                      class="w-4 h-4 border border-border text-foreground focus:ring-0 focus:ring-offset-0"
                    />
                    <span class="text-xs tracking-widest uppercase text-muted-foreground">Set as default address</span>
                  </label>
                </div>
              </div>

              <!-- Submit -->
              <div class="flex gap-4 mt-10">
                <button
                  type="submit"
                  class="flex-1 py-4 bg-primary text-primary-foreground text-xs tracking-widest uppercase hover:opacity-80 transition-opacity"
                >
                  Update Address
                </button>
                <button
                  type="button"
                  onclick="document.getElementById('edit-address-{{ address.id }}').classList.add('hidden'); document.getElementById('address-display-{{ address.id }}').classList.remove('hidden');"
                  class="py-4 px-8 border border-border text-xs tracking-widest uppercase text-foreground hover:bg-muted transition-colors"
                >
                  Cancel
                </button>
              </div>
            {% endform %}
          </div>

        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-sm text-muted-foreground">No addresses saved yet.</p>
  {% endif %}

</div>

<script>
  // Initialize Shopify country/province selectors
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof Shopify !== 'undefined' && Shopify.CountryProvinceSelector) {
      // New address form
      new Shopify.CountryProvinceSelector(
        'address_country_new',
        'address_province_new',
        { hideElement: 'address_province_new_container' }
      );

      // Edit address forms
      {% for address in customer.addresses %}
        new Shopify.CountryProvinceSelector(
          'address_country_{{ address.id }}',
          'address_province_{{ address.id }}',
          { hideElement: 'address_province_{{ address.id }}_container' }
        );
      {% endfor %}
    }
  });
</script>
