{% comment %}
  Customer Order Detail
  Shows individual order information, line items, and shipping address
{% endcomment %}

<div class="max-w-[1200px] mx-auto py-24 px-4 md:px-8">

  <!-- Back Link -->
  <a href="{{ routes.account_url }}" class="inline-block mb-12 text-xs tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors">
    &larr; Back to Account
  </a>

  <!-- Order Heading -->
  <h1 class="text-2xl font-semibold tracking-tighter uppercase text-foreground mb-4">Order {{ order.name }}</h1>

  <!-- Order Meta -->
  <div class="flex flex-wrap gap-x-8 gap-y-2 mb-16 text-sm text-muted-foreground">
    <span>{{ order.created_at | date: "%B %d, %Y" }}</span>
    <span class="text-xs tracking-widest uppercase">{{ order.fulfillment_status_label }}</span>
    <span class="text-xs tracking-widest uppercase">{{ order.financial_status_label }}</span>
  </div>

  <!-- Line Items -->
  <section class="mb-16">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-3 font-normal text-xs tracking-widest uppercase text-muted-foreground">Product</th>
            <th class="text-left py-3 font-normal text-xs tracking-widest uppercase text-muted-foreground hidden md:table-cell">SKU</th>
            <th class="text-right py-3 font-normal text-xs tracking-widest uppercase text-muted-foreground">Price</th>
            <th class="text-center py-3 font-normal text-xs tracking-widest uppercase text-muted-foreground">Qty</th>
            <th class="text-right py-3 font-normal text-xs tracking-widest uppercase text-muted-foreground">Total</th>
          </tr>
        </thead>
        <tbody>
          {% for line_item in order.line_items %}
            <tr class="border-b border-border">
              <td class="py-4">
                {% if line_item.url %}
                  <a href="{{ line_item.url }}" class="text-foreground underline underline-offset-4 hover:text-muted-foreground transition-colors">
                    {{ line_item.title }}
                  </a>
                {% else %}
                  <span class="text-foreground">{{ line_item.title }}</span>
                {% endif %}

                {% if line_item.variant.title != 'Default Title' %}
                  <span class="block text-xs text-muted-foreground mt-1">{{ line_item.variant.title }}</span>
                {% endif %}

                {% if line_item.fulfillment %}
                  <span class="block text-xs text-muted-foreground mt-1">
                    Fulfilled {{ line_item.fulfillment.created_at | date: "%B %d, %Y" }}
                    {% if line_item.fulfillment.tracking_url %}
                      &middot;
                      <a href="{{ line_item.fulfillment.tracking_url }}" class="underline underline-offset-4 hover:text-foreground transition-colors" target="_blank" rel="noopener">
                        Track
                      </a>
                    {% endif %}
                  </span>
                {% endif %}
              </td>
              <td class="py-4 text-muted-foreground hidden md:table-cell">
                {{ line_item.sku | default: '—' }}
              </td>
              <td class="py-4 text-right">
                {{ line_item.original_price | money }}
              </td>
              <td class="py-4 text-center">
                {{ line_item.quantity }}
              </td>
              <td class="py-4 text-right">
                {{ line_item.final_line_price | money }}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Order Summary & Shipping Address -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

    <!-- Order Summary -->
    <div class="md:order-2">
      <h2 class="text-xs tracking-widest uppercase text-muted-foreground mb-8">Order Summary</h2>

      <div class="space-y-3 text-sm">
        <div class="flex justify-between">
          <span class="text-muted-foreground">Subtotal</span>
          <span class="text-foreground">{{ order.line_items_subtotal_price | money }}</span>
        </div>

        {% for shipping_method in order.shipping_methods %}
          <div class="flex justify-between">
            <span class="text-muted-foreground">Shipping ({{ shipping_method.title }})</span>
            <span class="text-foreground">{{ shipping_method.price | money }}</span>
          </div>
        {% endfor %}

        {% for tax_line in order.tax_lines %}
          <div class="flex justify-between">
            <span class="text-muted-foreground">Tax ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)</span>
            <span class="text-foreground">{{ tax_line.price | money }}</span>
          </div>
        {% endfor %}

        {% if order.total_discounts > 0 %}
          <div class="flex justify-between">
            <span class="text-muted-foreground">Discounts</span>
            <span class="text-foreground">-{{ order.total_discounts | money }}</span>
          </div>
        {% endif %}

        <div class="flex justify-between pt-4 border-t border-border">
          <span class="text-foreground font-semibold">Total</span>
          <span class="text-foreground font-semibold">{{ order.total_price | money }}</span>
        </div>
      </div>
    </div>

    <!-- Shipping Address -->
    <div class="md:order-1">
      <h2 class="text-xs tracking-widest uppercase text-muted-foreground mb-8">Shipping Address</h2>

      {% if order.shipping_address %}
        <div class="text-sm text-muted-foreground leading-relaxed">
          {{ order.shipping_address | format_address }}
        </div>
      {% else %}
        <p class="text-sm text-muted-foreground">No shipping address provided.</p>
      {% endif %}
    </div>

  </div>

</div>
