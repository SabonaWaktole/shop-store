{% comment %} Customer Order Detail — Premium Design {% endcomment %}

{{ 'account.css' | asset_url | stylesheet_tag }}

<div class="acct-page-bg">
  <div class="max-w-[1200px] mx-auto py-24 px-4 md:px-8">

    <nav class="acct-breadcrumbs acct-fade-in">
      <a href="{{ routes.account_url }}">Account</a>
      <span class="separator">›</span>
      <span class="current">Order {{ order.name }}</span>
    </nav>

    <div class="acct-fade-in acct-fade-in-delay-1 mb-8">
      <h1 class="acct-page-title mb-4">Order {{ order.name }}</h1>

      <div class="flex flex-wrap items-center gap-4 mb-6">
        <span class="text-sm" style="color: #737373;">{{ order.created_at | date: "%B %d, %Y" }}</span>

        {%- capture fulfillment_class -%}
          {%- if order.fulfillment_status == 'fulfilled' -%}acct-badge--fulfilled
          {%- elsif order.fulfillment_status == 'partial' -%}acct-badge--partial
          {%- else -%}acct-badge--unfulfilled{%- endif -%}
        {%- endcapture -%}
        <span class="acct-badge {{ fulfillment_class | strip }}"><span class="acct-badge-dot"></span>{{ order.fulfillment_status_label }}</span>

        {%- capture financial_class -%}
          {%- if order.financial_status == 'paid' -%}acct-badge--paid
          {%- elsif order.financial_status == 'refunded' or order.financial_status == 'partially_refunded' -%}acct-badge--refunded
          {%- else -%}acct-badge--pending{%- endif -%}
        {%- endcapture -%}
        <span class="acct-badge {{ financial_class | strip }}"><span class="acct-badge-dot"></span>{{ order.financial_status_label }}</span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <div class="lg:col-span-2 acct-fade-in acct-fade-in-delay-2">
        <h2 class="acct-section-label">Items</h2>

        {% for line_item in order.line_items %}
          <div class="acct-line-item">
            <div class="acct-line-item-image">
              {% if line_item.image %}
                <img src="{{ line_item.image | image_url: width: 200 }}" alt="{{ line_item.title | escape }}" loading="lazy">
              {% else %}
                <div class="w-full h-full flex items-center justify-center text-xs" style="color: #a3a3a3;">No image</div>
              {% endif %}
            </div>

            <div class="flex-1 min-w-0">
              {% if line_item.url %}
                <a href="{{ line_item.url }}" class="acct-link" style="font-size: 14px; font-weight: 500;">{{ line_item.title }}</a>
              {% else %}
                <span style="font-size: 14px; font-weight: 500;">{{ line_item.title }}</span>
              {% endif %}

              {% if line_item.variant.title != 'Default Title' %}
                <div class="text-xs" style="color: #737373;">{{ line_item.variant.title }}</div>
              {% endif %}

              {% if line_item.fulfillment %}
                <div class="text-xs" style="color: #737373;">
                  Fulfilled {{ line_item.fulfillment.created_at | date: "%B %d, %Y" }}
                  {% if line_item.fulfillment.tracking_url %}
                    <a href="{{ line_item.fulfillment.tracking_url }}" class="acct-track-btn" target="_blank" rel="noopener">Track shipment</a>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            <div class="text-right flex-shrink-0">
              <div class="text-sm">{{ line_item.original_price | money }}</div>
              <div class="text-xs" style="color: #737373;">Qty: {{ line_item.quantity }}</div>
              <div class="text-sm font-medium">{{ line_item.final_line_price | money }}</div>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="acct-fade-in acct-fade-in-delay-3">
        <div class="acct-summary-card mb-8">
          <h2 class="acct-section-label">Summary</h2>

          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span style="color: #737373;">Subtotal</span>
              <span>{{ order.line_items_subtotal_price | money }}</span>
            </div>

            {% for shipping_method in order.shipping_methods %}
              <div class="flex justify-between">
                <span style="color: #737373;">{{ shipping_method.title }}</span>
                <span>{{ shipping_method.price | money }}</span>
              </div>
            {% endfor %}

            {% for tax_line in order.tax_lines %}
              <div class="flex justify-between">
                <span style="color: #737373;">{{ tax_line.title }} ({{ tax_line.rate | times: 100 }}%)</span>
                <span>{{ tax_line.price | money }}</span>
              </div>
            {% endfor %}

            {% if order.total_discounts > 0 %}
              <div class="flex justify-between">
                <span style="color: #737373;">Discounts</span>
                <span>-{{ order.total_discounts | money }}</span>
              </div>
            {% endif %}

            <div class="flex justify-between border-t border-border pt-4 mt-4">
              <span class="font-semibold">Total</span>
              <span class="font-semibold">{{ order.total_price | money }}</span>
            </div>
          </div>
        </div>

        <div class="acct-summary-card">
          <h2 class="acct-section-label">Shipping Address</h2>

          {% if order.shipping_address %}
            <div class="text-sm leading-relaxed" style="color: #737373;">
              {{ order.shipping_address | format_address }}
            </div>
          {% else %}
            <p class="text-sm" style="color: #737373;">No shipping address provided.</p>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</div>
