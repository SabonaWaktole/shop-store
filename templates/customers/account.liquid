{% comment %}
  Customer Account Dashboard — Premium Design
  Sidebar navigation, profile card, order history cards
{% endcomment %}

{{ 'account.css' | asset_url | stylesheet_tag }}

<div class="acct-page-bg">
  <div class="max-w-[1200px] mx-auto py-20 px-4 md:px-8">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- ======== SIDEBAR ======== -->
      <aside class="acct-sidebar acct-fade-in">
        <!-- Profile mini-card -->
        <div class="flex items-center gap-4 mb-8 px-4">
          <div class="acct-avatar--sm">
            {{ customer.first_name | slice: 0 }}{{ customer.last_name | slice: 0 }}
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold truncate" style="color: var(--color-foreground);">{{ customer.name }}</p>
            <p class="text-xs truncate" style="color: #737373;">{{ customer.email }}</p>
          </div>
        </div>

        <nav>
          <ul class="acct-sidebar-nav">
            <li>
              <a href="{{ routes.account_url }}" class="active">
                <span class="nav-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </span>
                Overview
              </a>
            </li>
            <li>
              <a href="{{ routes.account_url }}#orders">
                <span class="nav-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="2" y="3" width="20" height="18" rx="2"/>
                    <path d="M8 7h8M8 11h5"/>
                  </svg>
                </span>
                Orders
              </a>
            </li>
            <li>
              <a href="{{ routes.account_addresses_url }}">
                <span class="nav-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 1 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                Addresses
              </a>
            </li>

            <li class="acct-sidebar-divider" role="separator"></li>

            <li>
              <a href="/pages/wishlist">
                <span class="nav-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                </span>
                Wishlist
              </a>
            </li>
            <li>
              <a href="/pages/rewards">
                <span class="nav-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </span>
                Rewards
              </a>
            </li>

            <li class="acct-sidebar-divider" role="separator"></li>

            <li>
              <a href="{{ routes.account_logout_url }}" style="color: var(--color-error, #EF4444);">
                <span class="nav-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                  </svg>
                </span>
                Log Out
              </a>
            </li>
          </ul>
        </nav>
      </aside>

      <!-- ======== MAIN CONTENT ======== -->
      <div class="flex-1 min-w-0">

        <!-- Profile Card -->
        <div class="acct-glass-card p-8 mb-10 acct-fade-in acct-fade-in-delay-1">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
            <div class="acct-avatar">
              {{ customer.first_name | slice: 0 }}{{ customer.last_name | slice: 0 }}
            </div>
            <div class="flex-1 min-w-0">
              <h1 class="acct-page-title mb-1">{{ customer.name }}</h1>
              <p class="text-sm mb-3" style="color: #737373;">{{ customer.email }}</p>
              {% if customer.default_address %}
                <div class="flex items-start gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#737373" stroke-width="1.5" class="mt-0.5 flex-shrink-0">
                    <path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 1 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <span class="text-xs" style="color: #737373;">
                    {{ customer.default_address.city }}{% if customer.default_address.province_code %}, {{ customer.default_address.province_code }}{% endif %}{% if customer.default_address.country %}, {{ customer.default_address.country }}{% endif %}
                  </span>
                </div>
              {% endif %}
            </div>
            <div class="flex-shrink-0">
              <a href="{{ routes.account_addresses_url }}" class="acct-btn-secondary" style="padding: 10px 20px; font-size: 10px;">
                Manage Addresses
              </a>
            </div>
          </div>
        </div>

        <!-- Order History -->
        <section id="orders" class="acct-fade-in acct-fade-in-delay-2">
          <div class="flex items-center justify-between mb-6">
            <h2 class="acct-section-label mb-0">Order History</h2>
            {% if customer.orders.size > 0 %}
              <span class="text-xs" style="color: #a3a3a3;">{{ customer.orders.size }} order{{ customer.orders.size | pluralize: '', 's' }}</span>
            {% endif %}
          </div>

          {% if customer.orders.size == 0 %}
            <div class="acct-empty-state">
              <div class="acct-empty-state-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5">
                  <rect x="2" y="3" width="20" height="18" rx="2"/>
                  <path d="M8 7h8M8 11h5"/>
                </svg>
              </div>
              <p class="text-sm mb-4" style="color: #737373;">You haven't placed any orders yet.</p>
              <a href="/collections/all" class="acct-btn-primary inline-block" style="width: auto; padding: 12px 32px;">
                <span>Start Shopping</span>
              </a>
            </div>
          {% else %}
            {% paginate customer.orders by 5 %}
              <div class="space-y-4">
                {% for order in customer.orders %}
                  <a href="{{ order.customer_url }}" class="acct-order-card block group">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                      <!-- Left: Order Info -->
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-2">
                          <span class="text-sm font-semibold" style="color: var(--color-foreground);">{{ order.name }}</span>
                          {%- capture fulfillment_class -%}
                            {%- if order.fulfillment_status == 'fulfilled' -%}acct-badge--fulfilled
                            {%- elsif order.fulfillment_status == 'partial' -%}acct-badge--partial
                            {%- else -%}acct-badge--unfulfilled{%- endif -%}
                          {%- endcapture -%}
                          <span class="acct-badge {{ fulfillment_class | strip }}">
                            <span class="acct-badge-dot"></span>
                            {{ order.fulfillment_status_label }}
                          </span>
                        </div>
                        <p class="text-xs" style="color: #737373;">{{ order.created_at | date: "%B %d, %Y" }}</p>
                      </div>

                      <!-- Right: Total + Arrow -->
                      <div class="flex items-center gap-4 flex-shrink-0">
                        <span class="text-sm font-semibold" style="color: var(--color-foreground);">{{ order.total_price | money }}</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" class="group-hover:translate-x-1 transition-transform duration-200">
                          <path d="M9 18l6-6-6-6"/>
                        </svg>
                      </div>
                    </div>
                  </a>
                {% endfor %}
              </div>

              <!-- Pagination -->
              {% if paginate.pages > 1 %}
                <div class="flex items-center justify-center gap-6 mt-10">
                  {% if paginate.previous %}
                    <a href="{{ paginate.previous.url }}" class="acct-link flex items-center gap-2">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M15 18l-6-6 6-6"/>
                      </svg>
                      Previous
                    </a>
                  {% endif %}

                  <span class="text-xs" style="color: #a3a3a3;">
                    Page {{ paginate.current_page }} of {{ paginate.pages }}
                  </span>

                  {% if paginate.next %}
                    <a href="{{ paginate.next.url }}" class="acct-link flex items-center gap-2">
                      Next
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M9 18l6-6-6-6"/>
                      </svg>
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            {% endpaginate %}
          {% endif %}
        </section>

        <!-- Account Details -->
        <section class="mt-16 acct-fade-in acct-fade-in-delay-3">
          <h2 class="acct-section-label">Account Details</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Customer Info Card -->
            <div class="acct-glass-card p-6">
              <div class="flex items-center gap-3 mb-4">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#737373" stroke-width="1.5">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="text-xs font-semibold uppercase tracking-widest" style="color: #737373;">Personal Info</span>
              </div>
              <p class="text-sm font-medium mb-1" style="color: var(--color-foreground);">{{ customer.name }}</p>
              <p class="text-sm" style="color: #737373;">{{ customer.email }}</p>
              {% if customer.phone %}
                <p class="text-sm mt-1" style="color: #737373;">{{ customer.phone }}</p>
              {% endif %}
            </div>

            <!-- Default Address Card -->
            <div class="acct-glass-card p-6">
              <div class="flex items-center gap-3 mb-4">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#737373" stroke-width="1.5">
                  <path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 1 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="text-xs font-semibold uppercase tracking-widest" style="color: #737373;">Default Address</span>
              </div>
              {% if customer.default_address %}
                <div class="text-sm leading-relaxed" style="color: #737373;">
                  {{ customer.default_address | format_address }}
                </div>
              {% else %}
                <p class="text-sm" style="color: #a3a3a3;">No default address set.</p>
              {% endif %}
              <a href="{{ routes.account_addresses_url }}" class="acct-link inline-block mt-4 text-xs">Manage Addresses</a>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>
</div>
