{% layout 'theme' %}

{{ 'account.css' | asset_url | stylesheet_tag }}

<div class="acct-page-bg">
  <div class="acct-glass-card acct-glass-card--form acct-fade-in" style="max-width:480px;margin-left:auto;margin-right:auto;padding-top:6rem;padding-bottom:6rem;padding-left:1.5rem;padding-right:1.5rem;">

    <!-- ── LOGIN FORM ── -->
    <div id="login-form">
      <h1 class="acct-page-title text-center mb-2">Welcome Back</h1>
      <p class="text-sm text-center mb-10" style="color:#737373;">Sign in to your account</p>

      {%- form 'customer_login' -%}
        {%- if form.errors -%}
          <div class="acct-alert acct-alert--error">
            <svg class="acct-alert-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="acct-input-group">
          <div class="acct-input-underline">
            <label for="customer-email">Email</label>
            <input
              class="acct-input"
              type="email"
              id="customer-email"
              name="customer[email]"
              autocomplete="email"
              required
            >
          </div>
        </div>

        <div class="acct-input-group">
          <div class="acct-input-underline">
            <label for="customer-password">Password</label>
            <input
              class="acct-input"
              type="password"
              id="customer-password"
              name="customer[password]"
              autocomplete="current-password"
              required
            >
          </div>
        </div>

        <button type="submit" class="acct-btn-primary"><span>Sign In</span></button>
      {%- endform -%}

      <div class="acct-divider"><span>or</span></div>

      <div class="flex flex-col items-center gap-4">
        <button class="acct-link" onclick="toggleRecovery(true)">Forgot your password?</button>
        <a class="acct-link" href="{{ routes.account_register_url }}">Create account</a>
      </div>
    </div>

    <!-- ── RECOVER PASSWORD FORM ── -->
    <div id="recover-form" class="hidden">
      <h1 class="acct-page-title text-center mb-4">Reset Password</h1>
      <p class="text-sm text-center mb-10" style="color:#737373;">We will send you an email to reset your password.</p>

      {%- form 'recover_customer_password' -%}
        {%- if form.errors -%}
          <div class="acct-alert acct-alert--error">
            <svg class="acct-alert-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div class="acct-alert acct-alert--success">
            <svg class="acct-alert-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            We've sent you an email with a link to update your password.
          </div>
        {%- endif -%}

        <div class="acct-input-group">
          <div class="acct-input-underline">
            <label for="recover-email">Email</label>
            <input
              class="acct-input"
              type="email"
              id="recover-email"
              name="email"
              autocomplete="email"
              required
            >
          </div>
        </div>

        <button type="submit" class="acct-btn-primary"><span>Submit</span></button>
      {%- endform -%}

      <div class="flex flex-col items-center gap-4 mt-6">
        <button class="acct-link" onclick="toggleRecovery(false)">Back to login</button>
      </div>
    </div>

  </div>
</div>

<script>
  function toggleRecovery(show) {
    document.getElementById('login-form').classList.toggle('hidden', show);
    document.getElementById('recover-form').classList.toggle('hidden', !show);
  }

  {%- form 'recover_customer_password' -%}
    {%- if form.posted_successfully? or form.errors -%}
      document.addEventListener('DOMContentLoaded', function () {
        toggleRecovery(true);
      });
    {%- endif -%}
  {%- endform -%}
</script>
