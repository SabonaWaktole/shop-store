{% layout 'theme' %}

<div class="w-full max-w-[480px] mx-auto px-6 py-24">

  {%- comment -%} ======== LOGIN FORM ======== {%- endcomment -%}
  <div id="login-form">
    <h1 class="text-2xl font-semibold tracking-tighter uppercase mb-10 text-center" style="color: #000;">
      Sign In
    </h1>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div class="mb-8 p-4 border text-sm" style="border-color: #ff3333; color: #ff3333;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="mb-6">
        <label
          for="customer-email"
          class="block text-xs font-medium uppercase tracking-widest mb-2"
          style="color: #737373;"
        >
          Email
        </label>
        <input
          type="email"
          id="customer-email"
          name="customer[email]"
          autocomplete="email"
          autocapitalize="off"
          required
          class="w-full border-0 border-b bg-transparent py-3 text-sm focus:ring-0 focus:border-black outline-none"
          style="border-color: #e5e5e5;"
        >
      </div>

      <div class="mb-8">
        <label
          for="customer-password"
          class="block text-xs font-medium uppercase tracking-widest mb-2"
          style="color: #737373;"
        >
          Password
        </label>
        <input
          type="password"
          id="customer-password"
          name="customer[password]"
          autocomplete="current-password"
          required
          class="w-full border-0 border-b bg-transparent py-3 text-sm focus:ring-0 focus:border-black outline-none"
          style="border-color: #e5e5e5;"
        >
      </div>

      <button
        type="submit"
        class="w-full py-4 text-sm tracking-widest uppercase font-medium hover:opacity-90 transition-opacity"
        style="background-color: #000; color: #fff;"
      >
        Sign In
      </button>
    {%- endform -%}

    <div class="mt-8 flex flex-col items-center gap-4 text-sm">
      <button
        type="button"
        onclick="toggleRecovery(true)"
        class="underline underline-offset-4 hover:opacity-70 transition-opacity"
        style="color: #737373;"
      >
        Forgot your password?
      </button>
      <a
        href="{{ routes.account_register_url }}"
        class="underline underline-offset-4 hover:opacity-70 transition-opacity"
        style="color: #737373;"
      >
        Create account
      </a>
    </div>
  </div>

  {%- comment -%} ======== RECOVER PASSWORD FORM ======== {%- endcomment -%}
  <div id="recover-form" class="hidden">
    <h1 class="text-2xl font-semibold tracking-tighter uppercase mb-4 text-center" style="color: #000;">
      Reset Password
    </h1>
    <p class="text-sm text-center mb-10" style="color: #737373;">
      We will send you an email to reset your password.
    </p>

    {%- form 'recover_customer_password' -%}
      {%- if form.errors -%}
        <div class="mb-8 p-4 border text-sm" style="border-color: #ff3333; color: #ff3333;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <div class="mb-8 p-4 text-sm" style="background-color: #f5f5f5; color: #000;">
          We've sent you an email with a link to update your password.
        </div>
      {%- endif -%}

      <div class="mb-8">
        <label
          for="recover-email"
          class="block text-xs font-medium uppercase tracking-widest mb-2"
          style="color: #737373;"
        >
          Email
        </label>
        <input
          type="email"
          id="recover-email"
          name="email"
          autocomplete="email"
          autocapitalize="off"
          required
          class="w-full border-0 border-b bg-transparent py-3 text-sm focus:ring-0 focus:border-black outline-none"
          style="border-color: #e5e5e5;"
        >
      </div>

      <button
        type="submit"
        class="w-full py-4 text-sm tracking-widest uppercase font-medium hover:opacity-90 transition-opacity"
        style="background-color: #000; color: #fff;"
      >
        Submit
      </button>
    {%- endform -%}

    <div class="mt-8 text-center">
      <button
        type="button"
        onclick="toggleRecovery(false)"
        class="text-sm underline underline-offset-4 hover:opacity-70 transition-opacity"
        style="color: #737373;"
      >
        Back to login
      </button>
    </div>
  </div>

</div>

<script>
  function toggleRecovery(show) {
    document.getElementById('login-form').classList.toggle('hidden', show);
    document.getElementById('recover-form').classList.toggle('hidden', !show);
  }

  // Auto-show recovery form if it was just submitted (posted_successfully or has errors)
  {%- form 'recover_customer_password' -%}
    {%- if form.posted_successfully? or form.errors -%}
      document.addEventListener('DOMContentLoaded', function () {
        toggleRecovery(true);
      });
    {%- endif -%}
  {%- endform -%}
</script>
