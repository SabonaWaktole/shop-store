{
  "layout": "password",
  "sections": {
    "header": {
      "type": "custom-password-header",
      "settings": {
        "bg_color": "#ffffff",
        "text_color": "#000000",
        "header_left_text": "PUBLIC EQUITY",
        "header_center_text": "EQUITY ISSUED",
        "header_right_text": "Enter using password"
      }
    },
    "main": {
      "type": "custom-password-main",
      "settings": {
        "bg_color": "transparent",
        "text_color": "#000000",
        "padding_top": 20,
        "padding_bottom": 60
      },
      "blocks": {
        "embed_1": {
          "type": "html_embed",
          "settings": {
            "html": ""
          }
        },
        "logo_1": {
          "type": "logo",
          "settings": {
            "width": 200
          }
        },
        "hero_1": {
          "type": "hero_image",
          "settings": {
            "width": 400
          }
        },
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "DROPPING SATURDAY JULY 11TH — 11AM PST"
          }
        },
        "subheading_1": {
          "type": "subheading",
          "settings": {
            "text": "BLACK HICKORY DOUBLE KNEE CAPRIS."
          }
        }
      },
      "block_order": [
        "logo_1",
        "hero_1",
        "heading_1",
        "subheading_1",
        "embed_1"
      ]
    },
    "footer": {
      "type": "custom-password-footer",
      "settings": {
        "full_screen": true
