{%- liquid
  assign aspect_ratio = aspect_ratio | default: settings.product_card_aspect_ratio | default: 'portrait'
  assign image_crop = image_crop | default: settings.product_card_image_crop | default: 'cover'
  assign show_hover_image = show_hover_image | default: settings.product_card_show_hover_image | default: true
  assign show_vendor = show_vendor | default: settings.product_card_show_vendor | default: false
  assign badge_style = badge_style | default: settings.product_card_badge_style | default: 'pill'
  assign enable_quick_add = enable_quick_add | default: settings.product_card_enable_quick_add | default: false

  assign aspect_class = 'aspect-[3/4]'
  if aspect_ratio == 'square'
    assign aspect_class = 'aspect-square'
  elsif aspect_ratio == 'landscape'
    assign aspect_class = 'aspect-[4/3]'
  elsif aspect_ratio == 'auto'
    assign aspect_class = 'aspect-auto'
  endif

  assign crop_class = 'object-cover'
  if image_crop == 'contain'
    assign crop_class = 'object-contain'
  endif
  
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign sold_out = false
  unless product.available
    assign sold_out = true
  endunless

  assign is_preorder = false
  if settings.enable_preorder and product.tags contains 'preorder'
    assign is_preorder = true
  endif
-%}

<div class="relative group bg-background flex flex-col h-full block border border-outline-variant transition-colors hover:border-primary">
    <a href="{{ product.url }}" class="w-full {{ aspect_class }} overflow-hidden relative block z-10">
        
        <!-- Badges -->
        <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
            {%- if sold_out -%}
                <span class="{% if badge_style == 'pill' %}px-3 py-1 rounded-full{% elsif badge_style == 'minimal' %}px-0{% else %}px-4 py-2{% endif %} bg-surface text-primary border border-outline-variant font-label-mono text-[10px] md:text-xs uppercase tracking-widest">
                    SOLD OUT
                </span>
            {%- elsif is_preorder -%}
                <span class="{% if badge_style == 'pill' %}px-3 py-1 rounded-full{% elsif badge_style == 'minimal' %}px-0{% else %}px-4 py-2{% endif %} bg-accent text-background font-label-mono text-[10px] md:text-xs uppercase tracking-widest">
                    PREORDER
                </span>
            {%- elsif on_sale -%}
                <span class="{% if badge_style == 'pill' %}px-3 py-1 rounded-full{% elsif badge_style == 'minimal' %}px-0{% else %}px-4 py-2{% endif %} bg-primary text-background font-label-mono text-[10px] md:text-xs uppercase tracking-widest">
                    SALE
                </span>
            {%- endif -%}
        </div>

        {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" class="w-full h-full {{ crop_class }} transition-all duration-700 group-hover:scale-105 {% if show_hover_image and product.media[1] %}group-hover:opacity-0{% endif %}" loading="lazy">
            
            {%- if show_hover_image and product.media[1] -%}
                <img src="{{ product.media[1] | image_url: width: 800 }}" alt="{{ product.media[1].alt | escape }}" class="absolute inset-0 w-full h-full {{ crop_class }} opacity-0 transition-opacity duration-700 group-hover:opacity-100 group-hover:scale-105" loading="lazy">
            {%- endif -%}
        {%- else -%}
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDk5ycd4thceAXEiwpMLssoHHkxDWgpOjfpuJaRMBxzOj55bCdJBqWcJ45gReTNYbQmLIA3F_m-GtKTGo29ng7f9L3hkJ0uFzX2Ma53iaZerYcRScBTRu1ph9n9A1GmR5l9SIPYGXNZVJS1UEFe1wXkF6I7IBvMZ1CxEH_tTm5CZFOCwjzc4_LqDgEZobif_csVEDYFTeHCBQPsGWBuxXKo2OeSsl9Il45vfHyLh71sRR7u7s6LY5a1ltW9jWUGKm6-A9X9ExER4d3l" alt="Placeholder" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
        {%- endif -%}

        <!-- Quick Add Overlay (Desktop) -->
        {%- if enable_quick_add and product.available -%}
            <div class="absolute bottom-0 left-0 w-full p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-20 hidden md:block">
                {%- form 'product', product, id: product.id, class: 'w-full' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <button type="submit" class="w-full bg-surface/90 backdrop-blur border border-outline-variant text-primary font-label-mono text-label-mono py-3 uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-colors cursor-pointer" onclick="event.preventDefault(); window.addToCart(this.form);">
                        + QUICK ADD
                    </button>
                {%- endform -%}
            </div>
        {%- endif -%}
    </a>
    
    <div class="p-6 flex flex-col font-label-mono text-label-mono uppercase border-t border-outline-variant group-hover:bg-primary group-hover:text-on-primary transition-colors duration-300 flex-grow z-10 relative pointer-events-none">
        {%- if show_vendor -%}
            <span class="text-[10px] text-on-surface-variant group-hover:text-on-primary/70 mb-1 tracking-widest">{{ product.vendor }}</span>
        {%- endif -%}
        <div class="flex justify-between items-start gap-4">
            <h2 class="truncate flex-1">{{ product.title | default: 'OBSIDIAN SHELL JACKET' }}</h2>
            <div class="flex flex-col items-end shrink-0">
                {%- if on_sale -%}
                    <span class="line-through text-on-surface-variant group-hover:text-on-primary/70 text-[10px]">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                <span>{{ product.price | money | default: '$850' }}</span>
            </div>
        </div>
    </div>
</div>

<script>
    if (typeof window.addToCart !== 'function') {
        window.addToCart = function(form) {
            const formData = new FormData(form);
            fetch(window.Shopify.routes.root + 'cart/add.js', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    if (typeof openCartDrawer === 'function') {
                        openCartDrawer();
                    } else {
                        window.location.href = '/cart';
                    }
                }
            })
            .catch(error => {
                console.error('Error adding to cart', error);
            });
        };
    }
</script>
