<style>
/* Material Symbols Adjustments */
.material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}

/* Scanner Animation */
@keyframes scan {
    0% { top: -10%; }
    100% { top: 110%; }
}
.animate-scanner {
    animation: scan 3s linear infinite;
}

@keyframes scannerDrift {
    0% { top: -5%; opacity: 0; }
    10% { opacity: 0.8; }
    90% { opacity: 0.8; }
    100% { top: 105%; opacity: 0; }
}
.scanner-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background-color: {{ settings.color_accent | default: '#ffffff' }};
    z-index: 10;
    box-shadow: 0 0 10px {{ settings.color_accent | default: '#ffffff' }}, 0 0 20px {{ settings.color_accent | default: '#ffffff' }};
    animation: scannerDrift 8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    pointer-events: none;
}

/* Scrollbar customization */
::-webkit-scrollbar {
    width: 4px;
}
::-webkit-scrollbar-track {
    background: {{ settings.color_bg_primary | default: '#131314' }};
}
::-webkit-scrollbar-thumb {
    background: {{ settings.color_border | default: '#444748' }};
}
::-webkit-scrollbar-thumb:hover {
    background: {{ settings.color_text_primary | default: '#ffffff' }};
}
.hide-scrollbar::-webkit-scrollbar {
    display: none;
}
.hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
}

/* Grid lines for brutalist design */
.grid-line-v { border-right: 1px solid {{ settings.color_border | default: '#444748' }}; }
.grid-line-h { border-bottom: 1px solid {{ settings.color_border | default: '#444748' }}; }

.bg-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
}

/* Cinetica Input */
.cinetica-input {
    border: none;
    border-bottom: 1px solid {{ settings.color_border | default: '#444748' }};
    background: transparent;
    color: {{ settings.color_text_primary | default: '#ffffff' }};
    border-radius: 0;
    padding: 0.5rem 0;
    transition: border-color 0.3s ease;
}
.cinetica-input:focus {
    outline: none;
    box-shadow: none;
    border-bottom-color: {{ settings.color_text_primary | default: '#ffffff' }};
}

/* Dynamic Overrides based on Schema */
{% unless settings.heading_uppercase %}
h1, h2, h3, h4, h5, h6, .font-display-xl, .font-headline-lg, .font-headline-lg-mobile {
    text-transform: none !important;
}
{% endunless %}

{% unless settings.button_uppercase %}
.btn, button, a.btn-primary {
    text-transform: none !important;
}
{% endunless %}

{{ settings.custom_css }}
</style>
