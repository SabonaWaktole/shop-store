                "primary": "{{ settings.color_text_primary | default: '#ffffff' }}",
                "primary-container": "#e2e2e2",
                "on-surface": "#e5e2e3",
                "error": "#ffb4ab",
                "surface-container-highest": "#353436",
                "tertiary-container": "#e3e2e2",
